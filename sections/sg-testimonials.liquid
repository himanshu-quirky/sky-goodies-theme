<style>
  .sg-test-section { padding: 40px 20px; max-width: 1200px; margin: 0 auto; }
  .sg-test-header { text-align: center; margin-bottom: 32px; }
  .sg-test-eyebrow { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 600; color: #E8845A; display: block; margin-bottom: 6px; }
  .sg-test-header h2 { font-family: 'DM Serif Display', serif; font-size: clamp(28px, 4vw, 40px); color: #1E1B18; margin: 0 0 8px; }
  .sg-test-sub { color: #7A7168; font-size: 15px; max-width: 560px; margin: 0 auto; }
  .sg-test-grid { display: grid; grid-template-columns: 1fr; gap: 16px; }
  @media (min-width: 750px) { .sg-test-grid { grid-template-columns: repeat(4, 1fr); } }
  .sg-test-card { background: #FFF; border-radius: 24px; overflow: hidden; border: 1px solid #EDE8E2; }
  .sg-test-img { aspect-ratio: 1/1; overflow: hidden; background: #FAF6F0; }
  .sg-test-img img { width: 100%; height: 100%; object-fit: cover; }
  .sg-test-body { padding: 20px; }
  .sg-test-stars { color: #D4A853; font-size: 16px; margin-bottom: 8px; }
  .sg-test-text { font-size: 14px; color: #3D3833; line-height: 1.6; margin-bottom: 12px; }
  .sg-test-name { font-weight: 600; font-size: 13px; color: #1E1B18; }
  .sg-test-verified { font-size: 11px; color: #7A7168; margin-left: 6px; }
  .sg-test-date { font-size: 11px; color: #A59C92; display: block; margin-top: 2px; }
</style>

<section class="sg-test-section" style="background:{{ section.settings.background_color }};" {{ section.shopify_attributes }}>
  <div class="sg-test-header">
    {% if section.settings.eyebrow != blank %}<span class="sg-test-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
    {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
    {% if section.settings.subheading != blank %}<p class="sg-test-sub">{{ section.settings.subheading }}</p>{% endif %}
  </div>
  <div class="sg-test-grid">
    {% if section.blocks.size == 0 %}
      {%- assign fb_imgs = 'https://cdn.shopify.com/s/files/1/0428/5530/1271/files/Sky-Goodies-Mini-Lantern-Fairy-Lights-Paper-Lamp-03.jpg,https://cdn.shopify.com/s/files/1/0428/5530/1271/products/Sky-Goodies-DIY-animals-BOX-setof12-5.jpg,https://cdn.shopify.com/s/files/1/0428/5530/1271/products/Sky_Goodies_Flower_Lights_WHITE_3000_04.jpg,https://cdn.shopify.com/s/files/1/0428/5530/1271/files/Sky-Goodies-Typewriter-Calendar-Colourful-2026-01.jpg' | split: ',' -%}
      {%- assign fb_texts = "The paper lantern arrived beautifully packed and lit up our living room like magic. Honestly didn't expect this level of craft for the price.|Built the elephant with my 7-year-old over a rainy Sunday. The instructions were clear and the finished piece is now proudly on his shelf.|Bought the paper flowers for my mum's birthday — she thought they were real until she touched them. So much better than cut flowers.|The 2026 calendar is a small joy every morning. Lovely illustrations, sturdy paper, and just the right size for my desk." | split: '|' -%}
      {%- assign fb_names = 'Ananya Rao,Vikram Shetty,Priya Menon,Rohan Bhattacharya' | split: ',' -%}
      {%- assign fb_dates = '2 March 2026,18 February 2026,9 March 2026,27 January 2026' | split: ',' -%}
      {%- for i in (0..3) -%}
        <div class="sg-test-card">
          <div class="sg-test-img">
            <img src="{{ fb_imgs[i] }}" alt="" loading="lazy" referrerpolicy="no-referrer">
          </div>
          <div class="sg-test-body">
            <div class="sg-test-stars">★★★★★</div>
            <p class="sg-test-text">{{ fb_texts[i] }}</p>
            <div><span class="sg-test-name">{{ fb_names[i] }}</span><span class="sg-test-verified">✓ Verified</span><span class="sg-test-date">{{ fb_dates[i] }}</span></div>
          </div>
        </div>
      {%- endfor -%}
    {% else %}
      {% for block in section.blocks %}
        <div class="sg-test-card" {{ block.shopify_attributes }}>
          {% if block.settings.customer_image != blank %}
            <div class="sg-test-img">
              <img src="{{ block.settings.customer_image | image_url: width: 600 }}" alt="" loading="lazy" referrerpolicy="no-referrer">
            </div>
          {% else %}
            <div class="sg-test-img">
              <img src="https://cdn.shopify.com/s/files/1/0428/5530/1271/files/Sky-Goodies-Mini-Lantern-Fairy-Lights-Paper-Lamp-03.jpg" alt="" loading="lazy" referrerpolicy="no-referrer">
            </div>
          {% endif %}
          <div class="sg-test-body">
            <div class="sg-test-stars">
              {% assign r = block.settings.rating | default: 5 %}
              {% for star in (1..r) %}★{% endfor %}
            </div>
            {% if block.settings.review_text != blank %}<p class="sg-test-text">{{ block.settings.review_text }}</p>{% endif %}
            <div>
              {% if block.settings.customer_name != blank %}<span class="sg-test-name">{{ block.settings.customer_name }}</span>{% endif %}
              {% if block.settings.verified %}<span class="sg-test-verified">✓ Verified</span>{% endif %}
              {% if block.settings.date != blank %}<span class="sg-test-date">{{ block.settings.date }}</span>{% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "SG Testimonials",
  "tag": "section",
  "class": "sg-section-wrapper",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "REVIEWS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real people, real craft" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#FDFCFA" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "limit": 12,
      "settings": [
        { "type": "image_picker", "id": "customer_image", "label": "Customer image" },
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Rating", "default": 5 },
        { "type": "textarea", "id": "review_text", "label": "Review text" },
        { "type": "text", "id": "customer_name", "label": "Customer name" },
        { "type": "checkbox", "id": "verified", "label": "Verified buyer", "default": true },
        { "type": "text", "id": "date", "label": "Date", "default": "12 March 2026" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG Testimonials",
      "blocks": [
        { "type": "review", "settings": { "rating": 5, "review_text": "The paper lantern arrived beautifully packed and lit up our living room like magic.", "customer_name": "Ananya Rao", "verified": true, "date": "2 March 2026" } },
        { "type": "review", "settings": { "rating": 5, "review_text": "Built the elephant with my 7-year-old over a rainy Sunday. Instructions were clear.", "customer_name": "Vikram Shetty", "verified": true, "date": "18 February 2026" } },
        { "type": "review", "settings": { "rating": 5, "review_text": "Bought the paper flowers for my mum's birthday — she thought they were real.", "customer_name": "Priya Menon", "verified": true, "date": "9 March 2026" } },
        { "type": "review", "settings": { "rating": 4, "review_text": "The 2026 calendar is a small joy every morning. Lovely illustrations.", "customer_name": "Rohan Bhattacharya", "verified": true, "date": "27 January 2026" } }
      ]
    }
  ]
}
{% endschema %}
