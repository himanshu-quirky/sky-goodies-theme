{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-test-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#FCEEE6' }};
    padding: 80px 0 100px;
    position: relative;
    overflow: hidden;
  }
  .sg-test-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: -1px; left: 0; right: 0;
    height: 80px;
    background: {{ section.settings.wave_color | default: '#FAF6F0' }};
    clip-path: ellipse(70% 100% at 50% 0%);
  }
  @media (min-width: 768px) {
    .sg-test-{{ section.id }}::before { height: 110px; clip-path: ellipse(100% 100% at 50% 0%); }
  }
  .sg-test-{{ section.id }} .sg-wrap { position: relative; z-index: 2; }
{%- endstyle -%}

<section class="sg-root sg-test-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-wrap">
    <div class="sg-test-top">
      <div class="sg-test-stars" aria-label="5 out of 5 stars">★ ★ ★ ★ ★</div>
      <div class="sg-test-meta">
        <span>{{ section.settings.rating | default: '4.9 stars' }}</span>
        <span class="divider"></span>
        <span>{{ section.settings.rating_label | default: 'Loved across India' }}</span>
      </div>
      <h2>{{ section.settings.heading | default: '50,000+ Happy Crafters' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="sg-polaroid-row">
      {%- for block in section.blocks -%}
        {%- assign rot = forloop.index | modulo: 3 -%}
        {%- assign rot_class = '' -%}
        {%- if rot == 1 -%}{%- assign rot_class = 'rot-l' -%}
        {%- elsif rot == 2 -%}{%- assign rot_class = 'rot-r' -%}
        {%- else -%}{%- assign rot_class = 'rot-l2' -%}
        {%- endif -%}
        <div class="sg-polaroid {{ rot_class }}" {{ block.shopify_attributes }}>
          <div class="sg-polaroid-img"
               {% if block.settings.image %}style="background-image: url('{{ block.settings.image | image_url: width: 600 }}');"{% endif %}></div>
          <blockquote>"{{ block.settings.quote | default: 'A genuinely lovely product.' }}"</blockquote>
          <div class="sg-polaroid-foot">★ ★ ★ ★ ★ · {{ block.settings.location | default: 'India' }}</div>
          <span class="sg-name-pill" style="background: {{ block.settings.pill_color | default: '#F5CF8A' }};">{{ block.settings.name | default: 'Reviewer' }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.sg-test-top { text-align: center; margin-bottom: 60px; }
.sg-test-stars {
  font-size: 28px;
  letter-spacing: 0;
  word-spacing: 8px;
  color: var(--sg-butter-dk);
  margin-bottom: 14px;
  line-height: 1;
}
.sg-test-meta {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  font-size: 15px;
  font-weight: 700;
  color: var(--sg-ink);
  margin-bottom: 20px;
}
.sg-test-meta .divider { width: 1px; height: 16px; background: rgba(30,27,24,.35); }
.sg-test-top h2 {
  font-family: var(--sg-display);
  font-weight: 900;
  font-size: clamp(44px, 7vw, 84px);
  color: var(--sg-forest);
  letter-spacing: -0.03em;
  margin: 0 0 12px;
}
.sg-test-top p { font-size: 17px; color: var(--sg-ink); font-weight: 600; }
.sg-polaroid-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px 24px;
}
@media (min-width: 768px) { .sg-polaroid-row { grid-template-columns: repeat(3, 1fr); } }
.sg-polaroid {
  background: var(--sg-white);
  border: 2px solid var(--sg-ink);
  border-radius: 20px;
  padding: 14px 14px 40px;
  position: relative;
  transition: transform .2s;
}
.sg-polaroid.rot-l { transform: rotate(-1.5deg); }
.sg-polaroid.rot-r { transform: rotate(1.2deg); }
.sg-polaroid.rot-l2 { transform: rotate(-0.8deg); }
.sg-polaroid:hover { transform: rotate(0deg) translateY(-4px); }
.sg-polaroid-img {
  aspect-ratio: 1;
  border-radius: 12px;
  overflow: hidden;
  background: var(--sg-sage);
  background-size: cover;
  background-position: center;
  margin-bottom: 14px;
}
.sg-polaroid blockquote {
  font-family: var(--sg-display);
  font-weight: 700;
  font-size: 17px;
  line-height: 1.3;
  color: var(--sg-forest);
  margin: 0 0 12px;
  font-style: italic;
}
.sg-polaroid-foot {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--sg-ink);
  font-weight: 700;
  letter-spacing: 1px;
}
.sg-name-pill {
  position: absolute;
  bottom: -14px; left: 50%;
  transform: translateX(-50%) rotate(-2deg);
  color: var(--sg-ink);
  border: 2px solid var(--sg-ink);
  padding: 6px 18px;
  border-radius: 999px;
  font-weight: 800;
  font-size: 14px;
  white-space: nowrap;
}
.sg-polaroid.rot-r .sg-name-pill { transform: translateX(-50%) rotate(1.5deg); }
.sg-polaroid.rot-l2 .sg-name-pill { transform: translateX(-50%) rotate(-1deg); }
</style>

{% schema %}
{
  "name": "SG — Testimonials (Polaroids)",
  "tag": "section",
  "class": "section-sg-testimonials",
  "settings": [
    { "type": "text", "id": "rating", "label": "Rating short", "default": "4.9 stars" },
    { "type": "text", "id": "rating_label", "label": "Rating subtitle", "default": "Loved across India" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "50,000+ Happy Crafters" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Don't take our word for it. Hear theirs!" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#FCEEE6" },
    { "type": "color", "id": "wave_color", "label": "Wave color (match prior section)", "default": "#FAF6F0" }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo (optional)" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Three Ganesh Chaturthis later, it's our family tradition." },
        { "type": "text", "id": "name", "label": "Reviewer name", "default": "Rashmi S." },
        { "type": "text", "id": "location", "label": "Location", "default": "Pune" },
        { "type": "color", "id": "pill_color", "label": "Name pill color", "default": "#F5CF8A" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Testimonials (Polaroids)",
      "blocks": [
        { "type": "review", "settings": { "quote": "Three Ganesh Chaturthis later, it's our family tradition. Such a beautiful eco-alternative.", "name": "Rashmi S.", "location": "Pune", "pill_color": "#F5CF8A" } },
        { "type": "review", "settings": { "quote": "Gifted the hot-air-balloon lamp kit at my sister's housewarming. Packaging alone made the evening.", "name": "Arjun M.", "location": "Bengaluru", "pill_color": "#F4BBA4" } },
        { "type": "review", "settings": { "quote": "My seven-year-old built the animals set with zero help. Hasn't stopped talking about it.", "name": "Priya K.", "location": "Mumbai", "pill_color": "#C8E616" } }
      ]
    }
  ]
}
{% endschema %}
