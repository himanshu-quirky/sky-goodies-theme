<section class="sg-section sg-testimonials" style="background:{{ section.settings.background_color }}; padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="sg-container">
    <div class="sg-section-header sg-text-center">
      <span class="sg-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="sg-h2">{{ section.settings.heading }}</h2>
      <p class="sg-subheading">{{ section.settings.subheading }}</p>
    </div>
    <div class="sg-reviews-scroll">
      {% for block in section.blocks %}
        <div class="sg-review-card" {{ block.shopify_attributes }}>
          {% if block.settings.customer_image != blank %}
            <div class="sg-review-image">
              <img src="{{ block.settings.customer_image | image_url: width: 800 }}" alt="" loading="lazy" referrerpolicy="no-referrer">
            </div>
          {% endif %}
          <div class="sg-review-body">
            <div class="sg-review-stars">
              {% for star in (1..block.settings.rating) %}<span>★</span>{% endfor %}
            </div>
            <p class="sg-review-text">{{ block.settings.review_text }}</p>
            <div class="sg-review-meta">
              <strong>{{ block.settings.customer_name }}</strong>
              {% if block.settings.verified %}<span class="sg-verified-badge">✓ Verified</span>{% endif %}
              {% if block.settings.date != blank %}<span class="sg-review-date">{{ block.settings.date }}</span>{% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SG Testimonials",
  "tag": "section",
  "class": "sg-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "REVIEWS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real people, real craft"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FDFCFA"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "customer_image",
          "label": "Customer image"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer name"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified buyer",
          "default": true
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "12 March 2026"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG Testimonials",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "The paper lantern arrived beautifully packed and lit up our living room like magic. Honestly didn't expect this level of craft for the price.",
            "customer_name": "Ananya Rao",
            "verified": true,
            "date": "2 March 2026"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "Built the elephant with my 7-year-old over a rainy Sunday. The instructions were clear and the finished piece is now proudly on his shelf.",
            "customer_name": "Vikram Shetty",
            "verified": true,
            "date": "18 February 2026"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "Bought the paper flowers for my mum's birthday — she thought they were real until she touched them. So much better than cut flowers.",
            "customer_name": "Priya Menon",
            "verified": true,
            "date": "9 March 2026"
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 4,
            "review_text": "The 2026 calendar is a small joy every morning. Lovely illustrations, sturdy paper, and just the right size for my desk.",
            "customer_name": "Rohan Bhattacharya",
            "verified": true,
            "date": "27 January 2026"
          }
        }
      ]
    }
  ]
}
{% endschema %}
