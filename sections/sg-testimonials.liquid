{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-rev-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#F5EFE3' }};
    padding: {{ section.settings.mobile_padding | default: 72 }}px 0;
  }
  @media (min-width: 900px) {
    .sg-rev-{{ section.id }} {
      padding: {{ section.settings.desktop_padding | default: 96 }}px 0;
    }
  }
{%- endstyle -%}

<section class="sg-root sg-rev-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-rev-head">
    <div class="sg-rev-rating">
      <span class="big">{{ section.settings.rating | default: '4.9' }}</span>
      <div>
        <div class="stars">★★★★★</div>
        <small>{{ section.settings.rating_subtext | default: '12,400+ verified reviews' }}</small>
      </div>
    </div>
    <h2>{{ section.settings.heading_line1 }}{%- if section.settings.heading_line2_em != blank -%}<br><em>{{ section.settings.heading_line2_em }}</em>{%- endif -%}</h2>
  </div>

  <div class="sg-rev-grid">
    {%- for block in section.blocks -%}
      <article class="sg-review" {{ block.shopify_attributes }}>
        <div class="sg-rev-imgs">
          <div {% if block.settings.image_1 %}style="background-image: url('{{ block.settings.image_1 | image_url: width: 600 }}');"{% endif %}></div>
          <div {% if block.settings.image_2 %}style="background-image: url('{{ block.settings.image_2 | image_url: width: 400 }}');"{% endif %}></div>
        </div>
        <div class="sg-rev-body">
          <div class="stars">★★★★★</div>
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.quote }}</p>
          <div class="sg-rev-by">
            <span class="avt" {% if block.settings.avatar %}style="background-image: url('{{ block.settings.avatar | image_url: width: 80 }}');"{% endif %}></span>
            <div>
              <strong>{{ block.settings.name }}</strong>
              <div style="font-size:11px; color:var(--sg-muted);">{{ block.settings.meta }}</div>
            </div>
            {%- if block.settings.verified -%}
              <span class="verified"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Verified</span>
            {%- endif -%}
          </div>
        </div>
      </article>
    {%- endfor -%}
  </div>
</section>

<style>
.sg-rev-head {
  max-width: var(--sg-container);
  margin: 0 auto 40px;
  padding: 0 var(--sg-gutter);
  text-align: center;
}
.sg-rev-rating {
  display: inline-flex;
  align-items: baseline;
  gap: 14px;
  background: var(--sg-ivory);
  padding: 16px 32px;
  border-radius: var(--sg-r-pill);
  box-shadow: var(--sg-shadow-sm);
  margin-bottom: 22px;
  border: 1px solid var(--sg-line);
}
.sg-rev-rating .big {
  font-family: var(--sg-display);
  font-style: italic;
  font-weight: 500;
  font-size: 36px;
  color: var(--sg-ink);
  line-height: 1;
}
.sg-rev-rating .stars {
  color: var(--sg-gold);
  font-size: 17px;
  letter-spacing: 2px;
  line-height: 1;
  display: block;
  margin-bottom: 4px;
}
.sg-rev-rating small {
  font-size: 12px;
  color: var(--sg-muted);
  font-weight: 500;
}
.sg-rev-head h2 {
  font-family: var(--sg-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(30px, 3.8vw, 50px);
  color: var(--sg-ink);
  letter-spacing: -0.02em;
  line-height: 1.05;
}
.sg-rev-head h2 em { font-style: normal; font-weight: 500; color: var(--sg-terra); }

.sg-rev-grid {
  max-width: var(--sg-container);
  margin: 0 auto;
  padding: 0 var(--sg-gutter);
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}
@media (min-width: 768px) { .sg-rev-grid { grid-template-columns: repeat(3, 1fr); gap: 22px; } }

.sg-review {
  background: var(--sg-ivory);
  border: 1px solid var(--sg-line);
  border-radius: var(--sg-r-md);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform .25s, box-shadow .25s;
}
.sg-review:hover { transform: translateY(-3px); box-shadow: var(--sg-shadow); }
.sg-rev-imgs {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 2px;
  aspect-ratio: 16/10;
}
.sg-rev-imgs > div {
  background-size: cover;
  background-position: center;
  background-color: var(--sg-paper-2);
}
.sg-rev-body { padding: 20px 22px 22px; }
.sg-review .stars { color: var(--sg-gold); letter-spacing: 2px; font-size: 14px; margin-bottom: 10px; }
.sg-review h4 {
  font-family: var(--sg-display);
  font-style: italic;
  font-weight: 500;
  font-size: 17px;
  color: var(--sg-ink);
  margin-bottom: 8px;
  line-height: 1.25;
}
.sg-review p {
  font-size: 13.5px;
  color: var(--sg-brown);
  line-height: 1.55;
  margin-bottom: 16px;
}
.sg-rev-by {
  display: flex; align-items: center; gap: 10px;
  font-size: 12.5px; color: var(--sg-brown);
  padding-top: 14px;
  border-top: 1px solid var(--sg-line);
}
.sg-rev-by .avt {
  width: 32px; height: 32px;
  background-size: cover; background-position: center;
  background-color: var(--sg-peach);
  border-radius: 50%;
}
.sg-rev-by strong { color: var(--sg-ink); font-weight: 600; }
.sg-rev-by .verified {
  display: inline-flex; align-items: center; gap: 4px;
  margin-left: auto;
  font-size: 10.5px;
  color: #3E8E6B;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.sg-rev-by .verified svg { width: 11px; height: 11px; }
</style>

{% schema %}
{
  "name": "SG — Testimonials",
  "tag": "section",
  "class": "section-sg-testimonials",
  "settings": [
    { "type": "header", "content": "Overall rating" },
    { "type": "text", "id": "rating", "label": "Big rating number", "default": "4.9" },
    { "type": "text", "id": "rating_subtext", "label": "Subtext", "default": "12,400+ verified reviews" },
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "heading_line1", "label": "Line 1", "default": "Real words from" },
    { "type": "text", "id": "heading_line2_em", "label": "Line 2 (italic)", "default": "crafters." },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F5EFE3" },
    { "type": "range", "id": "mobile_padding", "label": "Mobile padding (px)", "min": 20, "max": 120, "step": 4, "default": 72 },
    { "type": "range", "id": "desktop_padding", "label": "Desktop padding (px)", "min": 20, "max": 200, "step": 4, "default": 96 }
  ],
  "max_blocks": 9,
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "image_1", "label": "Image 1 (main)" },
        { "type": "image_picker", "id": "image_2", "label": "Image 2 (secondary)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Has made my kitchen feel like a café." },
        { "type": "textarea", "id": "quote", "label": "Review quote", "default": "Thick paper, beautiful print. Better than any calendar I've paid twice as much for." },
        { "type": "image_picker", "id": "avatar", "label": "Reviewer avatar (square)" },
        { "type": "text", "id": "name", "label": "Reviewer name", "default": "Sanjana P." },
        { "type": "text", "id": "meta", "label": "Reviewer meta", "default": "Pune · May 2026" },
        { "type": "checkbox", "id": "verified", "label": "Show verified badge", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Testimonials",
      "blocks": [
        { "type": "review", "settings": { "title": "Has made my kitchen feel like a café.", "name": "Sanjana P.", "meta": "Pune · May 2026" } },
        { "type": "review", "settings": { "title": "Bought five for my team. Legends.", "name": "Rahul D.", "meta": "Bengaluru · Apr 2026" } },
        { "type": "review", "settings": { "title": "My 7-year-old finished it in one afternoon.", "name": "Priya K.", "meta": "Mumbai · Apr 2026" } }
      ]
    }
  ]
}
{% endschema %}
