{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-section-{{ section.id }}-pad {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .sg-section-{{ section.id }}-pad {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .sg-split { max-width: 1200px; margin: 0 auto; padding-left: 20px; padding-right: 20px; }
  .sg-split__head { text-align: center; margin-bottom: 32px; }
  .sg-split__head .sg-heading { font-family: 'DM Serif Display', serif; font-size: clamp(28px, 4vw, 44px); color: #1E1B18; line-height: 1.15; margin: 8px 0 12px; }
  .sg-split__head .sg-eyebrow { font-size: 12px; font-weight: 600; letter-spacing: 0.12em; color: #E8845A; text-transform: uppercase; }
  .sg-split__head .sg-subtext { color: #7A7168; max-width: 580px; margin: 0 auto; font-size: 15px; }
  .sg-split__layout { display: grid; grid-template-columns: 1fr; gap: 24px; align-items: center; }
  @media (min-width: 750px) { .sg-split__layout { grid-template-columns: 1fr 1fr; gap: 48px; } .sg-split--flip .sg-split__layout { direction: rtl; } .sg-split--flip .sg-split__layout > * { direction: ltr; } }
  .sg-split__image { border-radius: 24px; overflow: hidden; aspect-ratio: 4/5; max-height: 520px; }
  .sg-split__image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .sg-split__products { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .sg-split__products .sg-product-card { max-width: 100%; }
  .sg-split__products img { max-height: 260px; object-fit: cover; }
{%- endstyle -%}

{%- liquid
  assign split_collection = section.settings.collection
  assign split_img = nil
  if section.settings.image != blank
    assign split_img = section.settings.image
  elsif split_collection != blank and split_collection.image != blank
    assign split_img = split_collection.image
  elsif split_collection != blank and split_collection.products.first.featured_image != blank
    assign split_img = split_collection.products.first.featured_image
  endif
-%}

<section
  class="sg-section sg-split {% if section.settings.flip_layout %}sg-split--flip{% endif %} sg-section-{{ section.id }}-pad"
  style="background: {{ section.settings.bg_color }};"
  {{ section.shopify_attributes }}
>
  <div class="sg-split__inner">
    <div class="sg-split__head">
      {%- if section.settings.eyebrow != blank -%}
        <div class="sg-eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="sg-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="sg-subtext">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="sg-split__layout">
      <!-- Image side -->
      <div class="sg-split__image">
        {%- if split_img != nil -%}
          <img
            src="{{ split_img | image_url: width: 800 }}"
            srcset="{{ split_img | image_url: width: 400 }} 400w, {{ split_img | image_url: width: 800 }} 800w"
            sizes="(max-width: 749px) 100vw, 50vw"
            alt="{{ section.settings.image_heading | default: section.settings.heading | escape }}"
            width="800"
            height="1000"
            loading="lazy"
          >
        {%- else -%}
          <div class="sg-placeholder" style="min-height:400px">
            <span style="font-size:14px;font-weight:600;">Add image or link a collection</span>
          </div>
        {%- endif -%}
        <div class="sg-split__image-ov">
          {%- if section.settings.image_heading != blank -%}
            <p>{{ section.settings.image_heading }}</p>
          {%- endif -%}
          {%- assign split_image_link = section.settings.image_link -%}
          {%- if split_image_link == blank and split_collection != blank -%}
            {%- assign split_image_link = split_collection.url -%}
          {%- endif -%}
          {%- if split_image_link != blank -%}
            <a href="{{ split_image_link }}" class="sg-split__image-link">
              {{ section.settings.image_link_text | default: 'Shop now' }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Products side -->
      <div class="sg-products-grid">
        {%- if split_collection != blank and split_collection.products_count > 0 -%}
          {%- for product in split_collection.products limit: section.settings.products_to_show -%}
            {%- render 'sg-product-card', product: product -%}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="sg-pc">
              <div class="sg-pc__img"><div class="sg-placeholder">Product {{ i }}</div></div>
              <div class="sg-pc__body">
                <div class="sg-pc__category">Category</div>
                <h3 class="sg-pc__title">Sample Product {{ i }}</h3>
                <div class="sg-pc__footer">
                  <span class="sg-pc__price">Rs. 499</span>
                  <button class="sg-pc__atc" type="button">Add</button>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SG Split Collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "For little makers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Busy hands, bright minds"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Paper kits that turn a quiet afternoon into something they made themselves."
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Feature Image",
      "info": "Overrides the collection image. If empty, collection image is used automatically."
    },
    {
      "type": "text",
      "id": "image_heading",
      "label": "Image Overlay Text",
      "default": "40+ activity kits for every kind of curious kid"
    },
    {
      "type": "text",
      "id": "image_link_text",
      "label": "Image Link Text",
      "default": "Shop kids' kits"
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "Image Link URL",
      "info": "If empty, links to the collection automatically."
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "flip_layout",
      "label": "Flip layout (image on right)",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FDFCFA"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "SG Split Collection"
    }
  ]
}
{% endschema %}
