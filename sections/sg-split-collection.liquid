{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-section-{{ section.id }}-pad {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .sg-section-{{ section.id }}-pad {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="sg-section sg-split {% if section.settings.flip_layout %}sg-split--flip{% endif %} sg-section-{{ section.id }}-pad"
  style="background: {{ section.settings.bg_color }};"
  {{ section.shopify_attributes }}
>
  <div class="sg-split__inner">
    <div class="sg-split__head">
      {%- if section.settings.eyebrow != blank -%}
        <div class="sg-eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="sg-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="sg-subtext">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="sg-split__layout">
      <!-- Image side -->
      <div class="sg-split__image">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.image_heading | escape }}" width="800" height="1000" loading="lazy">
        {%- else -%}
          <div class="sg-placeholder" style="min-height:400px">Feature image</div>
        {%- endif -%}
        <div class="sg-split__image-ov">
          {%- if section.settings.image_heading != blank -%}
            <p>{{ section.settings.image_heading }}</p>
          {%- endif -%}
          {%- if section.settings.image_link != blank -%}
            <a href="{{ section.settings.image_link }}" class="sg-split__image-link">
              {{ section.settings.image_link_text | default: 'Shop now' }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Products side -->
      <div class="sg-products-grid">
        {%- assign split_collection = section.settings.collection -%}
        {%- if split_collection != blank and split_collection.products_count > 0 -%}
          {%- for product in split_collection.products limit: section.settings.products_to_show -%}
            <div class="sg-pc">
              <div class="sg-pc__img">
                <a href="{{ product.url }}">
                  {%- if product.featured_image != blank -%}
                    <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" width="400" height="400" loading="lazy">
                  {%- else -%}
                    <div class="sg-placeholder">{{ product.title }}</div>
                  {%- endif -%}
                </a>
                {%- if product.compare_at_price > product.price -%}
                  {%- assign save_pct = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
                  <span class="sg-pc__badge sg-pc__badge--sale">{{ save_pct }}% off</span>
                {%- endif -%}
              </div>
              <div class="sg-pc__body">
                <div class="sg-pc__category">{{ product.type }}</div>
                <h3 class="sg-pc__title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
                <div class="sg-pc__footer">
                  <span class="sg-pc__price">
                    {{ product.price | money_without_trailing_zeros }}
                    {%- if product.compare_at_price > product.price -%}<del>{{ product.compare_at_price | money_without_trailing_zeros }}</del>{%- endif -%}
                  </span>
                  {%- form 'product', product -%}
                    <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                    <button type="submit" class="sg-pc__atc" {% unless product.available %}disabled{% endunless %}>
                      {%- if product.available -%}Add{%- else -%}Sold out{%- endif -%}
                    </button>
                  {%- endform -%}
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="sg-pc">
              <div class="sg-pc__img"><div class="sg-placeholder">Product {{ i }}</div></div>
              <div class="sg-pc__body">
                <div class="sg-pc__category">Category</div>
                <h3 class="sg-pc__title">Sample Product {{ i }}</h3>
                <div class="sg-pc__footer">
                  <span class="sg-pc__price">Rs. 499</span>
                  <button class="sg-pc__atc" type="button">Add</button>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SG Split Collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "For little makers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Busy hands, bright minds"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Paper kits that turn a quiet afternoon into something they made themselves."
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Feature Image"
    },
    {
      "type": "text",
      "id": "image_heading",
      "label": "Image Overlay Text",
      "default": "40+ activity kits for every kind of curious kid"
    },
    {
      "type": "text",
      "id": "image_link_text",
      "label": "Image Link Text",
      "default": "Shop kids' kits"
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "Image Link URL"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "flip_layout",
      "label": "Flip layout (image on right)",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FDFCFA"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "SG Split Collection"
    }
  ]
}
{% endschema %}
