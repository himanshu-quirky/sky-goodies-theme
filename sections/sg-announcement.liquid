{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-util-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.vertical_padding }}px 16px;
    font-size: {{ section.settings.font_size }}px;
    font-weight: 500;
    letter-spacing: 0.01em;
    border-bottom: 1px solid {{ section.settings.border_color | default: '#F8DCCA' }};
  }
  .sg-util-{{ section.id }} a { text-decoration: underline; text-underline-offset: 3px; }
  .sg-util-{{ section.id }} a:hover { opacity: 0.8; }
{%- endstyle -%}

<div class="sg-root sg-util-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-util-in">
    <div class="sg-util-left">
      {%- if section.settings.show_icon -%}<span>{{ section.settings.icon | default: '✿' }}</span>{%- endif -%}
      <span>
        {{ section.settings.message }}
        {%- if section.settings.link_text != blank and section.settings.link_url != blank -%}
          <a href="{{ section.settings.link_url }}">{{ section.settings.link_text }}</a>
        {%- endif -%}
      </span>
    </div>
    <div class="sg-util-right">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
.sg-util-in {
  max-width: var(--sg-container);
  margin: 0 auto;
  padding: 0 var(--sg-gutter);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}
.sg-util-left { display: flex; gap: 10px; align-items: center; }
.sg-util-right { display: flex; gap: 16px; font-size: 11.5px; }
@media (max-width: 640px) {
  .sg-util-in { justify-content: center; text-align: center; }
  .sg-util-right { display: none; }
}
</style>

{% schema %}
{
  "name": "SG — Announcement Bar",
  "tag": "section",
  "class": "section-sg-announcement",
  "settings": [
    { "type": "header", "content": "Main message" },
    { "type": "checkbox", "id": "show_icon", "label": "Show leading icon", "default": true },
    { "type": "text", "id": "icon", "label": "Icon (emoji/glyph)", "default": "✿" },
    { "type": "text", "id": "message", "label": "Message", "default": "Shopping for Mom?" },
    { "type": "text", "id": "link_text", "label": "Linked text", "default": "Order by May 8 for Mother's Day delivery" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FCEEE6" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#D26939" },
    { "type": "color", "id": "border_color", "label": "Border", "default": "#F8DCCA" },
    { "type": "range", "id": "vertical_padding", "label": "Vertical padding (px)", "min": 6, "max": 20, "step": 1, "default": 9 },
    { "type": "range", "id": "font_size", "label": "Font size (px)", "min": 11, "max": 15, "step": 1, "default": 12 }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Right-side link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Track Order" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "SG — Announcement Bar",
      "blocks": [
        { "type": "link", "settings": { "label": "Track Order" } },
        { "type": "link", "settings": { "label": "Log in" } },
        { "type": "link", "settings": { "label": "WhatsApp" } }
      ]
    }
  ]
}
{% endschema %}
