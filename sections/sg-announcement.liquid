{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-announce-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.vertical_padding }}px var(--sg-gutter);
    font-weight: 700;
    font-size: {{ section.settings.font_size }}px;
    letter-spacing: 0.02em;
    position: relative;
    overflow: hidden;
  }
  .sg-announce-{{ section.id }} .sg-announce-track {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 26px;
    gap: 16px;
  }
  .sg-announce-{{ section.id }} .sg-announce-msg {
    display: none;
    align-items: center;
    gap: 8px;
    transition: opacity .4s ease;
    text-align: center;
  }
  .sg-announce-{{ section.id }} .sg-announce-msg.is-active {
    display: inline-flex;
  }
  .sg-announce-{{ section.id }} .sg-announce-arrow {
    width: 26px;
    height: 26px;
    color: inherit;
    opacity: 0.7;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    transition: opacity .2s;
    background: none;
    border: none;
    cursor: pointer;
  }
  .sg-announce-{{ section.id }} .sg-announce-arrow:hover { opacity: 1; }
{%- endstyle -%}

<div class="sg-root sg-announce-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-announce-track">
    {%- if section.blocks.size > 1 -%}
      <button class="sg-announce-arrow" data-dir="prev" aria-label="Previous">‹</button>
    {%- endif -%}
    {%- for block in section.blocks -%}
      <span class="sg-announce-msg{% if forloop.first %} is-active{% endif %}" data-msg="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        {{ block.settings.text }}
      </span>
    {%- endfor -%}
    {%- if section.blocks.size > 1 -%}
      <button class="sg-announce-arrow" data-dir="next" aria-label="Next">›</button>
    {%- endif -%}
  </div>
</div>

{%- if section.blocks.size > 1 and section.settings.autoplay -%}
<script>
(function() {
  var root = document.querySelector('.sg-announce-{{ section.id }}');
  if (!root) return;
  var msgs = root.querySelectorAll('.sg-announce-msg');
  var i = 0;
  function show(n) {
    i = (n + msgs.length) % msgs.length;
    msgs.forEach(function(m, idx) { m.classList.toggle('is-active', idx === i); });
  }
  root.querySelector('[data-dir="next"]').addEventListener('click', function() { show(i + 1); });
  root.querySelector('[data-dir="prev"]').addEventListener('click', function() { show(i - 1); });
  setInterval(function() { show(i + 1); }, {{ section.settings.speed | default: 4500 }});
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "SG — Announcement Bar",
  "tag": "section",
  "class": "section-sg-announcement",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#F2EADB"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#D26939"
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding (px)",
      "min": 6,
      "max": 20,
      "step": 1,
      "default": 10
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size (px)",
      "min": 11,
      "max": 16,
      "step": 1,
      "default": 13
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate messages",
      "default": true
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Rotation speed (ms)",
      "min": 2000,
      "max": 10000,
      "step": 500,
      "default": 4500
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Message",
          "default": "<p>Free Shipping over <strong>₹1,000</strong> · Easy Returns</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Announcement Bar",
      "blocks": [
        { "type": "message", "settings": { "text": "<p>Free Shipping over <strong>₹1,000</strong> · Easy Returns</p>" } },
        { "type": "message", "settings": { "text": "<p>Save ₹50 on <strong>Prepaid Orders</strong> · Code PREPAID50</p>" } },
        { "type": "message", "settings": { "text": "<p><strong>COD</strong> available across India · Ships in 24 hrs</p>" } }
      ]
    }
  ]
}
{% endschema %}
