          "id": "heading_line_height",
          "label": "Heading line height",
          "min": 20,
          "max": 120,
          "step": 2,
          "unit": "px",
          "default": 58
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Explore our latest arrivals and elevate your everyday look."
        },
        {
          "type": "range",
          "id": "description_size",
          "label": "Description font size",
          "min": 10,
          "max": 28,
          "step": 1,
          "unit": "px",
          "default": 15
        },
        {
          "type": "header",
          "content": "Text Colors"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Subheading & description color",
          "default": "#ffffff"
        },
        {
          "type": "header",
          "content": "Button 1"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "default": "solid",
          "options": [
            { "value": "solid",   "label": "Solid" },
            { "value": "outline", "label": "Outline" },
            { "value": "text",    "label": "Text link" }
          ]
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button text color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button background",
          "default": "#1a1a1a"
        },
        {
          "type": "color",
          "id": "button_border_color",
          "label": "Button border color",
          "default": "#1a1a1a"
        },
        {
          "type": "header",
          "content": "Button 2 (optional)"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Button 2 label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Button 2 link"
        },
        {
          "type": "select",
          "id": "button_style_2",
          "label": "Button 2 style",
          "default": "outline",
          "options": [
            { "value": "solid",   "label": "Solid" },
            { "value": "outline", "label": "Outline" },
            { "value": "text",    "label": "Text link" }
          ]
        },
        {
          "type": "color",
          "id": "button_text_color_2",
          "label": "Button 2 text color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "button_bg_color_2",
          "label": "Button 2 background",
          "default": "rgba(0,0,0,0)"
        },
        {
          "type": "color",
          "id": "button_border_color_2",
          "label": "Button 2 border color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
