{{ 'section-slideshow.css' | asset_url | stylesheet_tag }}

{%- if section.blocks.size > 0 -%}
  {%- liquid
    assign autoplay        = section.settings.autoplay
    assign autoplay_speed  = section.settings.autoplay_speed
    assign transition_fade = section.settings.transition_fade
    assign show_dots       = section.settings.show_dots
    assign show_arrows     = section.settings.show_arrows
  -%}

  <div
    class="slideshow-section"
    id="slideshow-{{ section.id }}"
    data-section-id="{{ section.id }}"
    data-autoplay="{{ autoplay }}"
    data-autoplay-speed="{{ autoplay_speed }}"
    data-transition-fade="{{ transition_fade }}"
  >

    {%- comment -%} Slides wrapper {%- endcomment -%}
    <div class="slideshow__track" data-slideshow-track>

      {%- for block in section.blocks -%}
        {%- if block.type == 'slide' -%}

          <div
            class="slideshow__slide{% if forloop.first %} is-active{% endif %}"
            id="slide-{{ block.id }}"
            {{ block.shopify_attributes }}
          >

            {%- comment -%} Background image {%- endcomment -%}
            <div class="slideshow__media">
              {%- if block.settings.image != blank -%}
                {%- assign img = block.settings.image -%}
                {{
                  img
                  | image_url: width: 1920
                  | image_tag:
                    loading: 'lazy',
                    widths: '375, 750, 1100, 1500, 1780, 1920',
                    sizes: '100vw',
                    class: 'slideshow__img',
                    alt: img.alt | escape
                }}
              {%- else -%}
                <div class="slideshow__placeholder">
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'slideshow__placeholder-svg' }}
                </div>
              {%- endif -%}

              {%- if block.settings.image_mobile != blank -%}
                {%- assign img_mb = block.settings.image_mobile -%}
                {{
                  img_mb
                  | image_url: width: 750
                  | image_tag:
                    loading: 'lazy',
                    widths: '375, 750',
                    sizes: '100vw',
                    class: 'slideshow__img slideshow__img--mobile',
                    alt: img_mb.alt | escape
                }}
              {%- endif -%}
            </div>

            {%- comment -%} Full-slide clickable link {%- endcomment -%}
            {%- if block.settings.button_link != blank -%}
              <a
                href="{{ block.settings.button_link }}"
                class="slideshow__full-link"
                aria-label="{{ block.settings.heading | default: 'View' | escape }}"
                tabindex="-1"
              ></a>
            {%- endif -%}

            {%- comment -%} Overlay {%- endcomment -%}
            {%- if block.settings.overlay_opacity > 0 -%}
              <div
                class="slideshow__overlay"
                style="background-color: {{ block.settings.overlay_color }}; opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
              ></div>
            {%- endif -%}

            {%- comment -%} Content {%- endcomment -%}
            {%- if block.settings.heading != blank
              or block.settings.subheading != blank
              or block.settings.description != blank
              or block.settings.button_label != blank
            -%}
              <div
                class="slideshow__content slideshow__content--{{ block.settings.content_position }} slideshow__content--text-{{ block.settings.text_alignment }}"
                style="max-width: {{ block.settings.content_max_width }}px;"
              >

                {%- if block.settings.subheading != blank -%}
                  <p
                    class="slideshow__subheading"
                    style="color: {{ block.settings.text_color }}; font-size: {{ block.settings.subheading_size }}px;"
                  >
                    {{ block.settings.subheading }}
                  </p>
                {%- endif -%}

                {%- if block.settings.heading != blank -%}
                  <h2
                    class="slideshow__heading"
                    style="color: {{ block.settings.heading_color }}; font-size: {{ block.settings.heading_size }}px; line-height: {{ block.settings.heading_line_height }}px;"
                  >
                    {{ block.settings.heading }}
                  </h2>
                {%- endif -%}

                {%- if block.settings.description != blank -%}
                  <p
                    class="slideshow__description"
                    style="color: {{ block.settings.text_color }}; font-size: {{ block.settings.description_size }}px;"
                  >
                    {{ block.settings.description }}
                  </p>
                {%- endif -%}

                {%- if block.settings.button_label != blank -%}
                  <div class="slideshow__buttons">
                    <a
                      href="{{ block.settings.button_link | default: '#' }}"
                      class="slideshow__btn slideshow__btn--{{ block.settings.button_style }}"
                      style="
                        color: {{ block.settings.button_text_color }};
                        background-color: {{ block.settings.button_bg_color }};
                        border-color: {{ block.settings.button_border_color }};
                      "
                    >
                      {{ block.settings.button_label }}
                    </a>

                    {%- if block.settings.button_label_2 != blank -%}
                      <a
                        href="{{ block.settings.button_link_2 | default: '#' }}"
                        class="slideshow__btn slideshow__btn--{{ block.settings.button_style_2 }}"
                        style="
                          color: {{ block.settings.button_text_color_2 }};
                          background-color: {{ block.settings.button_bg_color_2 }};
                          border-color: {{ block.settings.button_border_color_2 }};
                        "
                      >
                        {{ block.settings.button_label_2 }}
                      </a>
                    {%- endif -%}
                  </div>
                {%- endif -%}

              </div>
            {%- endif -%}

          </div>

        {%- endif -%}
      {%- endfor -%}

    </div><!-- /.slideshow__track -->

    {%- comment -%} Navigation arrows {%- endcomment -%}
    {%- if show_arrows and section.blocks.size > 1 -%}
      <button class="slideshow__arrow slideshow__arrow--prev" aria-label="Previous slide" data-prev>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="slideshow__arrow slideshow__arrow--next" aria-label="Next slide" data-next>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    {%- endif -%}

    {%- comment -%} Dot pagination {%- endcomment -%}
    {%- if show_dots and section.blocks.size > 1 -%}
      <div class="slideshow__dots" data-dots>
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            <button
              class="slideshow__dot{% if forloop.first %} is-active{% endif %}"
              aria-label="Go to slide {{ forloop.index }}"
              data-dot="{{ forloop.index0 }}"
            ></button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div><!-- /#slideshow-{{ section.id }} -->

  <style>
    #slideshow-{{ section.id }} {
      background-color: {{ section.settings.section_bg }};
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
    #slideshow-{{ section.id }} .slideshow__arrow {
      color: {{ section.settings.arrow_color }};
      background-color: {{ section.settings.arrow_bg }};
      border-color: {{ section.settings.arrow_border }};
    }
    #slideshow-{{ section.id }} .slideshow__arrow:hover {
      color: {{ section.settings.arrow_color_hover }};
      background-color: {{ section.settings.arrow_bg_hover }};
    }
    #slideshow-{{ section.id }} .slideshow__dot {
      background-color: {{ section.settings.dot_color }};
    }
    #slideshow-{{ section.id }} .slideshow__dot.is-active {
      background-color: {{ section.settings.dot_active_color }};
    }
  </style>

  <script>
    (function () {
      const section   = document.getElementById('slideshow-{{ section.id }}');
      if (!section) return;

      const track     = section.querySelector('[data-slideshow-track]');
      const slides    = Array.from(track ? track.querySelectorAll('.slideshow__slide') : []);
      const dots      = Array.from(section.querySelectorAll('[data-dot]'));
      const btnPrev   = section.querySelector('[data-prev]');
      const btnNext   = section.querySelector('[data-next]');

      const autoplay  = section.dataset.autoplay === 'true';
      const speed     = parseInt(section.dataset.autoplaySpeed) || 5000;
      const fade      = section.dataset.transitionFade === 'true';

      let current = 0;
      let timer   = null;

      if (slides.length < 2) return;

      /* Apply fade class if needed */
      if (fade) section.classList.add('slideshow--fade');

      function goTo(index) {
        slides[current].classList.remove('is-active');
        if (dots[current]) dots[current].classList.remove('is-active');

        current = (index + slides.length) % slides.length;

        slides[current].classList.add('is-active');
        if (dots[current]) dots[current].classList.add('is-active');

        /* Move track for slide mode */
        if (!fade && track) {
          track.style.transform = 'translateX(-' + (current * 100) + '%)';
        }
      }

      function startTimer() {
        if (!autoplay) return;
        clearInterval(timer);
        timer = setInterval(() => goTo(current + 1), speed);
      }

      function stopTimer() { clearInterval(timer); }

      if (btnPrev) btnPrev.addEventListener('click', () => { goTo(current - 1); stopTimer(); startTimer(); });
      if (btnNext) btnNext.addEventListener('click', () => { goTo(current + 1); stopTimer(); startTimer(); });

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          goTo(parseInt(dot.dataset.dot));
          stopTimer();
          startTimer();
        });
      });

      /* Pause on hover */
      section.addEventListener('mouseenter', stopTimer);
      section.addEventListener('mouseleave', startTimer);

      /* Touch / swipe */
      let touchStartX = 0;
      section.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0].clientX; }, { passive: true });
      section.addEventListener('touchend', (e) => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) {
          goTo(diff > 0 ? current + 1 : current - 1);
          stopTimer();
          startTimer();
        }
      }, { passive: true });

      startTimer();
    })();
  </script>

{%- endif -%}

{% schema %}
{
  "name": "Slideshow",
  "tag": "section",
  "class": "section-slideshow",
  "max_blocks": 10,
  "settings": [
    {
      "type": "header",
      "content": "Slideshow Settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "select",
      "id": "autoplay_speed",
      "label": "Change slides every",
      "default": "5000",
      "options": [
        { "value": "3000", "label": "3 seconds" },
        { "value": "4000", "label": "4 seconds" },
        { "value": "5000", "label": "5 seconds" },
        { "value": "6000", "label": "6 seconds" },
        { "value": "7000", "label": "7 seconds" },
        { "value": "8000", "label": "8 seconds" },
        { "value": "9000", "label": "9 seconds" },
        { "value": "10000", "label": "10 seconds" }
      ]
    },
    {
      "type": "checkbox",
      "id": "transition_fade",
      "label": "Use fade transition (instead of slide)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dot indicators",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow icon color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "arrow_bg",
      "label": "Arrow background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrow_border",
      "label": "Arrow border",
      "default": "#e5e5e5"
    },
    {
      "type": "color",
      "id": "arrow_color_hover",
      "label": "Arrow icon color (hover)",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrow_bg_hover",
      "label": "Arrow background (hover)",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot color",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "dot_active_color",
      "label": "Active dot color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top margin",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom margin",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Images"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image",
          "info": "Recommended: 1920×720px"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile image (optional)",
          "info": "Recommended: 750×1000px. Shows on screens under 768px."
        },
        {
          "type": "header",
          "content": "Overlay"
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay opacity",
          "min": 0,
          "max": 80,
          "step": 5,
          "unit": "%",
          "default": 30
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content position",
          "default": "middle-left",
          "options": [
            { "value": "top-left",      "label": "Top left" },
            { "value": "top-center",    "label": "Top center" },
            { "value": "top-right",     "label": "Top right" },
            { "value": "middle-left",   "label": "Middle left" },
            { "value": "middle-center", "label": "Middle center" },
            { "value": "middle-right",  "label": "Middle right" },
            { "value": "bottom-left",   "label": "Bottom left" },
            { "value": "bottom-center", "label": "Bottom center" },
            { "value": "bottom-right",  "label": "Bottom right" }
          ]
        },
        {
          "type": "select",
          "id": "text_alignment",
          "label": "Text alignment",
          "default": "left",
          "options": [
            { "value": "left",   "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right",  "label": "Right" }
          ]
        },
        {
          "type": "range",
          "id": "content_max_width",
          "label": "Content max width",
          "min": 300,
          "max": 900,
          "step": 20,
          "unit": "px",
          "default": 560
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "New Collection"
        },
        {
          "type": "range",
          "id": "subheading_size",
          "label": "Subheading font size",
          "min": 10,
          "max": 32,
          "step": 1,
          "unit": "px",
          "default": 14
        },
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
          "default": "Discover Your Style"
        },
        {
