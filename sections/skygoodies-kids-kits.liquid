{%- style -%}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px; }
  @media screen and (min-width: 750px) { .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } }
{%- endstyle -%}
<section class="kits section-{{ section.id }}-padding" style="background: {{ section.settings.bg_color }};"><div class="kits__inner"><div class="kits__top"><div>{%- if section.settings.eyebrow != blank -%}<p class="eyebrow" style="color: {{ section.settings.accent_color }}">{{ section.settings.eyebrow }}</p>{%- endif -%}<h2 class="sh" style="color: {{ section.settings.heading_color }}">{{ section.settings.heading }}</h2>{%- if section.settings.text != blank -%}<p class="sd" style="color: {{ section.settings.text_color }}">{{ section.settings.text }}</p>{%- endif -%}</div>{%- if section.settings.button_link != blank -%}<a href="{{ section.settings.button_link }}" class="feat__top-link" style="color: {{ section.settings.accent_color }}">{{ section.settings.button_text }}<svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg></a>{%- endif -%}</div><div class="kits__grid">{%- assign kits_collection = section.settings.collection -%}{%- if kits_collection != blank and kits_collection.products_count > 0 -%}{%- for product in kits_collection.products limit: section.settings.products_to_show -%}{%- render 'skygoodies-product-card', product: product -%}{%- endfor -%}{%- else -%}{%- for i in (1..4) -%}{%- render 'skygoodies-product-card' -%}{%- endfor -%}{%- endif -%}</div></div></section>
{% schema %}{"name":"Sky Product Grid","settings":[{"type":"color","id":"bg_color","label":"Background Color","default":"#ffffff"},{"type":"color","id":"heading_color","label":"Heading Color","default":"#2C2825"},{"type":"color","id":"text_color","label":"Text Color","default":"#6B6560"},{"type":"color","id":"accent_color","label":"Accent Color","default":"#FD9963"},{"type":"text","id":"eyebrow","label":"Eyebrow Text","default":"Paper kits for little makers"},{"type":"text","id":"heading","label":"Heading","default":"Busy hands, bright minds"},{"type":"textarea","id":"text","label":"Subtext","default":"A cheerful paper kit that turns a little making time into something lovely."},{"type":"text","id":"button_text","label":"Link Text","default":"See all kids' kits"},{"type":"url","id":"button_link","label":"Link URL"},{"type":"collection","id":"collection","label":"Collection"},{"type":"range","id":"products_to_show","min":4,"max":16,"step":4,"default":4,"label":"Products to show"},{"type":"range","id":"padding_top","min":0,"max":100,"step":4,"unit":"px","label":"Padding Top","default":72},{"type":"range","id":"padding_bottom","min":0,"max":100,"step":4,"unit":"px","label":"Padding Bottom","default":72}],"presets":[{"name":"Sky Product Grid"}]}{% endschema %}
