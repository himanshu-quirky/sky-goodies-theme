{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-section-{{ section.id }}-pad {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .sg-section-{{ section.id }}-pad {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="sg-section sg-gifting sg-section-{{ section.id }}-pad" style="background: {{ section.settings.bg_color }};" {{ section.shopify_attributes }}>
  <div class="sg-gifting__inner">
    <div class="sg-gifting__head">
      {%- if section.settings.heading != blank -%}
        <h2 class="sg-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="sg-subtext">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="sg-gifting__grid">
      {%- for block in section.blocks -%}
        {%- assign gift_link = block.settings.link -%}
        {%- if gift_link == blank and block.settings.collection != blank -%}
          {%- assign gift_link = block.settings.collection.url -%}
        {%- endif -%}

        <a href="{{ gift_link }}" class="sg-gift" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.heading | escape }}" width="600" height="800" loading="lazy">
          {%- elsif block.settings.collection != blank and block.settings.collection.image != blank -%}
            <img src="{{ block.settings.collection.image | image_url: width: 600 }}" alt="{{ block.settings.collection.title | default: block.settings.heading | escape }}" width="600" height="800" loading="lazy">
          {%- elsif block.settings.collection != blank and block.settings.collection.products.first.featured_image != blank -%}
            <img src="{{ block.settings.collection.products.first.featured_image | image_url: width: 600 }}" alt="{{ block.settings.heading | escape }}" width="600" height="800" loading="lazy">
          {%- else -%}
            <div class="sg-placeholder" style="position:absolute;inset:0;">{{ block.settings.heading }}</div>
          {%- endif -%}
          <div class="sg-gift__ov">
            {%- if block.settings.heading != blank -%}
              <h3>{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p>{{ block.settings.text }}</p>
            {%- endif -%}
            {%- if block.settings.link_text != blank -%}
              <span class="sg-gift__link">
                {{ block.settings.link_text }}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><polyline points="9 18 15 12 9 6"/></svg>
              </span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SG Gifting Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Good gifts. Better reactions."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Whether it's a birthday return gift, a souvenir, or a corporate order -- we've got something thoughtful."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FDFCFA"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Gift Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection",
          "info": "Used for automatic image and link when no custom ones are set."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image (overrides collection image)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Kids' Return Gifts"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Colourful kits kids can actually make and keep."
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Browse gifts"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom Link (overrides collection link)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG Gifting Grid",
      "blocks": [
        { "type": "card", "settings": { "heading": "Kids' Return Gifts", "text": "Colourful kits kids can actually make and keep.", "link_text": "Browse kids' gifts" } },
        { "type": "card", "settings": { "heading": "Bulk & Party Orders", "text": "Return gifts for 20 or 200. We have you covered.", "link_text": "Enquire now" } },
        { "type": "card", "settings": { "heading": "Corporate & Custom Gifts", "text": "Thoughtful branded gifts that stand out.", "link_text": "Get a quote" } }
      ]
    }
  ]
}
{% endschema %}
