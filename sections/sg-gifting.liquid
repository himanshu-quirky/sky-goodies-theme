<section class="sg-section sg-gifting" style="background:{{ section.settings.background_color }}; padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="sg-container">
    <div class="sg-section-header sg-text-center sg-header-narrow">
      <span class="sg-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="sg-h2">{{ section.settings.heading }}</h2>
      <p class="sg-subheading">{{ section.settings.subheading }}</p>
    </div>
    <div class="sg-gifting-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link_url | default: '#' }}" class="sg-gift-card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="sg-gift-image">
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="lazy" referrerpolicy="no-referrer">
            </div>
          {% endif %}
          <h3 class="sg-gift-title">{{ block.settings.title }}</h3>
          <p class="sg-gift-desc">{{ block.settings.description }}</p>
          <span class="sg-link-arrow">{{ block.settings.link_text }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SG Gifting",
  "tag": "section",
  "class": "sg-gifting-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "GIFTING"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made to be gifted"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From birthday return gifts to wedding favors — handcrafted in batches, big or small."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FDFCFA"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Gift card"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Add a description for this gifting option."
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text",
          "default": "Explore →"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gifting",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Kids' Return Gifts",
            "description": "Personalised craft kits perfect for birthday parties and class favors."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Bulk & Party Orders",
            "description": "Order in batches for weddings, showers and celebrations of every size."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Corporate Gifts",
            "description": "Thoughtful, handcrafted gifts that say more than a logo'd mug ever could."
          }
        }
      ]
    }
  ]
}
{% endschema %}
