<style>
  .sg-gift-section { padding: 40px 20px; max-width: 1200px; margin: 0 auto; text-align: center; }
  .sg-gift-eyebrow { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 600; color: #E8845A; display: block; margin-bottom: 6px; }
  .sg-gift-header h2 { font-family: 'DM Serif Display', serif; font-size: clamp(28px, 4vw, 40px); color: #1E1B18; margin: 0 0 8px; }
  .sg-gift-sub { color: #7A7168; font-size: 15px; max-width: 560px; margin: 0 auto; }
  .sg-gift-grid { display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 32px; }
  @media (min-width: 750px) { .sg-gift-grid { grid-template-columns: repeat(3, 1fr); } }
  .sg-gift-card { background: #FFF; border-radius: 24px; overflow: hidden; border: 1px solid #EDE8E2; text-align: left; text-decoration: none; color: inherit; display: block; transition: transform 0.3s, box-shadow 0.3s; }
  .sg-gift-card:hover { transform: translateY(-4px); box-shadow: 0 10px 30px rgba(61, 56, 51, 0.08); }
  .sg-gift-img { aspect-ratio: 1/1; overflow: hidden; background: #FAF6F0; }
  .sg-gift-img img { width: 100%; height: 100%; object-fit: cover; }
  .sg-gift-content { padding: 20px; }
  .sg-gift-title { font-family: 'DM Serif Display', serif; font-size: 22px; color: #1E1B18; margin: 0 0 8px; }
  .sg-gift-desc { color: #7A7168; font-size: 14px; line-height: 1.6; margin-bottom: 12px; }
  .sg-gift-link { color: #E8845A; font-weight: 600; font-size: 14px; }
</style>

<section class="sg-gift-section" style="background:{{ section.settings.background_color }};" {{ section.shopify_attributes }}>
  <div class="sg-gift-header">
    {% if section.settings.eyebrow != blank %}<span class="sg-gift-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
    {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
    {% if section.settings.subheading != blank %}<p class="sg-gift-sub">{{ section.settings.subheading }}</p>{% endif %}
  </div>
  <div class="sg-gift-grid">
    {% if section.blocks.size == 0 %}
      {%- assign fb_titles = "Kids' Return Gifts|Bulk & Party Orders|Corporate Gifts" | split: '|' -%}
      {%- assign fb_descs = "Personalised craft kits perfect for birthday parties and class favors.|Order in batches for weddings, showers and celebrations of every size.|Thoughtful, handcrafted gifts that say more than a logo'd mug ever could." | split: '|' -%}
      {%- assign fb_imgs = 'https://cdn.shopify.com/s/files/1/0428/5530/1271/collections/Sky-Goodies-Birthday-Party-Decor-Daisy-Birthday-01.jpg,https://cdn.shopify.com/s/files/1/0428/5530/1271/collections/2025-fairy-lights-lamps-collection.jpg,https://cdn.shopify.com/s/files/1/0428/5530/1271/collections/2025-giftbox-collection.jpg' | split: ',' -%}
      {%- assign fb_links = '/pages/kids-gifts,/pages/bulk-orders,/pages/corporate-gifts' | split: ',' -%}
      {%- for i in (0..2) -%}
        <a href="{{ fb_links[i] }}" class="sg-gift-card">
          <div class="sg-gift-img">
            <img src="{{ fb_imgs[i] }}" alt="{{ fb_titles[i] }}" loading="lazy" referrerpolicy="no-referrer">
          </div>
          <div class="sg-gift-content">
            <h3 class="sg-gift-title">{{ fb_titles[i] }}</h3>
            <p class="sg-gift-desc">{{ fb_descs[i] }}</p>
            <span class="sg-gift-link">Explore →</span>
          </div>
        </a>
      {%- endfor -%}
    {% else %}
      {% for block in section.blocks %}
        <a href="{{ block.settings.link_url | default: '#' }}" class="sg-gift-card" {{ block.shopify_attributes }}>
          <div class="sg-gift-img">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="lazy" referrerpolicy="no-referrer">
            {% else %}
              <img src="https://cdn.shopify.com/s/files/1/0428/5530/1271/collections/Sky-Goodies-Birthday-Party-Decor-Daisy-Birthday-01.jpg" alt="{{ block.settings.title | escape }}" loading="lazy" referrerpolicy="no-referrer">
            {% endif %}
          </div>
          <div class="sg-gift-content">
            {% if block.settings.title != blank %}<h3 class="sg-gift-title">{{ block.settings.title }}</h3>{% endif %}
            {% if block.settings.description != blank %}<p class="sg-gift-desc">{{ block.settings.description }}</p>{% endif %}
            {% if block.settings.link_text != blank %}<span class="sg-gift-link">{{ block.settings.link_text }}</span>{% endif %}
          </div>
        </a>
      {% endfor %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "SG Gifting",
  "tag": "section",
  "class": "sg-gifting-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "GIFTING" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Made to be gifted" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "From birthday return gifts to wedding favors — handcrafted in batches, big or small." },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 40 },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#FDFCFA" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "limit": 6,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Gift card" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Add a description for this gifting option." },
        { "type": "text", "id": "link_text", "label": "Link text", "default": "Explore →" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gifting",
      "blocks": [
        { "type": "card", "settings": { "title": "Kids' Return Gifts", "description": "Personalised craft kits perfect for birthday parties and class favors." } },
        { "type": "card", "settings": { "title": "Bulk & Party Orders", "description": "Order in batches for weddings, showers and celebrations of every size." } },
        { "type": "card", "settings": { "title": "Corporate Gifts", "description": "Thoughtful, handcrafted gifts that say more than a logo'd mug ever could." } }
      ]
    }
  ]
}
{% endschema %}
