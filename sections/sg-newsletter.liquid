{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-news-{{ section.id }} {
    padding: 80px var(--sg-gutter);
    background: {{ section.settings.bg_color | default: '#3D3833' }};
    color: {{ section.settings.text_color | default: '#FFFFFF' }};
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .sg-news-{{ section.id }}::before {
    content: '✦';
    position: absolute;
    top: 40px; left: 10%;
    font-size: 40px;
    color: {{ section.settings.accent_color_1 | default: '#E8845A' }};
    opacity: 0.7;
  }
  .sg-news-{{ section.id }}::after {
    content: '✦';
    position: absolute;
    bottom: 40px; right: 10%;
    font-size: 60px;
    color: {{ section.settings.accent_color_2 | default: '#C8E616' }};
    opacity: 0.6;
  }
{%- endstyle -%}

<section class="sg-root sg-news-{{ section.id }}" {{ section.shopify_attributes }}>
  <h2 style="font-family: var(--sg-display); font-weight: 900; font-size: clamp(34px, 5vw, 60px); color: inherit; letter-spacing: -0.02em; margin: 0 0 10px;">
    {{ section.settings.heading | default: 'Get 10% off your first order' }}
  </h2>
  <p style="color: rgba(255,255,255,.8); max-width: 500px; margin: 0 auto 30px; font-size: 16px; font-weight: 500;">
    {{ section.settings.subheading | default: 'Join the crafting letter. Slow emails, pretty papers, early access.' }}
  </p>
  {%- form 'customer', class: 'sg-news-form' -%}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <input type="hidden" name="contact[accepts_marketing]" value="true">
    <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder | default: 'your@email.com' }}" required />
    <button type="submit">{{ section.settings.cta_text | default: 'Get my code' }}</button>
  {%- endform -%}
</section>

<style>
.sg-news-form {
  display: flex;
  gap: 10px;
  max-width: 500px;
  margin: 0 auto;
  background: var(--sg-white);
  border: 2px solid var(--sg-ink);
  padding: 6px;
  border-radius: 999px;
}
.sg-news-form input {
  flex: 1;
  padding: 12px 20px;
  background: transparent;
  border: none;
  font-size: 15px;
  font-weight: 500;
  color: var(--sg-ink);
  min-width: 0;
  outline: none;
}
.sg-news-form input::placeholder { color: var(--sg-muted); }
.sg-news-form button {
  padding: 12px 26px;
  background: var(--sg-lime);
  border: 2px solid var(--sg-ink);
  border-radius: 999px;
  font-weight: 800;
  color: var(--sg-ink);
  font-size: 14px;
  transition: all .15s;
  cursor: pointer;
}
.sg-news-form button:hover { background: #d5f52a; transform: translateY(-1px); box-shadow: 0 3px 0 var(--sg-ink); }
</style>

{% schema %}
{
  "name": "SG — Newsletter",
  "tag": "section",
  "class": "section-sg-newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 10% off your first order" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Join the crafting letter. Slow emails, pretty papers, early access." },
    { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "your@email.com" },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Get my code" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#3D3833" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color_1", "label": "Top accent ✦", "default": "#E8845A" },
    { "type": "color", "id": "accent_color_2", "label": "Bottom accent ✦", "default": "#C8E616" }
  ],
  "presets": [
    { "name": "SG — Newsletter" }
  ]
}
{% endschema %}
