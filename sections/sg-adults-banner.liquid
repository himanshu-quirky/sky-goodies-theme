<section class="sg-section sg-adults" style="background:{{ section.settings.background_color }}; padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="sg-container">
    <a href="{{ section.settings.cta_url | default: '#' }}" class="sg-adults-banner">
      {% if section.settings.banner_image != blank %}
        <img src="{{ section.settings.banner_image | image_url: width: 2000 }}" alt="" loading="lazy" referrerpolicy="no-referrer">
      {% endif %}
      <div class="sg-adults-banner-content">
        <span class="sg-eyebrow sg-eyebrow-light">{{ section.settings.eyebrow }}</span>
        <h2 class="sg-h2">{{ section.settings.heading }}</h2>
        <p class="sg-subheading">{{ section.settings.subheading }}</p>
        <span class="sg-btn sg-btn-primary">{{ section.settings.cta_text }} →</span>
      </div>
    </a>
    {% if section.settings.collection != blank and section.settings.product_count > 0 %}
      <div class="sg-products-grid sg-cols-4 sg-adults-grid">
        {% for product in section.settings.collection.products limit: section.settings.product_count %}
          {% render 'sg-product-card', product: product %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "SG Adults Banner",
  "tag": "section",
  "class": "sg-adults-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "INTRODUCING"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Slow making for grown-ups"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Quiet, hands-on craft for the moments when scrolling stops being enough."
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Explore the collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of products",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FDFCFA"
    }
  ],
  "presets": [
    {
      "name": "Adults banner & products"
    }
  ]
}
{% endschema %}
