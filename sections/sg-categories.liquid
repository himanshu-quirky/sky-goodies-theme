{%- style -%}
  .sg-cat-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
    background: {{ section.settings.bg_color }};
  }
  @media screen and (min-width: 750px) {
    .sg-cat-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- style -%}
  .sg-categories { font-family: 'DM Sans', -apple-system, sans-serif; color: #3D3833; }
  .sg-categories__container { max-width: 1320px; margin: 0 auto; padding: 0 24px; }
  @media (min-width: 768px) { .sg-categories__container { padding: 0 40px; } }

  .sg-categories__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 28px;
    gap: 24px;
  }
  .sg-categories__eyebrow {
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    color: #E8845A;
  }
  .sg-categories__title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 36px;
    color: #3D3833;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 6px 0 10px;
  }
  @media (min-width: 768px) {
    .sg-categories__title { font-size: 52px; }
  }
  .sg-categories__sub {
    color: #7A7168;
    font-size: 16px;
    max-width: 560px;
  }

  .sg-categories__scroll-wrap { position: relative; }
  .sg-categories__scroll {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 8px 4px 24px;
    margin: 0 -24px;
    padding-left: 24px;
    padding-right: 48px;
    scrollbar-width: none;
    scroll-behavior: smooth;
  }
  .sg-categories__scroll::-webkit-scrollbar { display: none; }

  .sg-cat-item {
    flex: 0 0 auto;
    text-align: center;
    scroll-snap-align: start;
    width: 140px;
    text-decoration: none;
    color: inherit;
  }
  @media (max-width: 767px) { .sg-cat-item { width: 120px; } }

  .sg-cat-item__circle {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: #FAF6F0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
    transition: transform 0.3s;
    padding: 12px;
  }
  @media (max-width: 767px) {
    .sg-cat-item__circle { width: 120px; height: 120px; }
  }
  .sg-cat-item__circle:hover { transform: scale(1.04); }
  .sg-cat-item__circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    display: block;
  }
  .sg-cat-item__label {
    font-size: 13px;
    font-weight: 500;
    color: #3D3833;
  }

  .sg-categories__fade {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 24px;
    width: 80px;
    pointer-events: none;
    background: linear-gradient(to right, rgba(253,252,250,0), {{ section.settings.bg_color }} 70%);
    z-index: 2;
  }
  .sg-categories__scroll-btn {
    position: absolute;
    top: 50%;
    right: 8px;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #FDFCFA;
    color: #3D3833;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(61, 56, 51, 0.14);
    z-index: 3;
    animation: sg-cat-nudge 2s ease-in-out infinite;
    border: 1px solid #EDE8E2;
    cursor: pointer;
  }
  .sg-categories__scroll-btn:hover { background: #FCEEE6; }
  @keyframes sg-cat-nudge {
    0%, 100% { transform: translate(0, -50%); }
    50% { transform: translate(6px, -50%); }
  }
{%- endstyle -%}

<section class="sg-categories sg-cat-section-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-categories__container">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank or section.settings.subheading != blank -%}
      <div class="sg-categories__head">
        <div>
          {%- if section.settings.eyebrow != blank -%}
            <span class="sg-categories__eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="sg-categories__title">{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <p class="sg-categories__sub">{{ section.settings.subheading }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <div class="sg-categories__scroll-wrap">
      <div class="sg-categories__scroll" id="sg-cat-scroll-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- liquid
            assign cat_collection = block.settings.collection
            assign cat_link = '#'
            if cat_collection != blank
              assign cat_link = cat_collection.url
            endif
            assign cat_label = block.settings.label
            if cat_label == blank and cat_collection != blank
              assign cat_label = cat_collection.title
            endif

            assign cat_image = block.settings.image
            if cat_image == blank and cat_collection != blank and cat_collection.image != blank
              assign cat_image = cat_collection.image
            endif
            if cat_image == blank and cat_collection != blank and cat_collection.products.first.featured_image != blank
              assign cat_image = cat_collection.products.first.featured_image
            endif
          -%}
          <a href="{{ cat_link }}" class="sg-cat-item" {{ block.shopify_attributes }}>
            <div class="sg-cat-item__circle">
              {%- if cat_image != blank -%}
                {{ cat_image | image_url: width: 280 | image_tag:
                  widths: '200,280,400',
                  sizes: '140px',
                  alt: cat_label,
                  loading: 'lazy'
                }}
              {%- else -%}
                <span style="font-size:12px;color:#7A7168;">{{ cat_label }}</span>
              {%- endif -%}
            </div>
            <span class="sg-cat-item__label">{{ cat_label }}</span>
          </a>
        {%- endfor -%}
      </div>
      <div class="sg-categories__fade"></div>
      <button type="button" class="sg-categories__scroll-btn" data-target="sg-cat-scroll-{{ section.id }}" aria-label="Scroll categories right">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
  (function () {
    var btn = document.querySelector('.sg-cat-section-{{ section.id }} .sg-categories__scroll-btn');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var scroll = document.getElementById(btn.getAttribute('data-target'));
      if (scroll) scroll.scrollBy({ left: 300, behavior: 'smooth' });
    });
  })();
</script>

{% schema %}
{
  "name": "SG Categories",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Categories"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pick your poison"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "From tiny lanterns to big festive moments - there's a craft with your name on it."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FDFCFA"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "max_blocks": 15,
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (1-2 words)",
          "info": "If empty, collection title is used."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override",
          "info": "If empty, collection image is used."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG Categories",
      "blocks": [
        { "type": "category", "settings": { "label": "Lanterns" } },
        { "type": "category", "settings": { "label": "Fairy Lights" } },
        { "type": "category", "settings": { "label": "Calendars" } },
        { "type": "category", "settings": { "label": "Party Decor" } },
        { "type": "category", "settings": { "label": "Animals" } },
        { "type": "category", "settings": { "label": "Dinosaurs" } },
        { "type": "category", "settings": { "label": "Flowers" } },
        { "type": "category", "settings": { "label": "Ganpati" } },
        { "type": "category", "settings": { "label": "Notebooks" } },
        { "type": "category", "settings": { "label": "Wall Decor" } },
        { "type": "category", "settings": { "label": "Gift Boxes" } },
        { "type": "category", "settings": { "label": "Travel" } }
      ]
    }
  ]
}
{% endschema %}
