{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-occ-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: 80px 0;
    position: relative;
    overflow: hidden;
  }
  .sg-occ-{{ section.id }}::before,
  .sg-occ-{{ section.id }}::after {
    content: '';
    position: absolute;
    left: 0; right: 0;
    height: 80px;
    background: {{ section.settings.wave_color | default: '#FAF6F0' }};
    z-index: 1;
  }
  .sg-occ-{{ section.id }}::before { top: -1px; clip-path: ellipse(70% 100% at 50% 0%); }
  .sg-occ-{{ section.id }}::after { bottom: -1px; clip-path: ellipse(70% 100% at 50% 100%); }
  @media (min-width: 768px) {
    .sg-occ-{{ section.id }}::before { height: 110px; clip-path: ellipse(100% 100% at 50% 0%); }
    .sg-occ-{{ section.id }}::after { height: 110px; clip-path: ellipse(100% 100% at 50% 100%); }
  }
  .sg-occ-{{ section.id }} .sg-wrap { position: relative; z-index: 2; }
{%- endstyle -%}

<section class="sg-root sg-occ-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-wrap">
    <div class="sg-section-head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="sg-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading | default: 'Made for everyone' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="sg-occ-grid">
      {%- for block in section.blocks -%}
        <a class="sg-occ-card"
           href="{{ block.settings.link | default: '#' }}"
           style="background: {{ block.settings.card_bg | default: '#F5CF8A' }};"
           {{ block.shopify_attributes }}>
          <div class="sg-occ-card-img"
               {% if block.settings.image %}style="background-image: url('{{ block.settings.image | image_url: width: 800 }}');"{% endif %}>
            {%- if block.settings.badge != blank -%}
              <div class="sg-age-blob">{{ block.settings.badge }}</div>
            {%- endif -%}
          </div>
          <div class="sg-occ-label" style="background: {{ block.settings.label_bg | default: '#C8E616' }}; color: {{ block.settings.label_color | default: '#1E1B18' }};">
            {{ block.settings.label | default: 'Shop' }}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.sg-occ-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
}
@media (min-width: 768px) { .sg-occ-grid { grid-template-columns: repeat({{ section.blocks.size | default: 3 }}, 1fr); gap: 22px; } }
.sg-occ-card {
  border: 2px solid var(--sg-ink);
  border-radius: 26px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform .2s, box-shadow .2s;
  color: inherit;
  text-decoration: none;
}
.sg-occ-card:hover { transform: translateY(-4px); box-shadow: 6px 6px 0 var(--sg-ink); }
.sg-occ-card-img {
  aspect-ratio: 4/5;
  background-size: cover;
  background-position: center;
  position: relative;
}
.sg-age-blob {
  position: absolute;
  top: 20px; left: 20px;
  background: var(--sg-white);
  border: 2px solid var(--sg-ink);
  padding: 14px 22px;
  font-family: var(--sg-display);
  font-weight: 900;
  font-size: 28px;
  color: var(--sg-forest);
  border-radius: 999px 999px 999px 24px;
  line-height: 1;
}
.sg-occ-label {
  text-align: center;
  padding: 18px;
  font-family: var(--sg-display);
  font-weight: 900;
  font-size: 26px;
  border-top: 2px solid var(--sg-ink);
}
</style>

{% schema %}
{
  "name": "SG — Occasion Tiles",
  "tag": "section",
  "class": "section-sg-categories",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Made for everyone" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Sized, priced & styled for every kind of making." },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#FCEEE6" },
    { "type": "color", "id": "wave_color", "label": "Wave color (match adjoining section)", "default": "#FAF6F0" }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "badge", "label": "Badge (age, category)", "default": "6–12" },
        { "type": "text", "id": "label", "label": "Label", "default": "For Little Hands" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "color", "id": "card_bg", "label": "Card background", "default": "#F5CF8A" },
        { "type": "color", "id": "label_bg", "label": "Label background", "default": "#C8E616" },
        { "type": "color", "id": "label_color", "label": "Label text color", "default": "#1E1B18" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Occasion Tiles",
      "blocks": [
        { "type": "tile", "settings": { "badge": "6–12", "label": "For Little Hands", "card_bg": "#F5CF8A", "label_bg": "#C8E616" } },
        { "type": "tile", "settings": { "badge": "13+", "label": "For Grown-ups", "card_bg": "#FCEEE6", "label_bg": "#F5CF8A" } },
        { "type": "tile", "settings": { "badge": "BULK", "label": "For Offices & Events", "card_bg": "#F4BBA4", "label_bg": "#E8845A", "label_color": "#FFFFFF" } }
      ]
    }
  ]
}
{% endschema %}
