<style>
  .sg-cat-section { padding: 40px 20px; max-width: 1200px; margin: 0 auto; }
  .sg-cat-header { text-align: center; margin-bottom: 24px; }
  .sg-cat-eyebrow { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 600; color: #E8845A; }
  .sg-cat-title { font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(28px, 4vw, 44px); color: #1E1B18; line-height: 1.15; margin: 6px 0 10px; }
  .sg-cat-sub { color: #7A7168; font-size: 16px; max-width: 560px; margin: 0 auto; }
  .sg-cat-row { display: flex; gap: 16px; overflow-x: auto; scrollbar-width: none; padding-bottom: 8px; scroll-snap-type: x mandatory; }
  .sg-cat-row::-webkit-scrollbar { display: none; }
  .sg-cat-item { flex-shrink: 0; text-align: center; scroll-snap-align: start; text-decoration: none; color: inherit; display: block; }
  .sg-cat-circle { width: 120px; height: 120px; border-radius: 50%; overflow: hidden; background: #FAF6F0; margin-bottom: 8px; display: flex; align-items: center; justify-content: center; transition: transform 0.3s; }
  .sg-cat-circle:hover { transform: scale(1.04); }
  .sg-cat-circle img { width: 100%; height: 100%; object-fit: cover; }
  .sg-cat-label { font-size: 13px; color: #3D3833; font-weight: 500; }
  @media (max-width: 749px) {
    .sg-cat-circle { width: 100px; height: 100px; }
  }
</style>

<section class="sg-cat-section" style="background:{{ section.settings.bg_color }};" {{ section.shopify_attributes }}>
  {%- if section.settings.heading != blank or section.settings.eyebrow != blank or section.settings.subheading != blank -%}
    <div class="sg-cat-header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="sg-cat-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="sg-cat-title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="sg-cat-sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="sg-cat-row">
    {%- if section.blocks.size == 0 -%}
      {%- assign default_labels = 'Lanterns,Fairy Lights,Calendars,Party Decor,Animals,Dinosaurs,Flowers,Ganpati' | split: ',' -%}
      {%- assign default_imgs = 'https://cdn.shopify.com/s/files/1/0428/5530/1271/files/Sky-Goodies-Mini-Lantern-Fairy-Lights-Paper-Lamp-01.jpg,https://cdn.shopify.com/s/files/1/0428/5530/1271/products/3000-Sky_Goodies_Paper_Hot_Air_Balloon_Fair_Lights_3.jpg,https://cdn.shopify.com/s/files/1/0428/5530/1271/files/Sky-Goodies-Typewriter-Calendar-Colourful-2026-01.jpg,https://cdn.shopify.com/s/files/1/0428/5530/1271/collections/Sky-Goodies-Birthday-Party-Decor-Daisy-Birthday-01.jpg,https://cdn.shopify.com/s/files/1/0428/5530/1271/products/Sky-Goodies-DIY-animals-BOX-setof12-5.jpg,https://cdn.shopify.com/s/files/1/0428/5530/1271/products/3000-dinoboxset.jpg,https://cdn.shopify.com/s/files/1/0428/5530/1271/products/Sky_Goodies_Flower_Lights_WHITE_3000_04.jpg,https://cdn.shopify.com/s/files/1/0428/5530/1271/collections/Sky-Goodies-DIY-Paper-Banana-Trees-06.jpg' | split: ',' -%}
      {%- for label in default_labels -%}
        <a href="/collections/all" class="sg-cat-item">
          <div class="sg-cat-circle">
            <img src="{{ default_imgs[forloop.index0] }}" alt="{{ label }}" loading="lazy" referrerpolicy="no-referrer">
          </div>
          <span class="sg-cat-label">{{ label }}</span>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for block in section.blocks -%}
        {%- liquid
          assign cat_collection = block.settings.collection
          assign cat_link = '#'
          if cat_collection != blank
            assign cat_link = cat_collection.url
          endif
          assign cat_label = block.settings.label
          if cat_label == blank and cat_collection != blank
            assign cat_label = cat_collection.title
          endif
          assign cat_image = block.settings.image
          if cat_image == blank and cat_collection != blank and cat_collection.image != blank
            assign cat_image = cat_collection.image
          endif
          if cat_image == blank and cat_collection != blank and cat_collection.products.first.featured_image != blank
            assign cat_image = cat_collection.products.first.featured_image
          endif
        -%}
        <a href="{{ cat_link }}" class="sg-cat-item" {{ block.shopify_attributes }}>
          <div class="sg-cat-circle">
            {%- if cat_image != blank -%}
              <img src="{{ cat_image | image_url: width: 280 }}" alt="{{ cat_label | escape }}" loading="lazy" referrerpolicy="no-referrer">
            {%- else -%}
              <span style="font-size:12px;color:#7A7168;">{{ cat_label | default: 'Shop' }}</span>
            {%- endif -%}
          </div>
          <span class="sg-cat-label">{{ cat_label | default: 'Shop' }}</span>
        </a>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "SG Categories",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Categories" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pick your poison" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "From tiny lanterns to big festive moments - there's a craft with your name on it." },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FDFCFA" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding Top", "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 60 }
  ],
  "max_blocks": 15,
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "label", "label": "Label (1-2 words)" },
        { "type": "image_picker", "id": "image", "label": "Image override" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG Categories",
      "blocks": [
        { "type": "category", "settings": { "label": "Lanterns" } },
        { "type": "category", "settings": { "label": "Fairy Lights" } },
        { "type": "category", "settings": { "label": "Calendars" } },
        { "type": "category", "settings": { "label": "Party Decor" } },
        { "type": "category", "settings": { "label": "Animals" } },
        { "type": "category", "settings": { "label": "Dinosaurs" } },
        { "type": "category", "settings": { "label": "Flowers" } },
        { "type": "category", "settings": { "label": "Ganpati" } }
      ]
    }
  ]
}
{% endschema %}
