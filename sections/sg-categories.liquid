{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-section-{{ section.id }}-pad {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .sg-section-{{ section.id }}-pad {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="sg-section sg-categories sg-section-{{ section.id }}-pad" style="background: {{ section.settings.bg_color }};" {{ section.shopify_attributes }}>
  {%- if section.settings.heading != blank -%}
    <div class="sg-categories__head">
      <h2 class="sg-heading">{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}

  <div class="sg-categories__scroll">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="sg-cat" {{ block.shopify_attributes }}>
        <div class="sg-cat__img">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 200 }}" alt="{{ block.settings.title | escape }}" width="200" height="200" loading="lazy">
          {%- else -%}
            <div class="sg-placeholder">{{ block.settings.title }}</div>
          {%- endif -%}
        </div>
        <span class="sg-cat__label">{{ block.settings.title }}</span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "SG Categories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by category"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FDFCFA"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Name",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG Categories",
      "blocks": [
        { "type": "category", "settings": { "title": "Party Decor" } },
        { "type": "category", "settings": { "title": "Kids Kits" } },
        { "type": "category", "settings": { "title": "DIY for Adults" } },
        { "type": "category", "settings": { "title": "Home Decor" } },
        { "type": "category", "settings": { "title": "Fairy Lights" } },
        { "type": "category", "settings": { "title": "Calendars" } },
        { "type": "category", "settings": { "title": "Pooja Decor" } },
        { "type": "category", "settings": { "title": "Notebooks" } }
      ]
    }
  ]
}
{% endschema %}
