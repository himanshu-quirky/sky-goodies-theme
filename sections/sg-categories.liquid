{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-occ-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#F5EFE3' }};
    padding: {{ section.settings.mobile_padding | default: 20 }}px 0 {{ section.settings.mobile_padding_bottom | default: 24 }}px;
  }
  @media (min-width: 900px) {
    .sg-occ-{{ section.id }} {
      padding: {{ section.settings.desktop_padding | default: 28 }}px 0 {{ section.settings.desktop_padding_bottom | default: 40 }}px;
    }
  }
{%- endstyle -%}

<section class="sg-root sg-occ-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-occ-head">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow">— {{ section.settings.eyebrow }} —</span>
    {%- endif -%}
    <h2>{{ section.settings.heading_plain | default: 'Shop by' }} <em>{{ section.settings.heading_em | default: 'occasion' }}</em></h2>
  </div>

  <div class="sg-occ-scroll">
    {%- for block in section.blocks -%}
      <a class="sg-occ-item" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
        <div class="sg-occ-circle"
             {% if block.settings.image %}style="background-image: url('{{ block.settings.image | image_url: width: 400 }}');"{% endif %}></div>
        <div class="sg-occ-label">{{ block.settings.label | default: 'Category' }}</div>
      </a>
    {%- endfor -%}
  </div>
</section>

<style>
.sg-occ-head { text-align: center; margin-bottom: 32px; }
.sg-occ-head .eyebrow {
  font-family: var(--sg-sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--sg-muted);
  margin-bottom: 10px;
  display: block;
}
.sg-occ-head h2 {
  font-family: var(--sg-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(26px, 3vw, 36px);
  color: var(--sg-ink);
  letter-spacing: -0.015em;
}
.sg-occ-head h2 em { font-style: normal; font-weight: 500; color: var(--sg-orange-dk); }

.sg-occ-scroll {
  display: flex;
  gap: 18px;
  overflow-x: auto;
  scrollbar-width: none;
  padding: 4px var(--sg-gutter) 12px;
  max-width: var(--sg-container);
  margin: 0 auto;
  scroll-snap-type: x mandatory;
}
.sg-occ-scroll::-webkit-scrollbar { display: none; }
@media (min-width: 1100px) { .sg-occ-scroll { gap: 26px; justify-content: center; overflow-x: visible; } }
.sg-occ-item {
  flex: 0 0 auto;
  text-align: center;
  transition: transform .2s;
  scroll-snap-align: center;
}
.sg-occ-item:hover { transform: translateY(-4px); }
.sg-occ-circle {
  width: 108px; height: 108px;
  border-radius: 50%;
  background-size: cover;
  background-position: center;
  background-color: var(--sg-peach);
  margin-bottom: 10px;
  border: 3px solid var(--sg-paper-soft);
  transition: border-color .2s;
  overflow: hidden;
}
.sg-occ-item:hover .sg-occ-circle { border-color: var(--sg-orange-soft); }
@media (min-width: 768px) { .sg-occ-circle { width: 128px; height: 128px; } }
.sg-occ-label {
  font-family: var(--sg-display);
  font-style: italic;
  font-weight: 400;
  font-size: 16px;
  color: var(--sg-ink);
  max-width: 128px;
  margin: 0 auto;
  line-height: 1.2;
}
</style>

{% schema %}
{
  "name": "SG — Occasion Circles",
  "tag": "section",
  "class": "section-sg-categories",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Find the right one" },
    { "type": "text", "id": "heading_plain", "label": "Heading (plain)", "default": "Shop by" },
    { "type": "text", "id": "heading_em", "label": "Heading (italic accent)", "default": "occasion" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F5EFE3" },
    { "type": "range", "id": "mobile_padding", "label": "Mobile top padding", "min": 0, "max": 120, "step": 4, "default": 20 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Mobile bottom padding", "min": 0, "max": 120, "step": 4, "default": 24 },
    { "type": "range", "id": "desktop_padding", "label": "Desktop top padding", "min": 0, "max": 200, "step": 4, "default": 28 },
    { "type": "range", "id": "desktop_padding_bottom", "label": "Desktop bottom padding", "min": 0, "max": 200, "step": 4, "default": 40 }
  ],
  "max_blocks": 12,
  "blocks": [
    {
      "type": "occasion",
      "name": "Occasion",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (round)" },
        { "type": "text", "id": "label", "label": "Label", "default": "Birthdays" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Occasion Circles",
      "blocks": [
        { "type": "occasion", "settings": { "label": "Birthdays" } },
        { "type": "occasion", "settings": { "label": "Housewarming" } },
        { "type": "occasion", "settings": { "label": "Pooja" } },
        { "type": "occasion", "settings": { "label": "Kids' Gifts" } },
        { "type": "occasion", "settings": { "label": "Anniversaries" } },
        { "type": "occasion", "settings": { "label": "Return Gifts" } },
        { "type": "occasion", "settings": { "label": "Festive" } },
        { "type": "occasion", "settings": { "label": "Corporate" } }
      ]
    }
  ]
}
{% endschema %}
