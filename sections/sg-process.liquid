<style>
  .sg-proc-section { padding: 40px 20px; max-width: 1200px; margin: 0 auto; text-align: center; }
  .sg-proc-eyebrow { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 600; color: #E8845A; display: block; margin-bottom: 6px; }
  .sg-proc-header h2 { font-family: 'DM Serif Display', serif; font-size: clamp(28px, 4vw, 40px); color: #1E1B18; margin: 0 0 8px; }
  .sg-proc-sub { color: #7A7168; font-size: 15px; max-width: 560px; margin: 0 auto; }
  .sg-proc-grid { display: grid; grid-template-columns: 1fr; gap: 24px; margin-top: 32px; }
  @media (min-width: 750px) { .sg-proc-grid { grid-template-columns: repeat(3, 1fr); gap: 32px; } }
  .sg-proc-step { text-align: center; padding: 24px; }
  .sg-proc-num { display: inline-flex; width: 56px; height: 56px; border-radius: 50%; background: #E8845A; color: #FFF; font-family: 'DM Serif Display', serif; font-size: 24px; align-items: center; justify-content: center; margin-bottom: 16px; }
  .sg-proc-title { font-family: 'DM Serif Display', serif; font-size: 22px; color: #1E1B18; margin: 0 0 8px; }
  .sg-proc-desc { color: #7A7168; font-size: 14px; line-height: 1.6; margin: 0; }
</style>

<section class="sg-proc-section" style="background:{{ section.settings.background_color }};" {{ section.shopify_attributes }}>
  <div class="sg-proc-header">
    {% if section.settings.eyebrow != blank %}<span class="sg-proc-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
    {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
    {% if section.settings.subheading != blank %}<p class="sg-proc-sub">{{ section.settings.subheading }}</p>{% endif %}
  </div>
  <div class="sg-proc-grid">
    {% if section.blocks.size == 0 %}
      {%- assign fb_nums = '01,02,03' | split: ',' -%}
      {%- assign fb_titles = 'Open the kit|Fold, score, slot|Display & glow' | split: '|' -%}
      {%- assign fb_descs = 'Pre-cut, colour-coded pieces. No scissors, no tears.|Follow the illustrated guide. Most kits done in an hour.|Keepsake-quality. Hang the lights, share the joy.' | split: '|' -%}
      {%- for i in (0..2) -%}
        <div class="sg-proc-step">
          <div class="sg-proc-num">{{ fb_nums[i] }}</div>
          <h3 class="sg-proc-title">{{ fb_titles[i] }}</h3>
          <p class="sg-proc-desc">{{ fb_descs[i] }}</p>
        </div>
      {%- endfor -%}
    {% else %}
      {% for block in section.blocks %}
        <div class="sg-proc-step" {{ block.shopify_attributes }}>
          <div class="sg-proc-num">{{ block.settings.step_number | default: forloop.index }}</div>
          {% if block.settings.title != blank %}<h3 class="sg-proc-title">{{ block.settings.title }}</h3>{% endif %}
          {% if block.settings.description != blank %}<p class="sg-proc-desc">{{ block.settings.description }}</p>{% endif %}
        </div>
      {% endfor %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "How it works",
  "tag": "section",
  "class": "sg-section-wrapper",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "HOW IT WORKS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From flat pack to finished piece" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Three simple steps. No glue gun drama. Just the joy of making." },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#FDFCFA" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 40 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "step_number", "label": "Step number", "default": "01" },
        { "type": "text", "id": "title", "label": "Title", "default": "Step title" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Short description of this step." }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Paper plane steps",
      "blocks": [
        { "type": "step", "settings": { "step_number": "01", "title": "Open the kit", "description": "Pre-cut, colour-coded pieces. No scissors, no tears." } },
        { "type": "step", "settings": { "step_number": "02", "title": "Fold, score, slot", "description": "Follow the illustrated guide. Most kits done in an hour." } },
        { "type": "step", "settings": { "step_number": "03", "title": "Display & glow", "description": "Keepsake-quality. Hang the lights, share the joy." } }
      ]
    }
  ]
}
{% endschema %}
