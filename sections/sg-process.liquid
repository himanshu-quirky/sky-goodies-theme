<section class="sg-section sg-how-it-works" style="background:{{ section.settings.background_color }}; padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="sg-container">
    <div class="sg-section-header sg-text-center">
      {% if section.settings.eyebrow != blank %}
        <span class="sg-eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="sg-h2">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="sg-subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="sg-how-canvas">
      <svg class="sg-plane-path" viewBox="0 0 1200 360" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="none">
        <path d="M 120 90 C 300 250, 450 250, 600 140 S 900 30, 1080 200"
              stroke="#C9A87C"
              stroke-width="2"
              stroke-linecap="round"
              stroke-dasharray="2 10"
              fill="none" />
        <g class="sg-plane-icon" transform="translate(1060 175) rotate(28)">
          <path d="M 0 0 L 44 14 L 18 20 L 12 40 Z" fill="#E07856" />
          <path d="M 18 20 L 44 14 L 24 28 Z" fill="#B85C3E" />
        </g>
      </svg>

      <div class="sg-steps-grid">
        {% for block in section.blocks %}
          {% if block.type == 'step' %}
            <div class="sg-step-card sg-step-{{ forloop.index }}" {{ block.shopify_attributes }}>
              <div class="sg-step-circle">{{ block.settings.step_number }}</div>
              {% if block.settings.title != blank %}
                <h3 class="sg-step-title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <p class="sg-step-desc">{{ block.settings.description }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How it works",
  "tag": "section",
  "class": "sg-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "HOW IT WORKS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From flat pack to finished piece"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Three simple steps. No glue gun drama. Just the joy of making."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FDFCFA"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Step title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Short description of this step."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Paper plane steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_number": "01",
            "title": "Open the kit",
            "description": "Pre-cut, colour-coded pieces. No scissors, no tears."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "02",
            "title": "Fold, score, slot",
            "description": "Follow the illustrated guide. Most kits done in an hour."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "03",
            "title": "Display & glow",
            "description": "Keepsake-quality. Hang the lights, share the joy."
          }
        }
      ]
    }
  ]
}
{% endschema %}
