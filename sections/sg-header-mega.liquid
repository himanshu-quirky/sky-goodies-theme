{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- assign main_menu = linklists[section.settings.menu | default: 'main-menu'] -%}

{%- style -%}
  .sg-header-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#FDFCFA' }};
    border-bottom: 1px solid rgba(30,27,24,.05);
    position: {% if section.settings.sticky %}sticky{% else %}relative{% endif %};
    top: 0;
    z-index: 80;
  }
{%- endstyle -%}

<header class="sg-root sg-header-{{ section.id }}" data-sg-header {{ section.shopify_attributes }}>
  <div class="sg-header-inner">
    <a href="{{ routes.root_url }}" class="sg-header-logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo -%}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="{{ section.settings.logo_width | default: 48 }}" />
      {%- else -%}
        <span class="sg-header-wordmark">{{ shop.name | downcase }}</span>
      {%- endif -%}
    </a>

    <nav class="sg-header-nav" aria-label="Main">
      {%- if main_menu.links.size > 0 -%}
        {%- for link in main_menu.links -%}
          <div class="sg-nav-item{% if link.links.size > 0 %} has-mega{% endif %}">
            <a href="{{ link.url }}">{{ link.title }}{% if link.links.size > 0 %} <span class="sg-nav-caret">▾</span>{% endif %}</a>
            {%- if link.links.size > 0 -%}
              <div class="sg-mega">
                <div class="sg-mega-inner">
                  {%- assign cols = 0 -%}
                  {%- for sub in link.links -%}
                    {%- if sub.links.size > 0 -%}
                      {%- assign cols = cols | plus: 1 -%}
                      {%- if cols <= 2 -%}
                        <div class="sg-mega-col">
                          <h5>{{ sub.title }}</h5>
                          <ul>
                            {%- for item in sub.links -%}
                              <li><a href="{{ item.url }}">{{ item.title }}</a></li>
                            {%- endfor -%}
                          </ul>
                        </div>
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}

                  {%- for block in section.blocks -%}
                    {%- if block.type == 'featured' -%}
                      <a class="sg-mega-feature"
                         href="{{ block.settings.link | default: '#' }}"
                         {% if block.settings.image %}style="background-image: url('{{ block.settings.image | image_url: width: 600 }}');"{% endif %}>
                        <div class="sg-mega-tag" style="background: {{ block.settings.tag_bg | default: '#E8845A' }}; color: {{ block.settings.tag_color | default: '#FFFFFF' }};">{{ block.settings.tag | default: 'Featured' }}</div>
                        <div class="sg-mega-cta">
                          <h4>{{ block.settings.title | default: 'Featured product' }}</h4>
                          <span>Shop now →</span>
                        </div>
                      </a>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="sg-nav-item"><a href="{{ routes.collections_url }}">SHOP</a></div>
      {%- endif -%}
    </nav>

    <div class="sg-header-actions">
      <button class="sg-icon-btn" aria-label="Search" data-sg-search-trigger>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <a href="{{ routes.account_url }}" class="sg-icon-btn" aria-label="Account">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <!-- Wishlist Hero app renders here -->
      <button class="sg-icon-btn" aria-label="Cart" data-sg-cart-open>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="sg-cart-badge" data-sg-cart-count>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>
</header>

<style>
.sg-header-inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  padding: 14px var(--sg-gutter);
  max-width: var(--sg-container);
  margin: 0 auto;
  gap: 20px;
}
.sg-header-logo {
  justify-self: start;
  display: inline-block;
  text-decoration: none;
}
.sg-header-logo img { display: block; height: 40px; width: auto; }
@media (min-width: 768px) { .sg-header-logo img { height: 48px; } }
.sg-header-wordmark {
  font-family: var(--sg-display);
  font-style: italic;
  font-weight: 700;
  font-size: 36px;
  color: var(--sg-orange);
  letter-spacing: -0.03em;
  line-height: 1;
}
@media (min-width: 768px) { .sg-header-wordmark { font-size: 44px; } }

.sg-header-nav {
  display: none;
  gap: 36px;
  justify-content: center;
}
@media (min-width: 900px) { .sg-header-nav { display: flex; } }
.sg-nav-item { position: relative; }
.sg-nav-item > a {
  font-family: var(--sg-sans);
  font-weight: 700;
  font-size: 14px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--sg-ink);
  padding: 28px 0;
  transition: color .15s;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.sg-nav-item > a:hover { color: var(--sg-orange); }
.sg-nav-caret { font-size: 10px; opacity: 0.5; }

.sg-mega {
  position: fixed;
  top: 70px;
  left: 50%;
  transform: translateX(-50%) translateY(-6px);
  width: min(1100px, 95vw);
  background: var(--sg-cream-light);
  border: 2px solid var(--sg-ink);
  border-radius: 22px;
  box-shadow: 0 20px 60px -14px rgba(30,27,24,.35);
  padding: 32px;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity .22s, transform .22s, visibility .22s;
  z-index: 95;
}
.sg-nav-item.has-mega:hover .sg-mega,
.sg-nav-item.has-mega:focus-within .sg-mega {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateX(-50%) translateY(0);
}
.sg-mega-inner {
  display: grid;
  grid-template-columns: 1fr 1fr 1.3fr 1.3fr;
  gap: 28px;
}
.sg-mega-col h5 {
  font-family: var(--sg-display);
  font-weight: 900;
  font-size: 15px;
  color: var(--sg-forest);
  margin-bottom: 14px;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  padding-bottom: 10px;
  border-bottom: 2px dashed rgba(30,27,24,.15);
}
.sg-mega-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.sg-mega-col li a {
  font-family: var(--sg-sans);
  font-size: 14px;
  font-weight: 600;
  color: var(--sg-ink);
  letter-spacing: 0;
  text-transform: none;
  padding: 4px 0;
  display: inline-block;
  transition: color .15s, transform .15s;
}
.sg-mega-col li a:hover { color: var(--sg-orange); transform: translateX(2px); }
.sg-mega-feature {
  aspect-ratio: 4/5;
  border-radius: 18px;
  overflow: hidden;
  background-size: cover;
  background-position: center;
  background-color: var(--sg-peach);
  border: 2px solid var(--sg-ink);
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 14px;
  transition: transform .2s;
  text-decoration: none;
}
.sg-mega-feature:hover { transform: translateY(-3px); }
.sg-mega-feature::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 40%, rgba(30,27,24,.7));
}
.sg-mega-feature > * { position: relative; z-index: 2; }
.sg-mega-tag {
  align-self: flex-start;
  padding: 5px 12px;
  border-radius: 999px;
  font-family: var(--sg-sans);
  font-weight: 800;
  font-size: 11px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  border: 2px solid var(--sg-ink);
}
.sg-mega-cta h4 {
  font-family: var(--sg-display);
  font-weight: 900;
  font-size: 17px;
  color: #fff;
  line-height: 1.15;
  margin: 0 0 4px;
}
.sg-mega-cta span {
  font-family: var(--sg-sans);
  font-weight: 700;
  font-size: 13px;
  color: var(--sg-lime);
}
@media (max-width: 1024px) { .sg-nav-item.has-mega .sg-mega { display: none; } }

.sg-header-actions { display: flex; align-items: center; gap: 6px; justify-self: end; }
.sg-icon-btn {
  width: 42px; height: 42px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--sg-ink);
  position: relative;
  transition: background .15s;
  border: none;
  background: none;
  cursor: pointer;
}
.sg-icon-btn:hover { background: var(--sg-cream-deep); }
.sg-icon-btn svg { width: 22px; height: 22px; }
.sg-cart-badge {
  position: absolute;
  top: 4px; right: 4px;
  width: 18px; height: 18px;
  background: var(--sg-orange);
  color: #fff;
  border-radius: 50%;
  font-size: 10px;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--sg-sans);
  border: 2px solid var(--sg-cream-light);
}
</style>

{% schema %}
{
  "name": "SG — Header with Mega Menu",
  "tag": "header",
  "class": "section-sg-header-mega",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "range", "id": "logo_width", "label": "Logo width (px)", "min": 32, "max": 240, "step": 4, "default": 48 },
    { "type": "link_list", "id": "menu", "label": "Main menu", "default": "main-menu" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FDFCFA" },
    { "type": "checkbox", "id": "sticky", "label": "Sticky on scroll", "default": true }
  ],
  "blocks": [
    {
      "type": "featured",
      "name": "Mega menu feature card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "tag", "label": "Badge text", "default": "★ Bestseller" },
        { "type": "color", "id": "tag_bg", "label": "Badge background", "default": "#E8845A" },
        { "type": "color", "id": "tag_color", "label": "Badge text color", "default": "#FFFFFF" },
        { "type": "text", "id": "title", "label": "Title", "default": "Featured product" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Header with Mega Menu",
      "blocks": [
        { "type": "featured", "settings": { "tag": "★ Bestseller", "title": "Endangered Animals BOX SET" } },
        { "type": "featured", "settings": { "tag": "Just In", "tag_bg": "#C8E616", "tag_color": "#1E1B18", "title": "Fairy Light Drop" } }
      ]
    }
  ]
}
{% endschema %}
