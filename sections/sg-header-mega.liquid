{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- assign menu_handle = section.settings.menu | default: 'main-menu' -%}
{%- assign main_menu = linklists[menu_handle] -%}

{%- style -%}
  .sg-hdr-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#FFFFFF' }};
    position: {% if section.settings.sticky %}sticky{% else %}relative{% endif %};
    top: 0;
    z-index: 80;
    border-bottom: 1px solid var(--sg-line);
  }
{%- endstyle -%}

<header class="sg-root sg-hdr-{{ section.id }}" data-sg-header {{ section.shopify_attributes }}>
  <div class="sg-hdr-top">
    <div class="sg-hdr-left">
      <a href="#" class="sg-hdr-search" data-sg-search-trigger><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>Search</a>
    </div>

    <a href="{{ routes.root_url }}" class="sg-hdr-logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo -%}
        <img src="{{ section.settings.logo | image_url: width: 240 }}" alt="{{ shop.name | escape }}"/>
      {%- else -%}
        <span class="sg-hdr-wordmark">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <div class="sg-hdr-right">
      <a href="{{ routes.account_url }}" class="sg-hdr-icon" aria-label="Account"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></a>
      {%- if section.settings.show_wishlist -%}
        <a href="#" class="sg-hdr-icon" aria-label="Wishlist" data-sg-wishlist><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></a>
      {%- endif -%}
      <a href="#" class="sg-hdr-icon" aria-label="Cart" data-sg-cart-open>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="sg-hdr-count" data-sg-cart-count>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>

  {%- if main_menu.links.size > 0 or section.blocks.size > 0 -%}
  <nav class="sg-hdr-nav">
    <div class="sg-hdr-nav-in">
      {%- for link in main_menu.links -%}
        {%- assign has_children = false -%}
        {%- if link.links.size > 0 -%}{%- assign has_children = true -%}{%- endif -%}

        {%- assign matching_feature_block = null -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'mega_feature' and block.settings.menu_label == link.title -%}
            {%- assign matching_feature_block = block -%}
          {%- endif -%}
        {%- endfor -%}

        {%- assign item_class = 'sg-nav-item' -%}
        {%- if link.title contains "Mother" or link.title contains 'Mom' -%}
          {%- assign item_class = 'sg-nav-item sg-special' -%}
        {%- elsif link.title contains 'Sale' -%}
          {%- assign item_class = 'sg-nav-item sg-sale' -%}
        {%- endif -%}

        <div class="{{ item_class }}">
          <a href="{{ link.url }}">{{ link.title }}{% if has_children %} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>{% endif %}</a>
          {%- if has_children -%}
            <div class="sg-mega">
              <div class="sg-mega-grid">
                {%- assign col_count = 0 -%}
                {%- for child in link.links -%}
                  {%- if child.links.size > 0 -%}
                    {%- assign col_count = col_count | plus: 1 -%}
                    {%- if col_count <= 3 -%}
                      <div class="sg-mega-col">
                        <h5>{{ child.title }}</h5>
                        <ul>
                          {%- for sub in child.links -%}
                            <li><a href="{{ sub.url }}">{{ sub.title }}</a></li>
                          {%- endfor -%}
                        </ul>
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}

                {%- comment -%} If no sub-children exist, treat top-level children as a single column list {%- endcomment -%}
                {%- if col_count == 0 -%}
                  <div class="sg-mega-col">
                    <h5>{{ link.title }}</h5>
                    <ul>
                      {%- for child in link.links -%}
                        <li><a href="{{ child.url }}">{{ child.title }}</a></li>
                      {%- endfor -%}
                    </ul>
                  </div>
                {%- endif -%}

                {%- comment -%} Render up to 2 mega feature cards for this menu link {%- endcomment -%}
                {%- assign feat_count = 0 -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'mega_feature' and block.settings.menu_label == link.title and feat_count < 2 -%}
                    {%- assign feat_count = feat_count | plus: 1 -%}
                    <a class="sg-mega-feat" href="{{ block.settings.link | default: '#' }}"
                       {% if block.settings.image %}style="background-image: url('{{ block.settings.image | image_url: width: 600 }}');"{% endif %}>
                      <small>{{ block.settings.tag | default: 'featured' }}</small>
                      <h4>{{ block.settings.title }}</h4>
                      <span class="go">Shop now →</span>
                    </a>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </nav>
  {%- endif -%}
</header>

<style>
.sg-hdr-top {
  max-width: var(--sg-container);
  margin: 0 auto;
  padding: 18px var(--sg-gutter);
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 20px;
}
.sg-hdr-left {
  display: none;
  gap: 20px;
  align-items: center;
}
@media (min-width: 900px) { .sg-hdr-left { display: flex; } }
.sg-hdr-search {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 12.5px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--sg-brown);
  transition: color .15s;
}
.sg-hdr-search svg { width: 17px; height: 17px; }
.sg-hdr-search:hover { color: var(--sg-orange-dk); }

.sg-hdr-logo { justify-self: center; }
.sg-hdr-logo img { height: 62px; width: auto; max-width: 220px; }
@media (min-width: 768px) { .sg-hdr-logo img { height: 76px; max-width: 260px; } }
.sg-hdr-wordmark {
  font-family: var(--sg-display);
  font-style: italic;
  font-weight: 500;
  font-size: 32px;
  color: var(--sg-orange-dk);
}

.sg-hdr-right {
  display: flex;
  gap: 14px;
  justify-self: end;
  align-items: center;
}
.sg-hdr-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px; height: 40px;
  border-radius: 50%;
  color: var(--sg-brown);
  transition: all .15s;
  position: relative;
}
.sg-hdr-icon:hover { background: var(--sg-peach); color: var(--sg-orange-dk); }
.sg-hdr-icon svg { width: 20px; height: 20px; }
.sg-hdr-count {
  position: absolute;
  top: 4px; right: 3px;
  width: 18px; height: 18px;
  background: var(--sg-orange);
  color: #fff;
  border-radius: 50%;
  font-size: 10px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid var(--sg-white);
  font-family: var(--sg-sans);
}

.sg-hdr-nav {
  border-top: 1px solid var(--sg-line);
  background: inherit;
}
.sg-hdr-nav-in {
  max-width: var(--sg-container);
  margin: 0 auto;
  padding: 0 var(--sg-gutter);
  display: none;
  gap: 36px;
  justify-content: center;
  align-items: stretch;
}
@media (min-width: 1000px) { .sg-hdr-nav-in { display: flex; } }
.sg-nav-item { position: relative; padding: 14px 0; }
.sg-nav-item > a {
  font-family: var(--sg-sans);
  font-size: 13.5px;
  font-weight: 500;
  color: var(--sg-brown);
  transition: color .15s;
  display: inline-flex;
  align-items: center;
  gap: 5px;
}
.sg-nav-item > a:hover { color: var(--sg-orange-dk); }
.sg-nav-item.sg-special > a { color: var(--sg-terra); font-weight: 600; }
.sg-nav-item.sg-sale > a { color: var(--sg-terra); }
.sg-nav-item > a svg { width: 10px; height: 10px; opacity: 0.5; transition: transform .2s; }
.sg-nav-item:hover > a svg { transform: rotate(180deg); }

/* Mega */
.sg-mega {
  position: absolute;
  top: calc(100% - 1px);
  left: 50%;
  transform: translateX(-50%) translateY(-4px);
  width: min(980px, 95vw);
  background: var(--sg-white);
  border: 1px solid var(--sg-line);
  border-top: none;
  border-radius: 0 0 var(--sg-r-md) var(--sg-r-md);
  box-shadow: 0 20px 40px -14px rgba(26,22,20,.15);
  padding: 32px;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: all .22s var(--sg-ease);
  z-index: 95;
}
.sg-nav-item:hover .sg-mega,
.sg-nav-item:focus-within .sg-mega {
  opacity: 1; visibility: visible; pointer-events: auto;
  transform: translateX(-50%) translateY(0);
}
.sg-mega-grid {
  display: grid;
  grid-template-columns: 1.2fr 1.2fr 1.3fr 1.3fr;
  gap: 28px;
}
.sg-mega-col h5 {
  font-family: var(--sg-display);
  font-style: italic;
  font-weight: 500;
  font-size: 14px;
  color: var(--sg-terra);
  margin-bottom: 14px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--sg-line);
}
.sg-mega-col ul { list-style: none; display: flex; flex-direction: column; gap: 9px; }
.sg-mega-col a {
  font-size: 13.5px;
  font-weight: 500;
  color: var(--sg-brown);
  transition: color .15s, transform .15s;
  display: inline-block;
}
.sg-mega-col a:hover { color: var(--sg-orange-dk); transform: translateX(3px); }
.sg-mega-feat {
  aspect-ratio: 4/5;
  border-radius: var(--sg-r-md);
  overflow: hidden;
  background-size: cover;
  background-position: center;
  background-color: var(--sg-peach);
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 16px;
  color: #fff;
  transition: transform .2s;
  text-decoration: none;
}
.sg-mega-feat:hover { transform: translateY(-3px); }
.sg-mega-feat::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 45%, rgba(26,22,20,.75)); }
.sg-mega-feat > * { position: relative; z-index: 2; }
.sg-mega-feat small {
  font-family: var(--sg-script);
  font-size: 17px;
  color: var(--sg-orange-soft);
  margin-bottom: 2px;
}
.sg-mega-feat h4 {
  font-family: var(--sg-display);
  font-style: italic;
  font-weight: 400;
  font-size: 19px;
  color: #fff;
  line-height: 1.15;
  margin-bottom: 6px;
}
.sg-mega-feat .go {
  font-size: 11px;
  font-weight: 600;
  color: var(--sg-butter);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
</style>

{% schema %}
{
  "name": "SG — Header (Mega Menu)",
  "tag": "header",
  "class": "section-sg-header-mega",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "link_list", "id": "menu", "label": "Main menu", "default": "main-menu" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FFFFFF" },
    { "type": "checkbox", "id": "sticky", "label": "Sticky on scroll", "default": true },
    { "type": "checkbox", "id": "show_wishlist", "label": "Show wishlist icon (for Wishlist Hero app)", "default": true }
  ],
  "blocks": [
    {
      "type": "mega_feature",
      "name": "Mega menu feature card",
      "settings": [
        { "type": "text", "id": "menu_label", "label": "Attach to nav item (title match)", "info": "Must match the menu item title exactly, e.g., 'Paper Kits'" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "tag", "label": "Tag label (script)", "default": "bestseller" },
        { "type": "text", "id": "title", "label": "Title", "default": "Featured product" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Header (Mega Menu)"
    }
  ]
}
{% endschema %}
