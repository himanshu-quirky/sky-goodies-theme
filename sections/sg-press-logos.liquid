<section class="sg-section sg-press" style="background:{{ section.settings.background_color }}; padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="sg-container">
    <p class="sg-press-eyebrow">{{ section.settings.eyebrow }}</p>
  </div>
  <div class="sg-press-marquee">
    <div class="sg-marquee-track" style="animation-duration:{{ section.settings.scroll_speed }}s;">
      {% for i in (1..2) %}
        {% for block in section.blocks %}
          <div class="sg-press-item" {{ block.shopify_attributes }}>
            {% if block.settings.logo_image != blank %}
              <img src="{{ block.settings.logo_image | image_url: width: 240 }}" alt="{{ block.settings.logo_text | escape }}" loading="lazy" referrerpolicy="no-referrer">
            {% else %}
              <span class="sg-press-text sg-press-text--{{ block.settings.logo_weight }}">{{ block.settings.logo_text }}</span>
            {% endif %}
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SG Press Logos",
  "tag": "section",
  "class": "sg-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "The good company we keep"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 32
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FDFCFA"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Scroll speed (seconds per loop)",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo image (optional)"
        },
        {
          "type": "text",
          "id": "logo_text",
          "label": "Logo text (fallback)",
          "default": "NAT GEO"
        },
        {
          "type": "select",
          "id": "logo_weight",
          "label": "Text style",
          "options": [
            { "value": "regular", "label": "Regular" },
            { "value": "bold", "label": "Bold" },
            { "value": "italic", "label": "Italic" },
            { "value": "serif", "label": "Serif" }
          ],
          "default": "regular"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG Press Logos",
      "blocks": [
        { "type": "logo", "settings": { "logo_text": "NAT GEO", "logo_weight": "bold" } },
        { "type": "logo", "settings": { "logo_text": "Hot Wheels", "logo_weight": "italic" } },
        { "type": "logo", "settings": { "logo_text": "CRED", "logo_weight": "regular" } },
        { "type": "logo", "settings": { "logo_text": "Barbie", "logo_weight": "serif" } },
        { "type": "logo", "settings": { "logo_text": "DISCOVERY", "logo_weight": "bold" } },
        { "type": "logo", "settings": { "logo_text": "UNESCO", "logo_weight": "regular" } },
        { "type": "logo", "settings": { "logo_text": "TATA", "logo_weight": "serif" } },
        { "type": "logo", "settings": { "logo_text": "NCPEDP", "logo_weight": "bold" } }
      ]
    }
  ]
}
{% endschema %}
