<style>
  .sg-press-section { padding: 32px 20px; overflow: hidden; }
  .sg-press-eyebrow { text-align: center; font-size: 12px; letter-spacing: 0.12em; color: #7A7168; text-transform: uppercase; margin-bottom: 20px; }
  .sg-press-marquee { overflow: hidden; mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent); -webkit-mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent); }
  .sg-press-track { display: inline-flex; gap: 48px; animation: sg-marquee 40s linear infinite; white-space: nowrap; align-items: center; }
  @keyframes sg-marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .sg-press-item { font-family: 'DM Serif Display', serif; font-size: 20px; color: #3D3833; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.6; }
  .sg-press-item img { max-height: 40px; width: auto; display: block; }
</style>

<section class="sg-press-section" style="background:{{ section.settings.background_color }};" {{ section.shopify_attributes }}>
  {% if section.settings.eyebrow != blank %}
    <p class="sg-press-eyebrow">{{ section.settings.eyebrow }}</p>
  {% endif %}
  <div class="sg-press-marquee">
    <div class="sg-press-track" style="animation-duration:{{ section.settings.scroll_speed | default: 40 }}s;">
      {% if section.blocks.size == 0 %}
        {%- assign fb_logos = 'NAT GEO,HOT WHEELS,CRED,BARBIE,DISCOVERY,UNESCO,TATA,NCPEDP' | split: ',' -%}
        {% for loop_i in (1..2) %}
          {% for logo in fb_logos %}
            <div class="sg-press-item">{{ logo }}</div>
          {% endfor %}
        {% endfor %}
      {% else %}
        {% for loop_i in (1..2) %}
          {% for block in section.blocks %}
            <div class="sg-press-item" {{ block.shopify_attributes }}>
              {% if block.settings.logo_image != blank %}
                <img src="{{ block.settings.logo_image | image_url: width: 240 }}" alt="{{ block.settings.logo_text | escape }}" loading="lazy" referrerpolicy="no-referrer">
              {% else %}
                {{ block.settings.logo_text | default: 'BRAND' }}
              {% endif %}
            </div>
          {% endfor %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SG Press Logos",
  "tag": "section",
  "class": "sg-section-wrapper",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "The good company we keep" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 32 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 32 },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#FDFCFA" },
    { "type": "range", "id": "scroll_speed", "min": 20, "max": 60, "step": 5, "unit": "s", "label": "Scroll speed (seconds per loop)", "default": 40 }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 12,
      "settings": [
        { "type": "image_picker", "id": "logo_image", "label": "Logo image (optional)" },
        { "type": "text", "id": "logo_text", "label": "Logo text (fallback)", "default": "NAT GEO" },
        {
          "type": "select",
          "id": "logo_weight",
          "label": "Text style",
          "options": [
            { "value": "regular", "label": "Regular" },
            { "value": "bold", "label": "Bold" },
            { "value": "italic", "label": "Italic" },
            { "value": "serif", "label": "Serif" }
          ],
          "default": "regular"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG Press Logos",
      "blocks": [
        { "type": "logo", "settings": { "logo_text": "NAT GEO" } },
        { "type": "logo", "settings": { "logo_text": "HOT WHEELS" } },
        { "type": "logo", "settings": { "logo_text": "CRED" } },
        { "type": "logo", "settings": { "logo_text": "BARBIE" } },
        { "type": "logo", "settings": { "logo_text": "DISCOVERY" } },
        { "type": "logo", "settings": { "logo_text": "UNESCO" } },
        { "type": "logo", "settings": { "logo_text": "TATA" } },
        { "type": "logo", "settings": { "logo_text": "NCPEDP" } }
      ]
    }
  ]
}
{% endschema %}
