{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-press-{{ section.id }} {
    padding: {{ section.settings.padding | default: 32 }}px 0;
    background: {{ section.settings.bg_color | default: '#FAF6EC' }};
    text-align: center;
    border-top: 1px solid var(--sg-line);
    border-bottom: 1px solid var(--sg-line);
  }
{%- endstyle -%}

<section class="sg-root sg-press-{{ section.id }}" {{ section.shopify_attributes }}>
  {%- if section.settings.label != blank -%}
    <span class="sg-press-label">— {{ section.settings.label }} —</span>
  {%- endif -%}
  <div class="sg-press-logos">
    <div class="sg-press-track">
      {%- for block in section.blocks -%}
        <span class="{{ block.settings.style }}" {{ block.shopify_attributes }}>{{ block.settings.name }}</span>
      {%- endfor -%}
      {%- comment -%} duplicate set for seamless infinite scroll on mobile {%- endcomment -%}
      {%- for block in section.blocks -%}
        <span class="{{ block.settings.style }}" aria-hidden="true">{{ block.settings.name }}</span>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.sg-press-label {
  font-family: var(--sg-sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--sg-muted);
  margin-bottom: 18px;
  display: block;
}
.sg-press-logos {
  max-width: var(--sg-container);
  margin: 0 auto;
  overflow: hidden;
  position: relative;
  -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
          mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
}
.sg-press-track {
  display: flex;
  gap: 42px;
  align-items: center;
  width: max-content;
  animation: sg-press-marquee 28s linear infinite;
}
@media (min-width: 900px) {
  .sg-press-logos {
    padding: 0 var(--sg-gutter);
    -webkit-mask-image: none;
            mask-image: none;
  }
  .sg-press-track {
    width: 100%;
    justify-content: center;
    flex-wrap: wrap;
    animation: none;
  }
  .sg-press-track > span[aria-hidden="true"] { display: none; }
}
@keyframes sg-press-marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.sg-press-logos span {
  font-family: var(--sg-display);
  font-weight: 400;
  font-size: 20px;
  color: var(--sg-brown);
  opacity: 0.55;
  transition: opacity .2s;
  letter-spacing: 0.01em;
}
.sg-press-logos span:hover { opacity: 1; }
.sg-press-logos span.italic { font-style: italic; font-weight: 500; }
.sg-press-logos span.sans {
  font-family: var(--sg-sans);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
}
</style>

{% schema %}
{
  "name": "SG — Press Logos",
  "tag": "section",
  "class": "section-sg-press-logos",
  "settings": [
    { "type": "text", "id": "label", "label": "Eyebrow label", "default": "As featured in" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FAF6EC" },
    { "type": "range", "id": "padding", "label": "Vertical padding", "min": 16, "max": 120, "step": 4, "default": 32 }
  ],
  "max_blocks": 12,
  "blocks": [
    {
      "type": "logo",
      "name": "Publication",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Vogue" },
        { "type": "select", "id": "style", "label": "Style", "options": [
          { "value": "italic", "label": "Italic serif" },
          { "value": "sans", "label": "All caps sans" }
        ], "default": "italic" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Press Logos",
      "blocks": [
        { "type": "logo", "settings": { "name": "Vogue", "style": "italic" } },
        { "type": "logo", "settings": { "name": "Elle Decor", "style": "sans" } },
        { "type": "logo", "settings": { "name": "Lonely Planet", "style": "italic" } },
        { "type": "logo", "settings": { "name": "The Hindu", "style": "sans" } },
        { "type": "logo", "settings": { "name": "Verve", "style": "italic" } },
        { "type": "logo", "settings": { "name": "Mid-Day", "style": "sans" } },
        { "type": "logo", "settings": { "name": "Architectural Digest", "style": "italic" } }
      ]
    }
  ]
}
{% endschema %}
