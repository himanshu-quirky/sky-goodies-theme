{%- style -%}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px; }
  @media screen and (min-width: 750px) { .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } }
{%- endstyle -%}
<footer class="ftr section-{{ section.id }}-padding" style="background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};"><div class="ftr__inner"><div class="ftr__brand">{%- if section.settings.logo != blank -%}<img src="{{ section.settings.logo | image_url: width: 400 }}" alt="{{ section.settings.logo.alt | default: shop.name | escape }}" style="height:56px;width:auto;margin-bottom:14px" width="200" height="56" loading="lazy">{%- else -%}<span class="sh" style="margin-bottom:14px;display:block;color: {{ section.settings.heading_color }}">{{ shop.name }}</span>{%- endif -%}{%- if section.settings.text != blank -%}<p>{{ section.settings.text }}</p>{%- endif -%}{%- if section.settings.show_social -%}<div class="ftr__social">{%- if settings.social_instagram_link != blank -%}<a href="{{ settings.social_instagram_link }}" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>{%- endif -%}{%- if settings.social_facebook_link != blank -%}<a href="{{ settings.social_facebook_link }}" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>{%- endif -%}{%- if settings.social_youtube_link != blank -%}<a href="{{ settings.social_youtube_link }}" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg></a>{%- endif -%}{%- if settings.social_pinterest_link != blank -%}<a href="{{ settings.social_pinterest_link }}" aria-label="Pinterest"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.236 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.78 1.172-4.97 1.172-4.97s-.299-.598-.299-1.482c0-1.388.806-2.428 1.808-2.428.853 0 1.267.641 1.267 1.408 0 .858-.546 2.14-.828 3.33-.235.995.499 1.806 1.476 1.806 1.772 0 3.135-1.867 3.135-4.56 0-2.384-1.714-4.052-4.161-4.052-2.834 0-4.498 2.126-4.498 4.323 0 .856.33 1.773.741 2.274a.3.3 0 0 1 .069.282c-.076.315-.245 1.003-.278 1.142-.044.181-.146.22-.337.133-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.966-.527-2.292-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.938.29 1.931.446 2.962.446 5.523 0 10-4.477 10-10S17.523 2 12 2z"/></svg></a>{%- endif -%}</div>{%- endif -%}</div>{%- for block in section.blocks -%}{%- if block.type == 'menu' -%}<div class="ftr__col" {{ block.shopify_attributes }}><h4 style="color: {{ section.settings.heading_color }}">{{ block.settings.title }}</h4>{%- assign footer_linklist = block.settings.menu -%}{%- if footer_linklist != blank -%}<ul>{%- for link in footer_linklist.links -%}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{%- endfor -%}</ul>{%- endif -%}</div>{%- endif -%}{%- endfor -%}</div><div class="ftr__bot"><p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p></div></footer>
{% schema %}{"name":"Sky Footer","settings":[{"type":"color","id":"bg_color","label":"Background Color","default":"#F2EBDF"},{"type":"color","id":"text_color","label":"Text Color","default":"#6B6560"},{"type":"color","id":"heading_color","label":"Column Heading Color","default":"#2C2825"},{"type":"image_picker","id":"logo","label":"Logo Image"},{"type":"textarea","id":"text","label":"Brand Tagline","default":"Simple joys in a complex world. Beautiful paper craft kits, playful decor, and feel-good gifts — all made in India."},{"type":"checkbox","id":"show_social","label":"Show Social Icons","info":"Social links are configured in Theme Settings → Social Media","default":true},{"type":"range","id":"padding_top","min":0,"max":100,"step":4,"unit":"px","label":"Padding Top","default":64},{"type":"range","id":"padding_bottom","min":0,"max":100,"step":4,"unit":"px","label":"Padding Bottom","default":32}],"blocks":[{"type":"menu","name":"Menu Column","settings":[{"type":"text","id":"title","label":"Column Heading","default":"Links"},{"type":"link_list","id":"menu","label":"Menu"}]}],"presets":[{"name":"Sky Footer","blocks":[{"type":"menu","settings":{"title":"Shop"}},{"type":"menu","settings":{"title":"Help"}},{"type":"menu","settings":{"title":"Company"}}]}],"enabled_on":{"groups":["footer"]}}{% endschema %}
