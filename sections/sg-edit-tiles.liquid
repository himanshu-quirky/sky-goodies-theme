{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-edits-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top | default: 64 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 64 }}px;
  }
  @media (min-width: 768px) {
    .sg-edits-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop | default: 100 }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop | default: 100 }}px;
    }
  }
{%- endstyle -%}

<section class="sg-root sg-edits-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-wrap">
    <div class="sg-section-head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="sg-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading | default: 'Shop by Edit' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="sg-edits-grid">
      {%- for block in section.blocks -%}
        <a class="sg-edits-tile"
           href="{{ block.settings.link | default: '#' }}"
           {% if block.settings.image %}style="background-image: url('{{ block.settings.image | image_url: width: 1200 }}');"{% endif %}
           {{ block.shopify_attributes }}>
          <span class="sg-edits-cta" style="color: {{ block.settings.cta_color | default: '#E8845A' }};">{{ block.settings.label | default: 'Shop Edit' }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.sg-edits-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
}
@media (min-width: 768px) { .sg-edits-grid { grid-template-columns: 1fr 1fr; gap: 22px; } }
.sg-edits-tile {
  position: relative;
  aspect-ratio: 1.2 / 1;
  border-radius: 30px;
  overflow: hidden;
  background-size: cover;
  background-position: center;
  background-color: var(--sg-peach);
  border: 2px solid var(--sg-ink);
  transition: transform .2s, box-shadow .2s;
  display: block;
}
.sg-edits-tile:hover { transform: translateY(-3px); box-shadow: 6px 6px 0 var(--sg-ink); }
.sg-edits-cta {
  position: absolute;
  bottom: 20px; left: 20px; right: 20px;
  background: var(--sg-white);
  text-align: center;
  padding: 14px 20px;
  font-family: var(--sg-display);
  font-weight: 900;
  font-size: 22px;
  border-radius: 999px;
  border: 2px solid var(--sg-ink);
  letter-spacing: -0.01em;
}
@media (min-width: 768px) {
  .sg-edits-cta { font-size: 26px; padding: 16px 24px; }
}
</style>

{% schema %}
{
  "name": "SG — Collection Edits",
  "tag": "section",
  "class": "section-sg-edit-tiles",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Edit" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Themed drops, curated by our studio." },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#FAF6F0" },
    { "type": "range", "id": "padding_top", "label": "Padding top (mobile)", "min": 20, "max": 120, "step": 4, "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (mobile)", "min": 20, "max": 120, "step": 4, "default": 64 },
    { "type": "range", "id": "padding_top_desktop", "label": "Padding top (desktop)", "min": 20, "max": 200, "step": 4, "default": 100 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Padding bottom (desktop)", "min": 20, "max": 200, "step": 4, "default": 100 }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "tile",
      "name": "Edit tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Button label", "default": "The Pooja Edit" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "color", "id": "cta_color", "label": "Button text color", "default": "#E8845A" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Collection Edits",
      "blocks": [
        { "type": "tile", "settings": { "label": "The Pooja Edit", "cta_color": "#E8845A" } },
        { "type": "tile", "settings": { "label": "Birthday Party Drop", "cta_color": "#D26939" } },
        { "type": "tile", "settings": { "label": "Home Décor Edit", "cta_color": "#3D3833" } },
        { "type": "tile", "settings": { "label": "Animal Kingdom", "cta_color": "#C17753" } }
      ]
    }
  ]
}
{% endschema %}
