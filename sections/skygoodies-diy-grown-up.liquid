{%- style -%}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px; }
  @media screen and (min-width: 750px) { .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } }
{%- endstyle -%}
<section class="diy section-{{ section.id }}-padding" style="background: {{ section.settings.bg_color }};"><div class="diy__inner"><div class="diy__top"><div>{%- if section.settings.eyebrow != blank -%}<p class="eyebrow" style="color: {{ section.settings.accent_color }}">{{ section.settings.eyebrow }}</p>{%- endif -%}<h2 class="sh" style="color: {{ section.settings.heading_color }}">{{ section.settings.heading }}</h2>{%- if section.settings.text != blank -%}<p class="sd" style="color: {{ section.settings.text_color }}">{{ section.settings.text }}</p>{%- endif -%}</div>{%- if section.settings.button_link != blank -%}<a href="{{ section.settings.button_link }}" class="feat__top-link" style="color: {{ section.settings.accent_color }}">{{ section.settings.button_text }}<svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg></a>{%- endif -%}</div><div class="diy__layout"><div class="diy__hero">{%- if section.settings.image != blank -%}<img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.image_heading | escape }}" width="800" height="600" loading="lazy">{%- else -%}<img src="https://placehold.co/800x600/3EB8A8/FFF?text=Grown+Up+DIYs" alt="{{ section.settings.image_heading | escape }}" width="800" height="600" loading="lazy">{%- endif -%}<div class="diy__hero-overlay"><h3>{{ section.settings.image_heading }}</h3><p>{{ section.settings.image_text }}</p>{%- if section.settings.image_button_link != blank -%}<a href="{{ section.settings.image_button_link }}" class="btn btn-w" style="padding:10px 22px;font-size:.78rem;margin-top:8px;display:inline-flex;">{{ section.settings.image_button_text }}</a>{%- endif -%}</div></div><div class="diy__grid">{%- assign diy_collection = section.settings.collection -%}{%- if diy_collection != blank and diy_collection.products_count > 0 -%}{%- for product in diy_collection.products limit: section.settings.products_to_show -%}{%- render 'skygoodies-product-card', product: product -%}{%- endfor -%}{%- else -%}{%- for i in (1..4) -%}{%- render 'skygoodies-product-card' -%}{%- endfor -%}{%- endif -%}</div></div></div></section>
{% schema %}{"name":"Sky Promo + Product Grid","settings":[{"type":"color","id":"bg_color","label":"Background Color","default":"#F2EBDF"},{"type":"color","id":"heading_color","label":"Heading Color","default":"#2C2825"},{"type":"color","id":"text_color","label":"Text Color","default":"#6B6560"},{"type":"color","id":"accent_color","label":"Accent Color","default":"#FD9963"},{"type":"text","id":"eyebrow","label":"Eyebrow Text","default":"Slow making for fast lives"},{"type":"text","id":"heading","label":"Heading","default":"Calm crafty time for grown-ups"},{"type":"textarea","id":"text","label":"Subtext","default":"A simple paper craft that feels satisfying to make and even nicer to keep."},{"type":"text","id":"button_text","label":"Link Text","default":"See all"},{"type":"url","id":"button_link","label":"Link URL"},{"type":"header","content":"Promotional Banner"},{"type":"image_picker","id":"image","label":"Banner Image"},{"type":"text","id":"image_heading","label":"Banner Heading","default":"Paper projects that feel like a deep breath."},{"type":"textarea","id":"image_text","label":"Banner Text","default":"Vintage-inspired, detail-rich paper craft kits for grown-ups."},{"type":"text","id":"image_button_text","label":"Banner Button Text","default":"Explore the collection"},{"type":"url","id":"image_button_link","label":"Banner Button Link"},{"type":"header","content":"Products"},{"type":"collection","id":"collection","label":"Collection"},{"type":"range","id":"products_to_show","min":2,"max":8,"step":2,"default":4,"label":"Products to show"},{"type":"range","id":"padding_top","min":0,"max":100,"step":4,"unit":"px","label":"Padding Top","default":72},{"type":"range","id":"padding_bottom","min":0,"max":100,"step":4,"unit":"px","label":"Padding Bottom","default":72}],"presets":[{"name":"Sky Promo + Product Grid"}]}{% endschema %}
