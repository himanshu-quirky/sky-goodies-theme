{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

<style>
  .sg-trust { padding: 24px 20px; background: {{ section.settings.bg_color | default: '#FDFCFA' }}; border-bottom: 1px solid #EDE8E2; }
  .sg-trust__track { display: flex; gap: 32px; max-width: 1200px; margin: 0 auto; overflow-x: auto; scrollbar-width: none; justify-content: center; flex-wrap: wrap; }
  .sg-trust__track::-webkit-scrollbar { display: none; }
  .sg-trust__item { display: flex; align-items: center; gap: 8px; flex-shrink: 0; font-size: 13px; color: #3D3833; }
  .sg-trust__icon { flex-shrink: 0; width: 18px; height: 18px; display: inline-flex; align-items: center; justify-content: center; }
  .sg-trust__icon svg { width: 18px !important; height: 18px !important; fill: none; stroke: #E8845A; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
  .sg-trust__label { line-height: 1.4; }
  .sg-trust__label p { margin: 0; }
  @media (max-width: 749px) { .sg-trust { padding: 16px; } .sg-trust__track { gap: 16px; } .sg-trust__item { font-size: 12px; } }
</style>

<div class="sg-section sg-trust" {{ section.shopify_attributes }}>
  <div class="sg-trust__track">
    {%- for block in section.blocks -%}
      <div class="sg-trust__item" {{ block.shopify_attributes }}>
        <div class="sg-trust__icon">
          {%- case block.settings.icon -%}
            {%- when 'shield' -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {%- when 'pin' -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {%- when 'check' -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {%- when 'leaf' -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66L7 18l4-2 4.5-4.5C17 10 18 7 18 7l-1 1z"/></svg>
            {%- when 'truck' -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {%- when 'heart' -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            {%- else -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          {%- endcase -%}
        </div>
        <span class="sg-trust__label">{{ block.settings.text }}</span>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "SG Trust Strip",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FDFCFA"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield" },
            { "value": "pin", "label": "Map Pin" },
            { "value": "check", "label": "Checkmark" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "truck", "label": "Truck" },
            { "value": "heart", "label": "Heart" },
            { "value": "smile", "label": "Smile" }
          ],
          "default": "shield"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p><strong>50,000+</strong> happy makers</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG Trust Strip",
      "blocks": [
        { "type": "item", "settings": { "icon": "shield", "text": "<p><strong>50,000+<\/strong> happy makers<\/p>" } },
        { "type": "item", "settings": { "icon": "pin", "text": "<p><strong>Made in<\/strong> Mumbai, India<\/p>" } },
        { "type": "item", "settings": { "icon": "check", "text": "<p><strong>NID-designed<\/strong> craft kits<\/p>" } },
        { "type": "item", "settings": { "icon": "leaf", "text": "<p><strong>Eco-friendly<\/strong> & biodegradable<\/p>" } },
        { "type": "item", "settings": { "icon": "truck", "text": "<p><strong>Free shipping<\/strong> over Rs.1,000<\/p>" } }
      ]
    }
  ]
}
{% endschema %}
