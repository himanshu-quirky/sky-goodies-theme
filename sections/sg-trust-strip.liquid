{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-trust-{{ section.id }} {
    padding: {{ section.settings.padding | default: 40 }}px 0;
    background: {{ section.settings.bg_color | default: '#FAF6EC' }};
    border-top: 1px solid var(--sg-line);
    border-bottom: 1px solid var(--sg-line);
  }
{%- endstyle -%}

<section class="sg-root sg-trust-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-trust-grid">
    {%- for block in section.blocks -%}
      <div class="sg-trust-item" {{ block.shopify_attributes }}>
        <div class="sg-trust-icon">
          {%- case block.settings.icon -%}
            {%- when 'ship' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {%- when 'cod' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            {%- when 'return' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            {%- when 'hand' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            {%- when 'leaf' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 11H5a2 2 0 0 0-2 2v7h6v-5"/><path d="M19 11h-4V6a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v5z"/></svg>
            {%- when 'shield' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {%- when 'made-in' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          {%- endcase -%}
        </div>
        <h4>{{ block.settings.title }}</h4>
        <p>{{ block.settings.subtitle }}</p>
      </div>
    {%- endfor -%}
  </div>
</section>

<style>
.sg-trust-grid {
  max-width: var(--sg-container);
  margin: 0 auto;
  padding: 0 var(--sg-gutter);
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
}
@media (min-width: 768px) { .sg-trust-grid { grid-template-columns: repeat(4, 1fr); } }
.sg-trust-item { text-align: center; padding: 0 16px; position: relative; }
@media (min-width: 768px) {
  .sg-trust-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0; top: 18%; bottom: 18%;
    width: 1px;
    background: var(--sg-line);
  }
}
.sg-trust-icon { width: 44px; height: 44px; margin: 0 auto 10px; color: var(--sg-terra); }
.sg-trust-icon svg { width: 100%; height: 100%; }
.sg-trust-item h4 {
  font-family: var(--sg-display);
  font-style: italic;
  font-weight: 500;
  font-size: 16px;
  color: var(--sg-ink);
  margin-bottom: 3px;
  letter-spacing: -0.01em;
}
.sg-trust-item p { font-size: 12px; color: var(--sg-muted); font-weight: 500; }
</style>

{% schema %}
{
  "name": "SG — Trust Strip",
  "tag": "section",
  "class": "section-sg-trust-strip",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FAF6EC" },
    { "type": "range", "id": "padding", "label": "Vertical padding (px)", "min": 20, "max": 120, "step": 4, "default": 40 }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "item",
      "name": "Trust badge",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "ship", "label": "Shipping truck" },
          { "value": "cod", "label": "COD / Card" },
          { "value": "return", "label": "Return / Refresh" },
          { "value": "hand", "label": "Handmade / Heart" },
          { "value": "leaf", "label": "Eco / Leaf" },
          { "value": "shield", "label": "Secure / Shield" },
          { "value": "made-in", "label": "Made in / Home" }
        ], "default": "ship" },
        { "type": "text", "id": "title", "label": "Title", "default": "Free Shipping" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Orders above ₹1,000" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Trust Strip",
      "blocks": [
        { "type": "item", "settings": { "icon": "ship", "title": "Free Shipping", "subtitle": "Orders above ₹1,000" } },
        { "type": "item", "settings": { "icon": "cod", "title": "COD Available", "subtitle": "Across India" } },
        { "type": "item", "settings": { "icon": "return", "title": "Easy Returns", "subtitle": "7-day hassle-free" } },
        { "type": "item", "settings": { "icon": "hand", "title": "Handmade in Mumbai", "subtitle": "By NID-trained artists" } }
      ]
    }
  ]
}
{% endschema %}
