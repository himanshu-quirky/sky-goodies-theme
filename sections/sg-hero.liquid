          "type": "slide",
          "settings": {
            "tag": "🌿 For Little Hands",
            "tag_bg": "#C8E616",
            "tag_color": "#1E1B18",
            "heading": "Screen-free<br>summer<br><em>unlocked.</em>",
            "subheading": "Endangered animal BOX SETs, mini pets, and more.",
            "slide_bg": "#A27C5C",
