{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-hero-{{ section.id }} {
    background: {{ section.settings.section_bg }};
  }
  .sg-hero-{{ section.id }} .sg-hero-section {
    min-height: {{ section.settings.mobile_height }}px;
  }
  @media (min-width: 900px) {
    .sg-hero-{{ section.id }} .sg-hero-section {
      min-height: {{ section.settings.desktop_height }}px;
    }
  }
{%- endstyle -%}

<div class="sg-root sg-hero-wrapper sg-hero-{{ section.id }}" data-sg-hero="{{ section.id }}" {{ section.shopify_attributes }}>
  <section class="sg-hero-section" aria-roledescription="carousel">
    <div class="sg-hero-slides" data-slides>
      {%- for block in section.blocks -%}
        {%- assign theme_bg = block.settings.slide_bg | default: '#D26939' -%}
        {%- assign slide_img = block.settings.image -%}
        <div class="sg-hero-slide{% if forloop.first %} is-active first{% endif %}"
             data-slide="{{ forloop.index0 }}"
             style="background: {{ theme_bg }};"
             {{ block.shopify_attributes }}>
          <div class="sg-hero-content">
            {%- if block.settings.tag != blank -%}
              <span class="sg-hero-tag" style="background: {{ block.settings.tag_bg }}; color: {{ block.settings.tag_color }};">{{ block.settings.tag }}</span>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h1 class="sg-hero-title">{{ block.settings.heading }}</h1>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <p class="sg-hero-sub">{{ block.settings.subheading }}</p>
            {%- endif -%}
            <div class="sg-hero-ctas">
              {%- if block.settings.cta1_text != blank -%}
                <a href="{{ block.settings.cta1_link | default: '#' }}" class="sg-pill sg-pill--lime sg-pill--lg">{{ block.settings.cta1_text }}</a>
              {%- endif -%}
              {%- if block.settings.cta2_text != blank -%}
                <a href="{{ block.settings.cta2_link | default: '#' }}" class="sg-pill sg-pill--white sg-pill--lg">{{ block.settings.cta2_text }}</a>
              {%- endif -%}
            </div>
          </div>
          <div class="sg-hero-image"
               {% if slide_img %}style="background-image: url('{{ slide_img | image_url: width: 1400 }}');"{% endif %}>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="sg-hero-controls">
        <button class="sg-hero-arrow" data-dir="prev" aria-label="Previous slide">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="sg-hero-dots" role="tablist">
          {%- for block in section.blocks -%}
            <button class="sg-hero-dot{% if forloop.first %} active{% endif %}" data-dot="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
        <button class="sg-hero-arrow" data-dir="next" aria-label="Next slide">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    {%- endif -%}

    <div class="sg-hero-wave" aria-hidden="true" style="background: {{ section.settings.wave_color | default: '#FAF6F0' }};"></div>
  </section>
</div>

<style>
.sg-hero-wrapper { position: relative; overflow: hidden; }
.sg-hero-section { position: relative; }
.sg-hero-slides { position: relative; }
.sg-hero-slide {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-columns: 1fr;
  opacity: 0;
  pointer-events: none;
  transition: opacity .8s var(--sg-ease);
}
.sg-hero-slide.first { position: relative; inset: auto; }
.sg-hero-slide.is-active { opacity: 1; pointer-events: auto; position: relative; inset: auto; }
.sg-hero-slide.first:not(.is-active) { position: absolute; inset: 0; opacity: 0; }
@media (min-width: 900px) { .sg-hero-slide { grid-template-columns: 1fr 1fr; } }

.sg-hero-content {
  padding: 48px var(--sg-gutter) 120px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  color: #fff;
  position: relative;
  z-index: 2;
  max-width: 720px;
}
@media (min-width: 900px) { .sg-hero-content { padding: 80px 40px 80px 60px; } }

.sg-hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 18px;
  border-radius: 999px;
  font-weight: 800;
  font-size: 14px;
  letter-spacing: 0.04em;
  margin-bottom: 20px;
  border: 2px solid var(--sg-ink);
  box-shadow: 4px 4px 0 var(--sg-ink);
  align-self: flex-start;
  text-transform: uppercase;
}
.sg-hero-title {
  font-family: var(--sg-display);
  font-weight: 900;
  font-size: clamp(48px, 9vw, 120px);
  line-height: 0.88;
  color: #fff;
  margin: 0 0 20px;
  letter-spacing: -0.04em;
}
.sg-hero-title em {
  font-style: italic;
  font-weight: 400;
  color: var(--sg-cream);
}
.sg-hero-sub {
  font-size: 17px;
  color: rgba(255,255,255,.88);
  max-width: 440px;
  margin: 0 0 32px;
  font-weight: 500;
  line-height: 1.5;
}
.sg-hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }

.sg-hero-image {
  position: relative;
  min-height: 320px;
  background-size: cover;
  background-position: center;
}
@media (min-width: 900px) { .sg-hero-image { min-height: inherit; } }

.sg-hero-controls {
  position: absolute;
  bottom: 28px; left: 50%;
  transform: translateX(-50%);
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 14px;
}
.sg-hero-arrow {
  width: 44px; height: 44px;
  border-radius: 50%;
  background: var(--sg-white);
  border: 2px solid var(--sg-ink);
  color: var(--sg-ink);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all .15s;
}
.sg-hero-arrow:hover { transform: translateY(-2px); box-shadow: 0 4px 0 var(--sg-ink); }
.sg-hero-arrow svg { width: 18px; height: 18px; }
.sg-hero-dots { display: flex; gap: 6px; }
.sg-hero-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: rgba(255,255,255,.5);
  border: 2px solid var(--sg-ink);
  transition: all .2s;
  cursor: pointer;
}
.sg-hero-dot.active { background: var(--sg-lime); width: 28px; border-radius: 999px; }

.sg-hero-wave {
  position: absolute;
  bottom: -1px; left: 0; right: 0;
  z-index: 3;
  height: 80px;
  clip-path: ellipse(70% 100% at 50% 100%);
}
@media (min-width: 768px) {
  .sg-hero-wave { height: 110px; clip-path: ellipse(100% 100% at 50% 100%); }
}
</style>

<script>
(function() {
  var root = document.querySelector('.sg-hero-{{ section.id }}');
  if (!root) return;
  var slides = root.querySelectorAll('.sg-hero-slide');
  var dots = root.querySelectorAll('.sg-hero-dot');
  var idx = 0;
  var timer;
  function go(n) {
    idx = (n + slides.length) % slides.length;
    slides.forEach(function(s, i) { s.classList.toggle('is-active', i === idx); });
    dots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
    reset();
  }
  function next() { go(idx + 1); }
  function prev() { go(idx - 1); }
  function reset() { clearInterval(timer); {% if section.settings.autoplay %}timer = setInterval(next, {{ section.settings.autoplay_speed | default: 6000 }});{% endif %} }
  root.querySelectorAll('[data-dir="next"]').forEach(function(b) { b.addEventListener('click', next); });
  root.querySelectorAll('[data-dir="prev"]').forEach(function(b) { b.addEventListener('click', prev); });
  dots.forEach(function(d) { d.addEventListener('click', function() { go(parseInt(d.dataset.dot, 10)); }); });
  reset();
  root.addEventListener('mouseenter', function() { clearInterval(timer); });
  root.addEventListener('mouseleave', reset);
})();
</script>

{% schema %}
{
  "name": "SG — Hero Slideshow",
  "tag": "section",
  "class": "section-sg-hero",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Fallback background",
      "default": "#FAF6F0"
    },
    {
      "type": "color",
      "id": "wave_color",
      "label": "Wave color (should match the section that follows)",
      "default": "#FAF6F0"
    },
    {
      "type": "number",
      "id": "mobile_height",
      "label": "Mobile minimum height (px)",
      "default": 600
    },
    {
      "type": "number",
      "id": "desktop_height",
      "label": "Desktop minimum height (px)",
      "default": 700
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-advance slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Auto-advance interval (ms)",
      "min": 3000,
      "max": 10000,
      "step": 500,
      "default": 6000
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "text",
          "id": "tag",
          "label": "Tag / badge text",
          "default": "⚡ Selling Fast"
        },
        {
          "type": "color",
          "id": "tag_bg",
          "label": "Tag background",
          "default": "#E8845A"
        },
        {
          "type": "color",
          "id": "tag_color",
          "label": "Tag text color",
          "default": "#FFFFFF"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Headline (use <em>word</em> to italicise)",
          "default": "Gifting<br>made<br><em>joyful.</em>"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading",
          "default": "Handcrafted paper kits for birthdays, housewarmings & everyday wonder."
        },
        {
          "type": "color",
          "id": "slide_bg",
          "label": "Slide background color",
          "default": "#D26939"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide image (right side)"
        },
        {
          "type": "text",
          "id": "cta1_text",
          "label": "Primary CTA text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "cta1_link",
          "label": "Primary CTA link"
        },
        {
          "type": "text",
          "id": "cta2_text",
          "label": "Secondary CTA text",
          "default": "Bestsellers"
        },
        {
          "type": "url",
          "id": "cta2_link",
          "label": "Secondary CTA link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Hero Slideshow",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "tag": "⚡ Selling Fast",
            "heading": "Gifting<br>made<br><em>joyful.</em>",
            "subheading": "Handcrafted paper kits for birthdays, housewarmings & everyday wonder.",
            "slide_bg": "#D26939",
            "cta1_text": "Shop Now",
            "cta2_text": "Bestsellers"
          }
        },
        {
          "type": "slide",
          "settings": {
            "tag": "★ Bestsellers",
            "tag_bg": "#F5CF8A",
            "tag_color": "#1E1B18",
            "heading": "Paper,<br>but make it<br><em>magical.</em>",
            "subheading": "Lamps that glow, birds that flutter, idols that mean something.",
            "slide_bg": "#C17753",
            "cta1_text": "See lamps",
            "cta2_text": "All décor"
          }
        },
