{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-hero-{{ section.id }} { background: {{ section.settings.bg_color | default: '#F5EFE3' }}; }
  .sg-hero-{{ section.id }} .sg-hero-left {
    background: {{ section.settings.left_bg | default: '#E8845A' }};
    color: {{ section.settings.left_text | default: '#FAF6EC' }};
    min-height: {{ section.settings.mobile_height | default: 520 }}px;
  }
  .sg-hero-{{ section.id }} .sg-hero-title,
  .sg-hero-{{ section.id }} .sg-hero-eyebrow,
  .sg-hero-{{ section.id }} .sg-hero-sub,
  .sg-hero-{{ section.id }} .sg-hero-cta {
    color: {{ section.settings.left_text | default: '#FAF6EC' }};
  }
  .sg-hero-{{ section.id }} .sg-hero-cta { border-bottom-color: {{ section.settings.left_text | default: '#FAF6EC' }}; }
  .sg-hero-{{ section.id }} .sg-hero-title .script { color: {{ section.settings.script_color | default: '#F0D288' }}; }
  .sg-hero-{{ section.id }} .sg-hero-deco svg { fill: {{ section.settings.deco_color | default: '#F0D288' }}; }
  @media (min-width: 900px) {
    .sg-hero-{{ section.id }} .sg-hero-left { min-height: {{ section.settings.desktop_height | default: 620 }}px; }
  }
{%- endstyle -%}

<section class="sg-root sg-hero-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-hero-grid">
    <div class="sg-hero-left">
      {%- if section.settings.eyebrow != blank -%}
        <span class="sg-hero-eyebrow">— {{ section.settings.eyebrow }} —</span>
      {%- endif -%}
      {%- if section.settings.show_deco -%}
        <div class="sg-hero-deco">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 L14 9 L22 9 L15.5 14 L18 22 L12 17 L6 22 L8.5 14 L2 9 L10 9 Z"/></svg>
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 L14 9 L22 9 L15.5 14 L18 22 L12 17 L6 22 L8.5 14 L2 9 L10 9 Z"/></svg>
        </div>
      {%- endif -%}
      <h1 class="sg-hero-title">
        {{ section.settings.title_line_1 }}
        {%- if section.settings.title_script != blank -%}
          <span class="script">{{ section.settings.title_script }}</span>
        {%- endif -%}
      </h1>
      {%- if section.settings.sub != blank -%}
        <p class="sg-hero-sub">{{ section.settings.sub }}</p>
      {%- endif -%}
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link | default: '#' }}" class="sg-hero-cta">{{ section.settings.cta_text }}&nbsp;→</a>
      {%- endif -%}
    </div>
    <div class="sg-hero-right"
         {% if section.settings.image %}style="background-image: url('{{ section.settings.image | image_url: width: 1400 }}');"{% endif %}>
      {%- if section.settings.stamp_bottom != blank or section.settings.stamp_big != blank -%}
        <div class="sg-hero-stamp">
          {{ section.settings.stamp_top | default: 'New' }}
          <strong>{{ section.settings.stamp_big | default: '2026' }}</strong>
          {{ section.settings.stamp_bottom | default: 'Collection' }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
.sg-hero-grid {
  display: grid;
  grid-template-columns: 1fr;
  min-height: 520px;
}
@media (min-width: 900px) { .sg-hero-grid { grid-template-columns: 1fr 1fr; min-height: 620px; } }

.sg-hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 60px 32px;
  text-align: center;
  position: relative;
  background-image:
    radial-gradient(circle at 15% 25%, rgba(255,253,248,0.08), transparent 40%),
    radial-gradient(circle at 85% 75%, rgba(255,253,248,0.05), transparent 40%);
}
.sg-hero-eyebrow {
  font-family: var(--sg-sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  opacity: 0.85;
  margin-bottom: 24px;
}
.sg-hero-deco {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 4px;
}
.sg-hero-deco svg { width: 22px; height: 22px; }
.sg-hero-title {
  font-family: var(--sg-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(42px, 6vw, 86px);
  line-height: 0.96;
  letter-spacing: -0.015em;
  margin-bottom: 20px;
  max-width: 540px;
}
.sg-hero-title .script {
  font-family: var(--sg-script);
  font-weight: 600;
  font-style: normal;
  font-size: clamp(58px, 8.2vw, 124px);
  display: block;
  margin: -6px 0 -4px;
  line-height: 0.9;
  transform: rotate(-2deg);
}
.sg-hero-sub {
  font-family: var(--sg-sans);
  font-size: 15px;
  opacity: 0.9;
  max-width: 380px;
  line-height: 1.55;
  margin-bottom: 30px;
}
.sg-hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 14px 0;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  border-bottom: 1.5px solid currentColor;
  padding-bottom: 6px;
  transition: all .2s;
}
.sg-hero-cta:hover { gap: 14px; }

.sg-hero-right {
  background-size: cover;
  background-position: center;
  background-color: var(--sg-paper-2);
  min-height: 340px;
  position: relative;
}
.sg-hero-stamp {
  position: absolute;
  bottom: 28px; left: 28px;
  width: 120px; height: 120px;
  border-radius: 50%;
  background: var(--sg-ivory);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-family: var(--sg-display);
  font-style: italic;
  font-size: 11px;
  color: var(--sg-ink);
  line-height: 1.15;
  box-shadow: var(--sg-shadow);
  transform: rotate(-6deg);
  border: 1px solid var(--sg-line);
}
.sg-hero-stamp strong {
  display: block;
  font-style: normal;
  font-weight: 500;
  font-size: 17px;
  color: var(--sg-orange-dk);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin: 3px 0 1px;
  font-family: var(--sg-display);
}
@media (min-width: 768px) { .sg-hero-stamp { width: 140px; height: 140px; } }
</style>

{% schema %}
{
  "name": "SG — Hero (full-width)",
  "tag": "section",
  "class": "section-sg-hero",
  "settings": [
    { "type": "header", "content": "Left panel — text" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Handcrafted in Mumbai" },
    { "type": "checkbox", "id": "show_deco", "label": "Show decorative stars", "default": true },
    { "type": "text", "id": "title_line_1", "label": "Title (regular)", "default": "The Mother's Day" },
    { "type": "text", "id": "title_script", "label": "Title (script second line)", "default": "Gift Guide" },
    { "type": "textarea", "id": "sub", "label": "Subheading", "default": "Handcrafted paper kits for the mom who has everything — and the one who just wants a slow afternoon back." },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Shop Now" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "header", "content": "Right panel — image" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "stamp_top", "label": "Stamp top text", "default": "New" },
    { "type": "text", "id": "stamp_big", "label": "Stamp big (center)", "default": "2026" },
    { "type": "text", "id": "stamp_bottom", "label": "Stamp bottom text", "default": "Collection" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Overall background", "default": "#F5EFE3" },
    { "type": "color", "id": "left_bg", "label": "Left panel background", "default": "#E8845A" },
    { "type": "color", "id": "left_text", "label": "Left panel text", "default": "#FAF6EC" },
    { "type": "color", "id": "script_color", "label": "Script word color", "default": "#F0D288" },
    { "type": "color", "id": "deco_color", "label": "Decorative stars color", "default": "#F0D288" },
    { "type": "header", "content": "Sizing" },
    { "type": "range", "id": "mobile_height", "label": "Mobile minimum height (px)", "min": 400, "max": 800, "step": 20, "default": 520 },
    { "type": "range", "id": "desktop_height", "label": "Desktop minimum height (px)", "min": 400, "max": 900, "step": 20, "default": 620 }
  ],
  "presets": [
    { "name": "SG — Hero (full-width)" }
  ]
}
{% endschema %}
