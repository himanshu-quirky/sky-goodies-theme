{%- style -%}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px; }
  @media screen and (min-width: 750px) { .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } }
{%- endstyle -%}
<section class="proc section-{{ section.id }}-padding" style="background: {{ section.settings.bg_color }};"><div class="proc__inner"><div class="proc__hd">{%- if section.settings.eyebrow != blank -%}<p class="eyebrow" style="color: {{ section.settings.accent_color }}">{{ section.settings.eyebrow }}</p>{%- endif -%}<h2 class="sh" style="color: {{ section.settings.heading_color }}">{{ section.settings.heading }}</h2>{%- if section.settings.text != blank -%}<p class="sd" style="color: {{ section.settings.text_color }}">{{ section.settings.text }}</p>{%- endif -%}</div><div class="proc__cards">{%- assign proc_colors = "2C2825,3EB8A8,FD9963" | split: "," -%}{%- for block in section.blocks -%}{%- assign proc_color = proc_colors[forloop.index0] | default: "2C2825" -%}<div class="proc__card" {{ block.shopify_attributes }}><div class="proc__vid">{%- if block.settings.image != blank -%}<img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title | escape }}" width="400" height="620" loading="lazy">{%- else -%}<img src="https://placehold.co/400x620/{{ proc_color }}/FFF?text={{ block.settings.step | url_encode }}" alt="{{ block.settings.title | escape }}" width="400" height="620" loading="lazy">{%- endif -%}{%- assign video_url = block.settings.video_url | default: 'https://www.youtube.com/watch?v=dQw4w9WgXcQ' -%}<a href="{{ video_url }}" class="proc__play" target="_blank" rel="noopener" aria-label="Watch video"><svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg></a></div><div class="proc__info"><p class="proc__step">{{ block.settings.step }}</p><h3 class="proc__title">{{ block.settings.title }}</h3><p class="proc__desc">{{ block.settings.text }}</p></div></div>{%- endfor -%}</div></div></section>
{% schema %}{"name":"Sky Process Cards","settings":[{"type":"color","id":"bg_color","label":"Background Color","default":"#F2EBDF"},{"type":"color","id":"heading_color","label":"Heading Color","default":"#2C2825"},{"type":"color","id":"text_color","label":"Text Color","default":"#6B6560"},{"type":"color","id":"accent_color","label":"Accent Color","default":"#FD9963"},{"type":"text","id":"eyebrow","label":"Eyebrow Text","default":"From flat pack to finished piece"},{"type":"text","id":"heading","label":"Heading","default":"Easy to make. Hard to forget."},{"type":"textarea","id":"text","label":"Subtext","default":"Every kit comes with everything needed. No craft degree required."},{"type":"range","id":"padding_top","min":0,"max":100,"step":4,"unit":"px","label":"Padding Top","default":72},{"type":"range","id":"padding_bottom","min":0,"max":100,"step":4,"unit":"px","label":"Padding Bottom","default":72}],"blocks":[{"type":"step","name":"Process Step","settings":[{"type":"image_picker","id":"image","label":"Thumbnail Image"},{"type":"url","id":"video_url","label":"Video URL (YouTube / Vimeo)"},{"type":"text","id":"step","label":"Step Label","default":"Step 01"},{"type":"text","id":"title","label":"Title","default":"Open the kit"},{"type":"textarea","id":"text","label":"Description","default":"Pre-cut, pre-scored, colour-coded pieces ready to go."}]}],"presets":[{"name":"Sky Process Cards","blocks":[{"type":"step","settings":{"step":"Step 01","title":"Open the kit","text":"Pre-cut, pre-scored, colour-coded pieces ready to go.","video_url":"https://www.youtube.com/watch?v=dQw4w9WgXcQ"}},{"type":"step","settings":{"step":"Step 02","title":"Follow along","text":"Scan the QR code for a step-by-step video tutorial.","video_url":"https://www.youtube.com/watch?v=dQw4w9WgXcQ"}},{"type":"step","settings":{"step":"Step 03","title":"Show it off","text":"Display it, gift it, or keep it — it'll look gorgeous.","video_url":"https://www.youtube.com/watch?v=dQw4w9WgXcQ"}}]}]}{% endschema %}
