<section class="proc rv" style="background: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="proc__inner">
    <div class="proc__hd">
      <p class="eyebrow" style="color: {{ section.settings.accent_color }}">{{ section.settings.eyebrow }}</p>
      <h2 class="sh" style="color: {{ section.settings.heading_color }}">{{ section.settings.heading }}</h2>
      <p class="sd" style="color: {{ section.settings.text_color }}">{{ section.settings.text }}</p>
    </div>
    <div class="proc__cards">
      {%- for block in section.blocks -%}
        <div class="proc__card rv" {{ block.shopify_attributes }}>
          <div class="proc__vid">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title | escape }}">
            {%- else -%}
               {{ 'product-3' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            {%- if block.settings.video_url != blank -%}
              <a href="{{ block.settings.video_url }}" class="proc__play" target="_blank">
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </a>
            {%- else -%}
              <div class="proc__play">
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </div>
            {%- endif -%}
          </div>
          <div class="proc__info">
            <p class="proc__step">{{ block.settings.step }}</p>
            <h3 class="proc__title">{{ block.settings.title }}</h3>
            <p class="proc__desc">{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sky Process Cards",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F2EBDF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#2C2825"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#6B6560"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#FD9963"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "From flat pack to finished piece"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Easy to make. Hard to forget."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Every kit comes with everything needed. No craft degree required."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Process Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Thumbnail Image"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL"
        },
        {
          "type": "text",
          "id": "step",
          "label": "Step Label",
          "default": "Step 01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Open the kit"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Pre-cut, pre-scored, colour-coded pieces ready to go."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sky Process Cards",
      "blocks": [
        { "type": "step", "settings": { "step": "Step 01", "title": "Open the kit" } },
        { "type": "step", "settings": { "step": "Step 02", "title": "Follow along" } },
        { "type": "step", "settings": { "step": "Step 03", "title": "Show it off" } }
      ]
    }
  ]
}
{% endschema %}
