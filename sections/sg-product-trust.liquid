{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

<style>
  .sg-prod-trust {
    border-top: 1px solid var(--sg-border);
    border-bottom: 1px solid var(--sg-border);
    background: var(--sg-warm-white);
  }
  .sg-prod-trust__inner {
    max-width: var(--sg-max-w);
    margin: 0 auto;
    padding: 20px var(--sg-gutter);
    display: flex;
    align-items: center;
    gap: 12px;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .sg-prod-trust__inner::-webkit-scrollbar { display: none; }
  .sg-prod-trust__item {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    flex: 1;
    min-width: 0;
    padding: 12px 16px;
    border-radius: var(--sg-radius);
    background: #fff;
    border: 1px solid var(--sg-border);
  }
  .sg-prod-trust__icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--sg-peach);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .sg-prod-trust__icon svg {
    width: 18px;
    height: 18px;
    stroke: var(--sg-orange);
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .sg-prod-trust__title {
    font-size: 13px;
    font-weight: 600;
    color: var(--sg-dark);
    line-height: 1.3;
    white-space: nowrap;
  }
  .sg-prod-trust__desc {
    font-size: 11.5px;
    color: var(--sg-muted);
    line-height: 1.4;
    white-space: nowrap;
  }
  @media (max-width: 749px) {
    .sg-prod-trust__inner {
      gap: 10px;
      padding: 16px var(--sg-gutter);
    }
    .sg-prod-trust__item {
      padding: 10px 14px;
      min-width: 200px;
    }
  }
  @media (min-width: 750px) {
    .sg-prod-trust__inner {
      justify-content: center;
      overflow: visible;
    }
  }
</style>

<section class="sg-section sg-prod-trust" {{ section.shopify_attributes }}>
  <div class="sg-prod-trust__inner">
    {%- for block in section.blocks -%}
      <div class="sg-prod-trust__item" {{ block.shopify_attributes }}>
        <div class="sg-prod-trust__icon">
          {%- case block.settings.icon -%}
            {%- when 'truck' -%}
              <svg viewBox="0 0 24 24"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 4v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {%- when 'shield' -%}
              <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {%- when 'leaf' -%}
              <svg viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3.75 1.75 3.75"/></svg>
            {%- when 'return' -%}
              <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            {%- when 'clock' -%}
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {%- when 'heart' -%}
              <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            {%- when 'star' -%}
              <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- when 'check' -%}
              <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          {%- endcase -%}
        </div>
        <div>
          <div class="sg-prod-trust__title">{{ block.settings.title }}</div>
          {%- if block.settings.description != blank -%}
            <div class="sg-prod-trust__desc">{{ block.settings.description }}</div>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "SG - Product Trust",
  "tag": "section",
  "class": "sg-product-trust-section",
  "settings": [],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (Shipping)" },
            { "value": "shield", "label": "Shield (Security)" },
            { "value": "leaf", "label": "Leaf (Eco)" },
            { "value": "return", "label": "Return Arrow" },
            { "value": "clock", "label": "Clock (Time)" },
            { "value": "heart", "label": "Heart" },
            { "value": "star", "label": "Star" },
            { "value": "check", "label": "Checkmark" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "On orders over Rs.1000"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG - Product Trust",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "icon": "truck",
            "title": "Free Shipping",
            "description": "On orders over Rs.1000"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "return",
            "title": "Easy Returns",
            "description": "7-day return policy"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "leaf",
            "title": "100% Eco-friendly",
            "description": "Sustainable materials"
          }
        }
      ]
    }
  ]
}
{% endschema %}
