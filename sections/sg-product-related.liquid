{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

<style>
  .sg-prod-related {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }
  @media (min-width: 750px) {
    .sg-prod-related {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>

{%- if section.settings.collection != blank -%}
  {%- assign related_products = section.settings.collection.products -%}
{%- else -%}
  {%- assign related_products = recommendations.products -%}
{%- endif -%}

{%- if related_products.size > 0 -%}
<section class="sg-section sg-featured sg-prod-related" style="background: {{ section.settings.bg_color }};" {{ section.shopify_attributes }}>
  <div class="sg-featured__head">
    <div>
      {%- if section.settings.heading != blank -%}
        <h2 class="sg-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="sg-subtext">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
    {%- if section.settings.collection != blank -%}
      <a href="{{ section.settings.collection.url }}" class="sg-view-all">
        View all
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    {%- endif -%}
  </div>

  <div class="sg-products-scroll">
    {%- for product in related_products limit: section.settings.products_to_show -%}
      {%- render 'sg-product-card', product: product -%}
    {%- endfor -%}
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "SG - Related Products",
  "tag": "section",
  "class": "sg-product-related-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "More craft kits you'll love"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Leave empty to use Shopify's automatic product recommendations."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Products to show"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FAF6F0"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "SG - Related Products",
      "settings": {
        "heading": "You May Also Like",
        "subheading": "More craft kits you'll love"
      }
    }
  ]
}
{% endschema %}
