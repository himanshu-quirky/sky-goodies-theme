{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- assign collection = section.settings.collection -%}

{%- style -%}
  .sg-fp-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#F5EFE3' }};
    padding: {{ section.settings.mobile_padding_top | default: 48 }}px 0 {{ section.settings.mobile_padding_bottom | default: 48 }}px;
  }
  @media (min-width: 900px) {
    .sg-fp-{{ section.id }} {
      padding: {{ section.settings.desktop_padding_top | default: 72 }}px 0 {{ section.settings.desktop_padding_bottom | default: 72 }}px;
    }
  }
{%- endstyle -%}

<section class="sg-root sg-fp-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-sec-head">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">— {{ section.settings.eyebrow }} —</span>
      {%- endif -%}
      <h2>{{ section.settings.heading_plain }} <em>{{ section.settings.heading_em }}</em></h2>
    </div>
    {%- if section.settings.layout == 'grid' -%}
      <div class="sg-nav-btns">
        <button aria-label="Previous"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg></button>
        <button aria-label="Next"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></button>
      </div>
    {%- else -%}
      {%- if section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="sg-view-all">{{ section.settings.view_all_text | default: 'View all' }} →</a>
      {%- endif -%}
    {%- endif -%}
  </div>

  {%- if section.settings.layout == 'grid' -%}
    <div class="sg-fp-grid">
  {%- else -%}
    <div class="sg-fp-scroll">
  {%- endif -%}

  {%- if collection.products.size > 0 -%}
    {%- for product in collection.products limit: section.settings.products_to_show -%}
      {%- assign savings_paise = 0 -%}
      {%- if product.compare_at_price > product.price -%}
        {%- assign savings_paise = product.compare_at_price | minus: product.price -%}
      {%- endif -%}
      <article class="sg-prod-card">
        <a href="{{ product.url }}" class="sg-prod-img">
          <div class="sg-prod-badges">
            {%- if product.tags contains 'bestseller' or product.tags contains 'Bestseller' -%}<span class="sg-prod-badge best">★ Bestseller</span>{%- endif -%}
            {%- if savings_paise > 0 -%}<span class="sg-prod-badge save">Save ₹{{ savings_paise | money_without_currency | remove: '.00' | remove: ',' }}</span>{%- endif -%}
            {%- if product.tags contains 'new' or product.tags contains 'New' -%}<span class="sg-prod-badge new">Just In</span>{%- endif -%}
          </div>
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 720 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy" width="720" height="720"/>
          {%- endif -%}
        </a>
        <h3 class="sg-prod-title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
        <div class="sg-prod-price-row">
          <span class="sg-prod-price">₹{{ product.price | money_without_currency | remove: '.00' | remove: ',' }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="sg-prod-mrp">₹{{ product.compare_at_price | money_without_currency | remove: '.00' | remove: ',' }}</span>
            {%- assign pct = savings_paise | times: 100 | divided_by: product.compare_at_price -%}
            <span class="sg-prod-off">-{{ pct }}%</span>
          {%- endif -%}
        </div>
        {%- if product.available -%}
          <button type="button"
                  class="sg-prod-atc"
                  data-sg-atc
                  data-variant-id="{{ product.selected_or_first_available_variant.id }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
            Add to Cart
          </button>
        {%- else -%}
          <button class="sg-prod-atc sg-prod-atc--soldout" disabled>Sold Out</button>
        {%- endif -%}
      </article>
    {%- endfor -%}
  {%- else -%}
    {%- for i in (1..section.settings.products_to_show) -%}
      <article class="sg-prod-card">
        <div class="sg-prod-img"></div>
        <h3 class="sg-prod-title">Example product {{ forloop.index }}</h3>
        <div class="sg-prod-price-row"><span class="sg-prod-price">₹999</span></div>
        <button class="sg-prod-atc" disabled>Connect a collection</button>
      </article>
    {%- endfor -%}
  {%- endif -%}

  </div>

  {%- if section.settings.layout == 'grid' and section.settings.show_view_all_button -%}
    <div class="sg-fp-view-all">
      <a href="{{ section.settings.view_all_link | default: '#' }}" class="sg-btn-primary">
        {{ section.settings.view_all_text | default: 'Shop All' }}
        <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  {%- endif -%}
</section>

<style>
.sg-fp-scroll {
  display: flex;
  gap: 14px;
  overflow-x: auto;
  scrollbar-width: none;
  padding: 4px 16px 12px;
  scroll-snap-type: x mandatory;
}
.sg-fp-scroll::-webkit-scrollbar { display: none; }
@media (min-width: 700px) {
  .sg-fp-scroll {
    gap: 22px;
    max-width: var(--sg-container, 1280px);
    margin: 0 auto;
    padding: 4px var(--sg-gutter, 28px) 12px;
  }
}
.sg-fp-scroll .sg-prod-card {
  flex: 0 0 78%;
  max-width: 320px;
  scroll-snap-align: start;
}
@media (min-width: 700px) { .sg-fp-scroll .sg-prod-card { flex: 0 0 32%; } }
@media (min-width: 1100px) { .sg-fp-scroll .sg-prod-card { flex: 0 0 23%; } }

.sg-fp-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px 12px;
  max-width: var(--sg-container, 1280px);
  margin: 0 auto;
  padding: 0 16px;
}
@media (min-width: 700px) { .sg-fp-grid { grid-template-columns: repeat(3, 1fr); gap: 32px 20px; padding: 0 var(--sg-gutter, 28px); } }
@media (min-width: 1100px) { .sg-fp-grid { grid-template-columns: repeat(4, 1fr); gap: 40px 28px; } }

.sg-fp-view-all {
  text-align: center;
  margin-top: 40px;
  max-width: var(--sg-container, 1280px);
  margin-left: auto;
  margin-right: auto;
  padding: 0 var(--sg-gutter, 28px);
}

.sg-prod-img { display: block; position: relative; aspect-ratio: 1/1; background: #f5efe3; overflow: hidden; border-radius: 12px; }
.sg-prod-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .35s; }
.sg-prod-card:hover .sg-prod-img img { transform: scale(1.04); }
.sg-prod-badges { position: absolute; top: 10px; left: 10px; display: flex; flex-direction: column; gap: 6px; z-index: 2; }
.sg-prod-badge { font-size: 10px; padding: 4px 10px; border-radius: 100px; font-weight: 600; letter-spacing: .04em; background: #4A3D2F; color: #fff; }
.sg-prod-badge.save { background: #E8845A; }
.sg-prod-badge.new { background: #F0D288; color: #4A3D2F; }

.sg-prod-atc {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  width: 100%;
  margin-top: 14px;
  padding: 12px 18px;
  background: #E8845A;
  color: #fff;
  border: 1px solid #E8845A;
  border-radius: 100px;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: .04em;
  font-family: inherit;
  cursor: pointer;
  transition: background .2s, border-color .2s, transform .15s;
}
.sg-prod-atc:hover {
  background: #D26939;
  border-color: #D26939;
  color: #fff;
  transform: translateY(-1px);
}
.sg-prod-atc:disabled, .sg-prod-atc--soldout {
  background: transparent;
  color: #b0a89c;
  border: 1px solid #d6cfc3;
  cursor: not-allowed;
  transform: none;
}
.sg-prod-atc:disabled:hover, .sg-prod-atc--soldout:hover {
  background: transparent;
  color: #b0a89c;
  transform: none;
}
.sg-prod-atc svg { width: 16px; height: 16px; }

.sg-prod-title { font-size: 14.5px; font-weight: 600; color: #4A3D2F; margin-top: 12px; margin-bottom: 6px; line-height: 1.3; }
.sg-prod-title a { color: inherit; text-decoration: none; }
.sg-prod-price-row { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
.sg-prod-price { font-size: 16.5px; font-weight: 700; color: #4A3D2F; }
.sg-prod-mrp { font-size: 12.5px; text-decoration: line-through; color: #b0a89c; }
.sg-prod-off { font-size: 11px; color: #E8845A; font-weight: 700; }
</style>


{% schema %}
{
  "name": "SG — Featured Products",
  "tag": "section",
  "class": "section-sg-featured-products",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "2026 is already here" },
    { "type": "text", "id": "heading_plain", "label": "Heading (plain word)", "default": "The" },
    { "type": "text", "id": "heading_em", "label": "Heading (italic accent)", "default": "Calendar Shop" },
    { "type": "collection", "id": "collection", "label": "Source collection" },
    { "type": "range", "id": "products_to_show", "label": "Number of products", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "layout", "label": "Layout", "options": [
      { "value": "scroll", "label": "Horizontal scroller (for secondary strips)" },
      { "value": "grid", "label": "4-column grid (for bestsellers)" }
    ], "default": "scroll" },
    { "type": "text", "id": "view_all_text", "label": "View-all text", "default": "Shop all" },
    { "type": "url", "id": "view_all_link", "label": "View-all link" },
    { "type": "checkbox", "id": "show_view_all_button", "label": "Show View-all as big button (grid layout only)", "default": false },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F5EFE3" },
    { "type": "range", "id": "mobile_padding_top", "label": "Mobile padding top", "min": 20, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Mobile padding bottom", "min": 20, "max": 120, "step": 4, "default": 48 },
    { "type": "range", "id": "desktop_padding_top", "label": "Desktop padding top", "min": 20, "max": 200, "step": 4, "default": 72 },
    { "type": "range", "id": "desktop_padding_bottom", "label": "Desktop padding bottom", "min": 20, "max": 200, "step": 4, "default": 72 }
  ],
  "presets": [
    { "name": "SG — Featured Products" }
  ]
}
{% endschema %}
