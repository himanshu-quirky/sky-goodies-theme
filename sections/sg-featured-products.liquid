{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- assign collection = collections[section.settings.collection] -%}
{%- assign bg_palette = 'bg-butter,bg-sage,bg-peach,bg-sky,bg-terra,bg-pink' | split: ',' -%}

{%- style -%}
  .sg-fp-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top | default: 64 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 64 }}px;
  }
  @media (min-width: 768px) {
    .sg-fp-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop | default: 100 }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop | default: 100 }}px;
    }
  }
{%- endstyle -%}

<section class="sg-root sg-fp-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-wrap">
    <div class="sg-section-head">
      {%- if section.settings.eyebrow != blank -%}
        <span class="sg-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2>{{ section.settings.heading | default: 'Bestsellers' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="sub">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="sg-fp-tabs">
          {%- for block in section.blocks -%}
            <button class="sg-pill{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.label }}</button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="sg-prod-grid">
      {%- if collection.products.size > 0 -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          {%- assign bg_index = forloop.index0 | modulo: 6 -%}
          {%- assign bg_class = bg_palette[bg_index] -%}
          {%- assign savings = 0 -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
          {%- endif -%}
          <article class="sg-prod {{ bg_class }}">
            <a href="{{ product.url }}" class="sg-prod-image-link">
              <div class="sg-prod-image">
                <span class="sg-rating-chip">{% if product.metafields.reviews.rating.value %}{{ product.metafields.reviews.rating.value | round: 1 }}{% else %}4.9{% endif %}</span>
                {%- if forloop.first -%}
                  <span class="sg-bs-chip">Best Seller</span>
                {%- elsif product.tags contains 'new' -%}
                  <span class="sg-bs-chip sg-bs-chip--new">Just In</span>
                {%- elsif product.inventory_quantity < 10 and product.inventory_quantity > 0 -%}
                  <span class="sg-bs-chip sg-bs-chip--low">Low Stock</span>
                {%- endif -%}
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 640 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="640" height="640"/>
                {%- endif -%}
              </div>
            </a>
            <h3 class="sg-prod-title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
            {%- if product.description != blank -%}
              <p class="sg-prod-desc">{{ product.description | strip_html | truncate: 80 }}</p>
            {%- endif -%}
            <div class="sg-prod-price-row">
              <span class="sg-prod-price">₹{{ product.price | money_without_currency | remove: '.00' | remove: ',' }}</span>
              {%- if product.compare_at_price > product.price -%}
                <span class="sg-prod-mrp">₹{{ product.compare_at_price | money_without_currency | remove: '.00' | remove: ',' }}</span>
                <span class="sg-prod-disc">{{ savings }}% off</span>
              {%- endif -%}
            </div>
            <button class="sg-prod-atc"
                    data-sg-atc
                    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                    {% if product.available == false %}disabled{% endif %}>
              {% if product.available %}Add to Cart{% else %}Sold Out{% endif %}
            </button>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          {%- assign bg_index = forloop.index0 | modulo: 6 -%}
          {%- assign bg_class = bg_palette[bg_index] -%}
          <article class="sg-prod {{ bg_class }}">
            <div class="sg-prod-image">
              <span class="sg-rating-chip">4.9</span>
              <span class="sg-bs-chip">Best Seller</span>
            </div>
            <h3 class="sg-prod-title">Example product {{ i }}</h3>
            <p class="sg-prod-desc">Select a collection in the theme editor to show real products here.</p>
            <div class="sg-prod-price-row"><span class="sg-prod-price">₹999</span></div>
            <button class="sg-prod-atc" data-sg-atc>Add to Cart</button>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.view_all_link != blank -%}
      <div style="text-align:center; margin-top: 40px;">
        <a href="{{ section.settings.view_all_link }}" class="sg-pill sg-pill--ghost sg-pill--lg">{{ section.settings.view_all_text | default: 'View all →' }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
.sg-fp-tabs { display: inline-flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
.sg-prod-image-link { display: block; text-decoration: none; }
.sg-prod-title a { color: inherit; text-decoration: none; }
</style>

{% schema %}
{
  "name": "SG — Featured Products",
  "tag": "section",
  "class": "section-sg-featured-products",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Simple Joys, Sorted" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "For grown-ups who miss making things." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Number of products", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "text", "id": "view_all_text", "label": "View all button text", "default": "View All 200+ Kits →" },
    { "type": "url", "id": "view_all_link", "label": "View all button link" },
    { "type": "header", "content": "Style" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#FAF6F0" },
    { "type": "range", "id": "padding_top", "label": "Padding top (mobile)", "min": 20, "max": 120, "step": 4, "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (mobile)", "min": 20, "max": 120, "step": 4, "default": 64 },
    { "type": "range", "id": "padding_top_desktop", "label": "Padding top (desktop)", "min": 20, "max": 200, "step": 4, "default": 100 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Padding bottom (desktop)", "min": 20, "max": 200, "step": 4, "default": 100 }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Filter tab",
      "settings": [
        { "type": "text", "id": "label", "label": "Tab label", "default": "Bestsellers" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Featured Products",
      "settings": { "heading": "Simple Joys, Sorted", "subheading": "For grown-ups who miss making things.", "products_to_show": 4 },
      "blocks": [
        { "type": "tab", "settings": { "label": "Bestsellers" } },
        { "type": "tab", "settings": { "label": "New Arrivals" } },
        { "type": "tab", "settings": { "label": "Low Stock" } }
      ]
    }
  ]
}
{% endschema %}
