<section class="feat" style="background: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="feat__inner">
    <div class="feat__top">
      <div>
        <p class="eyebrow" style="color: {{ section.settings.accent_color }}">{{ section.settings.eyebrow }}</p>
        <h2 class="sh" style="color: {{ section.settings.heading_color }}">{{ section.settings.heading }}</h2>
        <p class="sd" style="color: {{ section.settings.text_color }}">{{ section.settings.text }}</p>
      </div>
      {%- if section.settings.button_link != blank -%}
        <a href="{{ section.settings.button_link }}" class="feat__top-link" style="color: {{ section.settings.accent_color }}">
          {{ section.settings.button_text }} 
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      {%- endif -%}
    </div>
    <div class="feat__layout">
      <div class="feat__static">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.image_heading | escape }}">
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        <div class="feat__static-overlay">
          <h3>{{ section.settings.image_heading }}</h3>
          <p>{{ section.settings.image_text }}</p>
        </div>
      </div>
      <div class="feat__carousel">
        <div class="feat__track">
          {%- assign collection = section.settings.collection -%}
          {%- if collection != blank and collection.products_count > 0 -%}
            {%- for product in collection.products limit: section.settings.products_to_show -%}
              {%- render 'skygoodies-product-card', product: product -%}
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..4) -%}
              {%- render 'skygoodies-product-card' -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sky Featured Collection",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F2EBDF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#2C2825"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#6B6560"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#FD9963"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What brings everyone here"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pick a kind of joy"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Rainy afternoon craft sessions, birthday prep, or a gift."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Promotional Image"
    },
    {
      "type": "text",
      "id": "image_heading",
      "label": "Promotional Image Heading",
      "default": "Busy hands, bright minds"
    },
    {
      "type": "textarea",
      "id": "image_text",
      "label": "Promotional Image Text",
      "default": "40+ activity kits for ages 4 to 12. Rainy day? Sorted."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Maximum products to show"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Sky Featured Collection"
    }
  ]
}
{% endschema %}
