{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-vid-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#F5EFE3' }};
    padding: {{ section.settings.mobile_padding | default: 64 }}px 0;
  }
  @media (min-width: 900px) {
    .sg-vid-{{ section.id }} {
      padding: {{ section.settings.desktop_padding | default: 96 }}px 0;
    }
  }
{%- endstyle -%}

<section class="sg-root sg-vid-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-sec-head">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">— {{ section.settings.eyebrow }} —</span>
      {%- endif -%}
      <h2>{{ section.settings.heading_plain }} <em>{{ section.settings.heading_em }}</em></h2>
    </div>
    <div class="sg-nav-btns">
      <button aria-label="Previous"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg></button>
      <button aria-label="Next"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></button>
    </div>
  </div>

  <div class="sg-vid-scroll">
    {%- for block in section.blocks -%}
      {%- assign product = block.settings.product -%}
      {%- assign video_file = block.settings.video_file -%}
      {%- assign poster_url = '' -%}
      {%- if block.settings.thumbnail -%}
        {%- assign poster_url = block.settings.thumbnail | image_url: width: 600 -%}
      {%- elsif product.featured_image -%}
        {%- assign poster_url = product.featured_image | image_url: width: 600 -%}
      {%- endif -%}
      {%- assign has_video_file = false -%}
      {%- if video_file != blank and video_file.sources.size > 0 -%}{%- assign has_video_file = true -%}{%- endif -%}
      {%- assign has_video_url = false -%}
      {%- if block.settings.video_url != blank -%}
        {%- assign url_lower = block.settings.video_url | downcase -%}
        {%- if url_lower contains '.mp4' or url_lower contains '.webm' or url_lower contains '.mov' -%}
          {%- assign has_video_url = true -%}
        {%- endif -%}
      {%- endif -%}
      {%- assign card_link = '' -%}
      {%- if product != blank -%}
        {%- assign card_link = product.url -%}
      {%- elsif block.settings.product_url != blank -%}
        {%- assign card_link = block.settings.product_url -%}
      {%- endif -%}
      <{% if card_link != '' %}a href="{{ card_link }}"{% else %}div{% endif %} class="sg-vid-card{% if has_video_file or has_video_url %} sg-vid-card--has-video{% endif %}"
           {% if poster_url != '' %}style="background-image: url('{{ poster_url }}');"{% endif %}
           {{ block.shopify_attributes }}>
        {%- if has_video_file -%}
          <video class="sg-vid-media" autoplay muted loop playsinline preload="auto"
                 {% if poster_url != '' %}poster="{{ poster_url }}"{% endif %}>
            {%- for source in video_file.sources -%}
              <source src="{{ source.url }}"{% if source.mime_type %} type="{{ source.mime_type }}"{% endif %}>
            {%- endfor -%}
          </video>
        {%- elsif has_video_url -%}
          <video class="sg-vid-media" autoplay muted loop playsinline preload="auto"
                 {% if poster_url != '' %}poster="{{ poster_url }}"{% endif %}>
            <source src="{{ block.settings.video_url }}">
          </video>
        {%- endif -%}
        {%- if block.settings.likes != blank -%}
          <div class="sg-vid-likes">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>{{ block.settings.likes }}
          </div>
        {%- endif -%}
        <div class="sg-vid-info">
          {%- if product != blank -%}
            <div class="sg-vid-prod">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 80 }}" alt="{{ product.title | escape }}"/>
              {%- endif -%}
              <span>{{ product.title | truncate: 20 }}</span>
              <span class="p">₹{{ product.price | money_without_currency | remove: '.00' | remove: ',' }}</span>
            </div>
          {%- elsif block.settings.product_label != blank -%}
            <div class="sg-vid-prod">
              {%- if block.settings.thumbnail -%}
                <img src="{{ block.settings.thumbnail | image_url: width: 80 }}" alt=""/>
              {%- endif -%}
              <span>{{ block.settings.product_label }}</span>
              {%- if block.settings.product_price != blank -%}<span class="p">{{ block.settings.product_price }}</span>{%- endif -%}
            </div>
          {%- endif -%}
          {%- if block.settings.caption != blank -%}
            <div class="sg-vid-title">{{ block.settings.caption }}</div>
          {%- endif -%}
        </div>
      </{% if card_link != '' %}a{% else %}div{% endif %}>
    {%- endfor -%}
  </div>
</section>

<style>
.sg-vid-scroll {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  scrollbar-width: none;
  padding: 4px var(--sg-gutter) 12px;
  max-width: var(--sg-container);
  margin: 0 auto;
  scroll-snap-type: x mandatory;
}
.sg-vid-scroll::-webkit-scrollbar { display: none; }
@media (min-width: 700px) { .sg-vid-scroll { gap: 18px; } }
.sg-vid-card {
  flex: 0 0 62%;
  max-width: 260px;
  scroll-snap-align: start;
  position: relative;
  aspect-ratio: 9/16;
  border-radius: var(--sg-r-md);
  overflow: hidden;
  background-size: cover;
  background-position: center;
  background-color: var(--sg-paper-2);
  cursor: pointer;
  transition: transform .2s;
  text-decoration: none;
  color: inherit;
  display: block;
}
a.sg-vid-card { color: inherit; }
@media (min-width: 700px) { .sg-vid-card { flex: 0 0 28%; } }
@media (min-width: 1100px) { .sg-vid-card { flex: 0 0 19%; } }
.sg-vid-card:hover { transform: translateY(-3px); }
.sg-vid-media {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  z-index: 1;
}
.sg-vid-card::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(26,22,20,.15) 0%, transparent 35%, transparent 55%, rgba(26,22,20,.75) 100%);
  z-index: 2;
  pointer-events: none;
}
.sg-vid-card > *:not(.sg-vid-media) { position: relative; z-index: 3; }
.sg-vid-info {
  position: absolute;
  bottom: 12px; left: 12px; right: 12px;
  color: #fff;
}
.sg-vid-prod {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,253,248,.95);
  color: var(--sg-ink);
  padding: 6px 10px 6px 6px;
  border-radius: var(--sg-r-pill);
  font-size: 11.5px;
  font-weight: 600;
  backdrop-filter: blur(6px);
  margin-bottom: 10px;
  max-width: 100%;
  text-decoration: none;
}
.sg-vid-prod img {
  width: 28px; height: 28px;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
}
.sg-vid-prod .p {
  color: var(--sg-orange-dk);
  font-weight: 700;
  font-size: 11px;
  margin-left: auto;
}
.sg-vid-title {
  font-size: 13px;
  font-weight: 500;
  line-height: 1.25;
  color: #fff;
}
.sg-vid-likes {
  position: absolute;
  top: 12px; right: 12px;
  font-size: 11px;
  color: #fff;
  background: rgba(26,22,20,.5);
  padding: 4px 10px;
  border-radius: var(--sg-r-pill);
  backdrop-filter: blur(6px);
  display: flex; align-items: center; gap: 4px;
  z-index: 3;
}
.sg-vid-likes svg { width: 12px; height: 12px; }
</style>

<script>
(function() {
  if (window.__sgVidAutoplayInit) return;
  window.__sgVidAutoplayInit = true;
  function tryPlay() {
    document.querySelectorAll('.sg-vid-media').forEach(function(v) {
      v.muted = true;
      v.setAttribute('muted', '');
      v.setAttribute('playsinline', '');
      var p = v.play();
      if (p && p.catch) p.catch(function(){});
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', tryPlay);
  } else {
    tryPlay();
  }
  // Retry on first user interaction (mobile fallback)
  ['click','touchstart','scroll'].forEach(function(evt) {
    window.addEventListener(evt, tryPlay, { once: true, passive: true });
  });
})();
</script>

{% schema %}
{
  "name": "SG — Shoppable Videos",
  "tag": "section",
  "class": "section-sg-shoppable-video",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Watch & shop" },
    { "type": "text", "id": "heading_plain", "label": "Heading (plain)", "default": "See them" },
    { "type": "text", "id": "heading_em", "label": "Heading (italic accent)", "default": "in action" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F5EFE3" },
    { "type": "range", "id": "mobile_padding", "label": "Mobile padding (px)", "min": 20, "max": 120, "step": 4, "default": 64 },
    { "type": "range", "id": "desktop_padding", "label": "Desktop padding (px)", "min": 20, "max": 200, "step": 4, "default": 96 }
  ],
  "max_blocks": 10,
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        { "type": "image_picker", "id": "thumbnail", "label": "Poster image (9:16 recommended)" },
        { "type": "video", "id": "video_file", "label": "Video file (Shopify upload — autoplays)" },
        { "type": "url", "id": "video_url", "label": "Or paste a direct .mp4 / .webm URL (autoplays). YouTube/Vimeo links are NOT supported here." },
        { "type": "product", "id": "product", "label": "Tagged product (entire card links to it)" },
        { "type": "url", "id": "product_url", "label": "Or paste a custom link (used if no product selected)" },
        { "type": "text", "id": "product_label", "label": "Product label (if no product picked)" },
        { "type": "text", "id": "product_price", "label": "Product price override" },
        { "type": "text", "id": "likes", "label": "Like count label", "default": "1.2K" },
        { "type": "text", "id": "caption", "label": "Caption / title", "default": "Unboxing the kit" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Shoppable Videos",
      "blocks": [
        { "type": "video", "settings": { "caption": "Unboxing the kit", "likes": "2.1K" } },
        { "type": "video", "settings": { "caption": "A balcony makeover in 10 min", "likes": "1.4K" } },
        { "type": "video", "settings": { "caption": "Eco-Ganesha · assembly film", "likes": "3.2K" } },
        { "type": "video", "settings": { "caption": "Setting up a party", "likes": "892" } },
        { "type": "video", "settings": { "caption": "From flat paper to tabletop", "likes": "1.9K" } }
      ]
    }
  ]
}
{% endschema %}
