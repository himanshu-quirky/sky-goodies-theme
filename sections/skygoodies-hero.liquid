{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="hero section-{{ section.id }}-padding" id="heroSlider-{{ section.id }}" style="background: {{ section.settings.bg_color }};">
  <div class="hero__slides" id="heroTrack-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="hero__slide" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 2000 }}" alt="{{ block.settings.image.alt | default: 'Slide image' | escape }}" style="object-position: {{ block.settings.image_position }};" width="2000" height="800" loading="lazy">
        {%- else -%}
          <img src="https://placehold.co/1600x600/F2EBDF/FD9963?text=Hero+Slide" alt="Hero slide {{ forloop.index }}" width="1600" height="600" loading="lazy">
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="hero__arrows">
      <button class="hero__arr" id="heroPrev-{{ section.id }}" aria-label="Previous slide"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg></button>
      <button class="hero__arr" id="heroNext-{{ section.id }}" aria-label="Next slide"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 6 15 12 9 18"/></svg></button>
    </div>
    <div class="hero__dots" id="heroDots-{{ section.id }}">
      {%- for block in section.blocks -%}
        <button class="hero__dot {% if forloop.first %}active{% endif %}" aria-label="Go to slide {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{%- if section.blocks.size > 1 -%}
<script>
document.addEventListener('DOMContentLoaded', function() {
  var track = document.getElementById('heroTrack-{{ section.id }}');
  if (!track) return;
  var dotsContainer = document.getElementById('heroDots-{{ section.id }}');
  var dots = dotsContainer ? dotsContainer.querySelectorAll('.hero__dot') : [];
  var ci = 0, total = {{ section.blocks.size }}, timer;
  function go(i) {
    ci = (i + total) % total;
    track.style.transform = 'translateX(-' + (ci * 100) + '%)';
    dots.forEach(function(d, j) { d.classList.toggle('active', j === ci); });
  }
  var nextBtn = document.getElementById('heroNext-{{ section.id }}');
  var prevBtn = document.getElementById('heroPrev-{{ section.id }}');
  if (nextBtn) nextBtn.addEventListener('click', function() { go(ci + 1); });
  if (prevBtn) prevBtn.addEventListener('click', function() { go(ci - 1); });
  dots.forEach(function(d, i) { d.addEventListener('click', function() { go(i); }); });
  {%- if section.settings.autoplay -%}
  timer = setInterval(function() { go(ci + 1); }, {{ section.settings.autoplay_speed }} * 1000);
  track.closest('.hero').addEventListener('mouseenter', function() { clearInterval(timer); });
  track.closest('.hero').addEventListener('mouseleave', function() {
    timer = setInterval(function() { go(ci + 1); }, {{ section.settings.autoplay_speed }} * 1000);
  });
  {%- endif -%}
});
</script>
{%- endif -%}

{% schema %}
{
  "name": "Sky Hero Slideshow",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#F2EBDF" },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay slideshow", "default": true },
    { "type": "range", "id": "autoplay_speed", "min": 3, "max": 10, "step": 1, "unit": "s", "label": "Autoplay speed", "default": 5 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 40, "step": 4, "unit": "px", "label": "Padding Top", "default": 0 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 40, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 0 }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Slide Image" },
        { "type": "select", "id": "image_position", "label": "Image Focus", "options": [{ "value": "center center", "label": "Center" }, { "value": "center top", "label": "Top" }, { "value": "center bottom", "label": "Bottom" }], "default": "center center" }
      ]
    }
  ],
  "presets": [{ "name": "Sky Hero Slideshow", "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }] }]
}
{% endschema %}
