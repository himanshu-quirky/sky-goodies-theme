{%- style -%}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px; }
  @media screen and (min-width: 750px) { .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } }
{%- endstyle -%}
<section class="insta section-{{ section.id }}-padding" style="background: {{ section.settings.bg_color }};"><div class="insta__hd">{%- if section.settings.eyebrow != blank -%}<p class="eyebrow" style="color: {{ section.settings.accent_color }}">{{ section.settings.eyebrow }}</p>{%- endif -%}<h2 class="sh" style="color: {{ section.settings.heading_color }}">{{ section.settings.heading }}</h2></div><div class="insta__grid">{%- assign insta_colors = "FD9963,3EB8A8,E86F5A,6BBF6A,5AAFE0,F6C84A" | split: "," -%}{%- for block in section.blocks -%}{%- assign insta_color = insta_colors[forloop.index0] | default: "FD9963" -%}<a href="{{ block.settings.link | default: '#' }}" class="insta__cell" {{ block.shopify_attributes }}>{%- if block.settings.image != blank -%}<img src="{{ block.settings.image | image_url: width: 400 }}" alt="Instagram post {{ forloop.index }}" width="400" height="400" loading="lazy">{%- else -%}<img src="https://placehold.co/400x400/{{ insta_color }}/FFF?text=📷" alt="Instagram {{ forloop.index }}" width="400" height="400" loading="lazy">{%- endif -%}<div class="insta__cell-ov"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></div></a>{%- endfor -%}</div></section>
{% schema %}{"name":"Sky Instafeed","settings":[{"type":"color","id":"bg_color","label":"Background Color","default":"#ffffff"},{"type":"color","id":"heading_color","label":"Heading Color","default":"#2C2825"},{"type":"color","id":"accent_color","label":"Accent Color","default":"#FD9963"},{"type":"text","id":"eyebrow","label":"Eyebrow Text","default":"@skygoodies"},{"type":"text","id":"heading","label":"Heading","default":"Made by real hands. Shared with pride."},{"type":"range","id":"padding_top","min":0,"max":100,"step":4,"unit":"px","label":"Padding Top","default":56},{"type":"range","id":"padding_bottom","min":0,"max":100,"step":4,"unit":"px","label":"Padding Bottom","default":0}],"blocks":[{"type":"image","name":"Instagram Image","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"url","id":"link","label":"Post Link"}]}],"presets":[{"name":"Sky Instafeed","blocks":[{"type":"image"},{"type":"image"},{"type":"image"},{"type":"image"},{"type":"image"},{"type":"image"}]}]}{% endschema %}
