<section class="gift rv" style="background: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="gift__inner">
    <div class="gift__hd">
      <p class="eyebrow" style="color: {{ section.settings.accent_color }}">{{ section.settings.eyebrow }}</p>
      <h2 class="sh" style="color: {{ section.settings.heading_color }}">{{ section.settings.heading }}</h2>
      <p class="sd" style="color: {{ section.settings.text_color }}">{{ section.settings.text }}</p>
    </div>
    <div class="gift__row">
      {%- for block in section.blocks -%}
        <div class="gift__card rv" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.heading | escape }}">
          {%- else -%}
             {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <div class="gift__card-ov">
            <h3>{{ block.settings.heading }}</h3>
            <p>{{ block.settings.text }}</p>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}">
                {{ block.settings.link_text }} 
                <svg class="icon" style="width:14px;height:14px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sky Gifting Grid",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#2C2825"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#6B6560"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#FD9963"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Made for giving"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Good gifts. Better reactions."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Whether it's a birthday return gift, a souvenir, or a corporate order."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Gift Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Kids' Gifts"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Colourful kits kids can actually make and keep."
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Browse kids' gifts"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sky Gifting Grid",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
