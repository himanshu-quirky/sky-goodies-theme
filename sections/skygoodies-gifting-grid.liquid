{%- style -%}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px; }
  @media screen and (min-width: 750px) { .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; } }
{%- endstyle -%}
<section class="gift section-{{ section.id }}-padding" style="background: {{ section.settings.bg_color }};"><div class="gift__inner"><div class="gift__hd">{%- if section.settings.eyebrow != blank -%}<p class="eyebrow" style="color: {{ section.settings.accent_color }}">{{ section.settings.eyebrow }}</p>{%- endif -%}<h2 class="sh" style="color: {{ section.settings.heading_color }}">{{ section.settings.heading }}</h2>{%- if section.settings.text != blank -%}<p class="sd" style="color: {{ section.settings.text_color }}">{{ section.settings.text }}</p>{%- endif -%}</div><div class="gift__row">{%- assign gift_colors = "FD9963,3EB8A8,E86F5A" | split: "," -%}{%- for block in section.blocks -%}{%- assign ph_color = gift_colors[forloop.index0] | default: "6B6560" -%}<div class="gift__card" {{ block.shopify_attributes }}>{%- if block.settings.image != blank -%}<img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.heading | escape }}" width="600" height="800" loading="lazy">{%- else -%}<img src="https://placehold.co/600x800/{{ ph_color }}/FFF?text=Gift" alt="{{ block.settings.heading | escape }}" width="600" height="800" loading="lazy">{%- endif -%}<div class="gift__card-ov"><h3>{{ block.settings.heading }}</h3><p>{{ block.settings.text }}</p>{%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{{ block.settings.link_text }}<svg style="width:14px;height:14px;display:inline-block;vertical-align:middle;margin-left:4px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg></a>{%- endif -%}</div></div>{%- endfor -%}</div></div></section>
{% schema %}{"name":"Sky Gifting Grid","settings":[{"type":"color","id":"bg_color","label":"Background Color","default":"#ffffff"},{"type":"color","id":"heading_color","label":"Heading Color","default":"#2C2825"},{"type":"color","id":"text_color","label":"Text Color","default":"#6B6560"},{"type":"color","id":"accent_color","label":"Accent Color","default":"#FD9963"},{"type":"text","id":"eyebrow","label":"Eyebrow Text","default":"Made for giving"},{"type":"text","id":"heading","label":"Heading","default":"Good gifts. Better reactions."},{"type":"textarea","id":"text","label":"Subtext","default":"Whether it's a birthday return gift, a souvenir, or a corporate order."},{"type":"range","id":"padding_top","min":0,"max":100,"step":4,"unit":"px","label":"Padding Top","default":72},{"type":"range","id":"padding_bottom","min":0,"max":100,"step":4,"unit":"px","label":"Padding Bottom","default":72}],"blocks":[{"type":"card","name":"Gift Card","settings":[{"type":"image_picker","id":"image","label":"Background Image"},{"type":"text","id":"heading","label":"Heading","default":"Kids' Gifts"},{"type":"textarea","id":"text","label":"Description","default":"Colourful kits kids can actually make and keep."},{"type":"text","id":"link_text","label":"Link Text","default":"Browse gifts"},{"type":"url","id":"link","label":"Link URL"}]}],"presets":[{"name":"Sky Gifting Grid","blocks":[{"type":"card","settings":{"heading":"Kids' Gifts & Return Gifts","text":"Colourful kits kids can actually make and keep.","link_text":"Browse kids' gifts"}},{"type":"card","settings":{"heading":"Bulk & Party Orders","text":"Return gifts for 20 or 200. We've got you covered.","link_text":"Enquire now"}},{"type":"card","settings":{"heading":"Corporate & Custom Gifts","text":"Thoughtful branded gifts that stand out.","link_text":"Get a quote"}}]}]}{% endschema %}
