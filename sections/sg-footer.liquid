{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-ft-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#4A3D2F' }};
    color: {{ section.settings.text_color | default: 'rgba(245,239,227,.78)' }};
    padding: {{ section.settings.padding_top | default: 64 }}px 0 {{ section.settings.padding_bottom | default: 28 }}px;
  }
  .sg-ft-{{ section.id }} .sg-ft-tag,
  .sg-ft-{{ section.id }} .sg-ft-col h5 {
    color: {{ section.settings.accent_color | default: '#F0D288' }};
  }
{%- endstyle -%}

<footer class="sg-root sg-ft-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-ft-in">
    <div class="sg-ft-top">
      <div class="sg-ft-brand">
        {%- if section.settings.logo -%}
          <img src="{{ section.settings.logo | image_url: width: 240 }}" alt="{{ shop.name | escape }}"/>
        {%- else -%}
          <h3 style="font-family: var(--sg-display); font-style: italic; color: var(--sg-butter); font-size: 32px; margin-bottom: 12px;">{{ shop.name }}</h3>
        {%- endif -%}
        {%- if section.settings.tagline != blank -%}
          <div class="sg-ft-tag">{{ section.settings.tagline }}</div>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p>{{ section.settings.description }}</p>
        {%- endif -%}
        <div class="sg-ft-socials">
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 2C4.243 2 2 4.243 2 7v10c0 2.757 2.243 5 5 5h10c2.757 0 5-2.243 5-5V7c0-2.757-2.243-5-5-5H7zm10 2c1.654 0 3 1.346 3 3v10c0 1.654-1.346 3-3 3H7c-1.654 0-3-1.346-3-3V7c0-1.654 1.346-3 3-3h10zm-5 3a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 2a3 3 0 1 1 0 6 3 3 0 0 1 0-6zm4.5-.5a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/></svg></a>
          {%- endif -%}
          {%- if section.settings.youtube_url != blank -%}
            <a href="{{ section.settings.youtube_url }}" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M21.58 7.2c-.2-1.1-1.1-2-2.2-2.2C17.4 4.5 12 4.5 12 4.5s-5.4 0-7.4.5c-1.1.2-2 1.1-2.2 2.2C2 9.2 2 12 2 12s0 2.8.4 4.8c.2 1.1 1.1 2 2.2 2.2 2 .5 7.4.5 7.4.5s5.4 0 7.4-.5c1.1-.2 2-1.1 2.2-2.2.4-2 .4-4.8.4-4.8s0-2.8-.4-4.8zM10 15.5V8.5l6 3.5-6 3.5z"/></svg></a>
          {%- endif -%}
          {%- if section.settings.pinterest_url != blank -%}
            <a href="{{ section.settings.pinterest_url }}" aria-label="Pinterest"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12c0 5 3.1 9.3 7.6 11.1-.1-.9-.2-2.4 0-3.4.2-.9 1.4-5.6 1.4-5.6s-.4-.7-.4-1.8c0-1.7 1-2.9 2.2-2.9 1 0 1.5.8 1.5 1.7 0 1-.7 2.6-1 4-.3 1.2.6 2.1 1.8 2.1 2.1 0 3.7-2.2 3.7-5.4 0-2.8-2-4.8-4.9-4.8-3.4 0-5.3 2.5-5.3 5.1 0 1 .4 2.1.9 2.7.1.1.1.2.1.3-.1.4-.3 1.2-.3 1.4 0 .2-.2.3-.4.2-1.3-.6-2.2-2.6-2.2-4.2 0-3.4 2.5-6.5 7.1-6.5 3.7 0 6.6 2.7 6.6 6.2 0 3.7-2.3 6.7-5.6 6.7-1.1 0-2.1-.6-2.5-1.2 0 0-.5 2.1-.7 2.6-.2.9-.9 2-1.3 2.7 1 .3 2 .4 3.1.4 6.6 0 12-5.4 12-12S18.6 0 12 0z"/></svg></a>
          {%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'column' -%}
          <div class="sg-ft-col" {{ block.shopify_attributes }}>
            <h5>{{ block.settings.heading }}</h5>
            {%- if block.settings.menu != blank -%}
              {%- assign menu = linklists[block.settings.menu] -%}
              <ul>
                {%- for link in menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
            {%- if block.settings.whatsapp_url != blank -%}
              <a href="{{ block.settings.whatsapp_url }}" class="sg-ft-wa">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.4-.1-.6.1-.2.3-.7.9-.8 1-.2.2-.3.2-.6.1-.3-.1-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.4.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.1-.6-1.4-.8-2-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.3.3-1 .9-1 2.3 0 1.4 1 2.7 1.2 2.9.1.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.3.2-.7.2-1.2.2-1.3-.1-.1-.3-.2-.6-.3z"/><path d="M20.5 3.5A11.5 11.5 0 0 0 2.8 18.2L2 22l3.9-1C7.5 21.7 9 22 10.5 22h.1c6.3 0 11.5-5.2 11.5-11.5 0-3-1.2-5.9-3.3-8zm-8 17c-1.4 0-2.7-.4-3.8-1l-.3-.2-2.8.7.8-2.7-.2-.3A9.5 9.5 0 0 1 4.5 12c0-5.2 4.3-9.5 9.5-9.5 2.5 0 4.9 1 6.7 2.8A9.5 9.5 0 0 1 22 12c0 5.2-4.3 9.5-9.5 9.5z"/></svg>
                WhatsApp Us
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="sg-ft-bot">
      <div>{{ section.settings.copyright | default: '© 2026 Sky Goodies' }}</div>
      {%- if section.settings.bottom_right != blank -%}<div>{{ section.settings.bottom_right }}</div>{%- endif -%}
    </div>
  </div>
</footer>

<style>
.sg-ft-in { max-width: var(--sg-container); margin: 0 auto; padding: 0 var(--sg-gutter); }
.sg-ft-top {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
  margin-bottom: 40px;
  padding-bottom: 40px;
  border-bottom: 1px solid rgba(245,239,227,.15);
}
@media (min-width: 768px) { .sg-ft-top { grid-template-columns: 2fr 1fr 1fr 1fr; gap: 56px; } }
.sg-ft-brand img { height: 72px; margin-bottom: 18px; filter: brightness(0) invert(1); }
.sg-ft-tag {
  font-family: var(--sg-display);
  font-style: italic;
  font-weight: 400;
  font-size: 19px;
  margin-bottom: 18px;
}
.sg-ft-brand p { font-size: 13.5px; line-height: 1.6; max-width: 320px; margin-bottom: 22px; opacity: 0.85; }
.sg-ft-socials { display: flex; gap: 10px; }
.sg-ft-socials a {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: rgba(245,239,227,.1);
  color: inherit;
  display: flex; align-items: center; justify-content: center;
  transition: all .2s;
}
.sg-ft-socials a:hover { background: var(--sg-orange); color: #fff; }
.sg-ft-socials svg { width: 15px; height: 15px; }

.sg-ft-col h5 {
  font-family: var(--sg-sans);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 18px;
}
.sg-ft-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; margin: 0; padding: 0; }
.sg-ft-col a { font-size: 13.5px; color: inherit; opacity: 0.85; transition: opacity .15s, color .15s; }
.sg-ft-col a:hover { opacity: 1; color: var(--sg-butter); }
.sg-ft-wa {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 9px 16px;
  background: #25D366; color: #fff !important;
  border-radius: var(--sg-r-pill);
  font-size: 12px; font-weight: 600;
  margin-top: 10px;
  opacity: 1 !important;
  transition: transform .15s;
}
.sg-ft-wa:hover { transform: translateY(-1px); }
.sg-ft-wa svg { width: 13px; height: 13px; fill: currentColor; }

.sg-ft-bot {
  display: flex; justify-content: space-between;
  align-items: center; gap: 16px;
  flex-wrap: wrap;
  font-size: 12px;
  opacity: 0.65;
}
</style>

{% schema %}
{
  "name": "SG — Footer",
  "tag": "footer",
  "class": "section-sg-footer",
  "settings": [
    { "type": "header", "content": "Branding" },
    { "type": "image_picker", "id": "logo", "label": "Logo (will be color-inverted for dark footer)" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Simple joys in a complex world :)" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Handcrafted paper kits, designed in our Khar, Mumbai studio by NID-trained artists. Since 2013." },
    { "type": "header", "content": "Social" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "youtube_url", "label": "YouTube URL" },
    { "type": "url", "id": "pinterest_url", "label": "Pinterest URL" },
    { "type": "header", "content": "Bottom line" },
    { "type": "text", "id": "copyright", "label": "Copyright text", "default": "© 2026 Sky Goodies Products Pvt Ltd · Handcrafted in Mumbai 🇮🇳" },
    { "type": "text", "id": "bottom_right", "label": "Right side text", "default": "Free shipping over ₹1,000 · COD available" },
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#4A3D2F" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#F5EFE3" },
    { "type": "color", "id": "accent_color", "label": "Accent (tagline + column heads)", "default": "#F0D288" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 20, "max": 120, "step": 4, "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 20, "max": 80, "step": 4, "default": 28 }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" },
        { "type": "url", "id": "whatsapp_url", "label": "WhatsApp URL (optional, adds button below list)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Footer",
      "blocks": [
        { "type": "column", "settings": { "heading": "Shop" } },
        { "type": "column", "settings": { "heading": "Help" } },
        { "type": "column", "settings": { "heading": "Sky Goodies" } }
      ]
    }
  ]
}
{% endschema %}
