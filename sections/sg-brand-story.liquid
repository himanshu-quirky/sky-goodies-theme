<section class="sg-section sg-brand-story" style="background:{{ section.settings.background_color }}; padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="sg-container">
    <div class="sg-story-grid">
      <div class="sg-story-image">
        {% if section.settings.image != blank %}
          <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="" loading="lazy" referrerpolicy="no-referrer">
        {% endif %}
      </div>
      <div class="sg-story-content">
        <span class="sg-eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="sg-h2">{{ section.settings.heading }}</h2>
        <p>{{ section.settings.story_para_1 }}</p>
        <p>{{ section.settings.story_para_2 }}</p>
        {% if section.settings.link_url != blank %}
          <a href="{{ section.settings.link_url }}" class="sg-link-arrow">{{ section.settings.link_text }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SG Brand Story",
  "tag": "section",
  "class": "sg-brand-story-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "THE SKY GOODIES STORY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Paper can spark something wonderful"
    },
    {
      "type": "textarea",
      "id": "story_para_1",
      "label": "Story paragraph 1",
      "default": "What started in a tiny Mumbai studio in 2013 is now a workshop of 40 makers, designers and storytellers — all obsessed with the humble sheet of paper."
    },
    {
      "type": "textarea",
      "id": "story_para_2",
      "label": "Story paragraph 2",
      "default": "Every kit you receive has been folded, scored and packed by hand. We work with recycled paper, water-based inks and minimal plastic because the planet is part of the family too."
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Read the full story →"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL",
      "default": "/pages/about"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FAF6F0"
    }
  ],
  "presets": [
    {
      "name": "Brand story"
    }
  ]
}
{% endschema %}
