{{ 'sg-theme.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .sg-ig-{{ section.id }} {
    padding: {{ section.settings.mobile_padding | default: 64 }}px 0 {{ section.settings.mobile_padding_bottom | default: 56 }}px;
    background: {{ section.settings.bg_color | default: '#F5EFE3' }};
  }
  @media (min-width: 900px) {
    .sg-ig-{{ section.id }} {
      padding: {{ section.settings.desktop_padding | default: 96 }}px 0 {{ section.settings.desktop_padding_bottom | default: 72 }}px;
    }
  }
{%- endstyle -%}

<section class="sg-root sg-ig-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="sg-ig-head">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow">— {{ section.settings.eyebrow }} —</span>
    {%- endif -%}
    <h2>{{ section.settings.heading_line1 }}{%- if section.settings.heading_line2_em != blank -%}<br>it to our <em>{{ section.settings.heading_line2_em }}</em>{%- endif -%}</h2>
    <div class="handle">Follow <a href="{{ section.settings.ig_url | default: 'https://instagram.com/skygoodies.co' }}" target="_blank" rel="noopener">{{ section.settings.handle | default: '@skygoodies.co' }}</a>{% if section.settings.follower_count != blank %} · {{ section.settings.follower_count }} crafters{% endif %}</div>
  </div>

  <div class="sg-ig-grid" data-sg-ig-slot>
    {%- for block in section.blocks -%}
      <a class="sg-ig-tile" href="{{ block.settings.link | default: section.settings.ig_url }}" target="_blank" rel="noopener"
         {% if block.settings.image %}style="background-image: url('{{ block.settings.image | image_url: width: 600 }}');"{% endif %}
         {{ block.shopify_attributes }}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      </a>
    {%- endfor -%}
  </div>
</section>

<style>
.sg-ig-head {
  text-align: center;
  margin-bottom: 32px;
  padding: 0 var(--sg-gutter);
}
.sg-ig-head .eyebrow {
  font-family: var(--sg-sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--sg-muted);
  margin-bottom: 14px;
  display: block;
}
.sg-ig-head h2 {
  font-family: var(--sg-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(28px, 3.6vw, 42px);
  color: var(--sg-ink);
  letter-spacing: -0.02em;
  line-height: 1.05;
  margin-bottom: 14px;
}
.sg-ig-head h2 em { font-style: normal; font-weight: 500; color: var(--sg-terra); }
.sg-ig-head .handle { font-size: 13.5px; color: var(--sg-brown); }
.sg-ig-head .handle a { color: var(--sg-orange-dk); font-weight: 600; }

.sg-ig-grid {
  max-width: var(--sg-container);
  margin: 0 auto;
  padding: 0 var(--sg-gutter);
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 4px;
}
@media (min-width: 600px) { .sg-ig-grid { grid-template-columns: repeat(3, 1fr); gap: 6px; } }
@media (min-width: 900px) { .sg-ig-grid { grid-template-columns: repeat(6, 1fr); gap: 8px; } }
.sg-ig-tile {
  aspect-ratio: 1;
  border-radius: var(--sg-r-sm);
  overflow: hidden;
  background-size: cover;
  background-position: center;
  background-color: var(--sg-paper-2);
  position: relative;
  transition: transform .25s;
  cursor: pointer;
}
.sg-ig-tile:hover { transform: translateY(-2px); }
.sg-ig-tile::after {
  content: ''; position: absolute; inset: 0;
  background: rgba(26,22,20,0); transition: background .2s;
}
.sg-ig-tile:hover::after { background: rgba(26,22,20,.4); }
.sg-ig-tile svg {
  position: absolute; top: 10px; right: 10px;
  width: 18px; height: 18px;
  color: #fff; opacity: 0;
  transition: opacity .2s;
  z-index: 2;
}
.sg-ig-tile:hover svg { opacity: 1; }
</style>

{% schema %}
{
  "name": "SG — Instagram Feed",
  "tag": "section",
  "class": "section-sg-instagram-feed",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "In the wild" },
    { "type": "text", "id": "heading_line1", "label": "Heading line 1", "default": "Tag us and you might make" },
    { "type": "text", "id": "heading_line2_em", "label": "Heading line 2 (italic)", "default": "Instagram." },
    { "type": "text", "id": "handle", "label": "Instagram handle", "default": "@skygoodies.co" },
    { "type": "text", "id": "follower_count", "label": "Follower count text", "default": "87K+" },
    { "type": "url", "id": "ig_url", "label": "Instagram profile URL" },
    { "type": "paragraph", "content": "If Insta Feed app is installed, it will replace these tiles with live posts." },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F5EFE3" },
    { "type": "range", "id": "mobile_padding", "label": "Mobile top padding", "min": 20, "max": 120, "step": 4, "default": 64 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Mobile bottom padding", "min": 20, "max": 120, "step": 4, "default": 56 },
    { "type": "range", "id": "desktop_padding", "label": "Desktop top padding", "min": 20, "max": 200, "step": 4, "default": 96 },
    { "type": "range", "id": "desktop_padding_bottom", "label": "Desktop bottom padding", "min": 20, "max": 200, "step": 4, "default": 72 }
  ],
  "max_blocks": 12,
  "blocks": [
    {
      "type": "post",
      "name": "Instagram post",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Post URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SG — Instagram Feed",
      "blocks": [
        { "type": "post" }, { "type": "post" }, { "type": "post" }, { "type": "post" }, { "type": "post" }, { "type": "post" }
      ]
    }
  ]
}
{% endschema %}
