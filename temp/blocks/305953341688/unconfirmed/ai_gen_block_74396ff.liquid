{% doc %}
  @prompt
    Create a breadcrumbs section that is optimised for mobile and desktop view. Don't use any icons. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-breadcrumbs-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-breadcrumbs-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-breadcrumbs-list-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: {{ block.settings.spacing }}px;
    font-size: {{ block.settings.font_size }}px;
    line-height: 1.5;
  }

  .ai-breadcrumbs-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-breadcrumbs-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .ai-breadcrumbs-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
    text-decoration: {{ block.settings.hover_underline }};
  }

  .ai-breadcrumbs-separator-{{ ai_gen_id }} {
    color: {{ block.settings.separator_color }};
    user-select: none;
  }

  .ai-breadcrumbs-current-{{ ai_gen_id }} {
    color: {{ block.settings.current_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-breadcrumbs-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 0 {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-breadcrumbs-container-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .ai-breadcrumbs-list-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
      gap: {{ block.settings.spacing_mobile }}px;
    }

    .ai-breadcrumbs-item-{{ ai_gen_id }} {
      gap: {{ block.settings.spacing_mobile }}px;
    }

    {% if block.settings.hide_on_mobile %}
      .ai-breadcrumbs-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}
  }
{% endstyle %}

<nav
  class="ai-breadcrumbs-{{ ai_gen_id }}"
  aria-label="Breadcrumb"
  {{ block.shopify_attributes }}
>
  <div class="ai-breadcrumbs-container-{{ ai_gen_id }}">
    <ol class="ai-breadcrumbs-list-{{ ai_gen_id }}">
      <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
        <a href="/" class="ai-breadcrumbs-link-{{ ai_gen_id }}">{{ block.settings.home_text }}</a>
      </li>

      {% if collection %}
        <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumbs-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        </li>
        {% if product %}
          <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
            <a href="{{ collection.url }}" class="ai-breadcrumbs-link-{{ ai_gen_id }}">{{ collection.title }}</a>
          </li>
        {% else %}
          <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumbs-current-{{ ai_gen_id }}">{{ collection.title }}</span>
          </li>
        {% endif %}
      {% endif %}

      {% if product %}
        {% unless collection %}
          <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumbs-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
          </li>
          <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
            <a href="/collections/all" class="ai-breadcrumbs-link-{{ ai_gen_id }}">Products</a>
          </li>
        {% endunless %}
        <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumbs-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        </li>
        <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumbs-current-{{ ai_gen_id }}">{{ product.title }}</span>
        </li>
      {% endif %}

      {% if page %}
        <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumbs-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        </li>
        <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumbs-current-{{ ai_gen_id }}">{{ page.title }}</span>
        </li>
      {% endif %}

      {% if blog %}
        <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumbs-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        </li>
        {% if article %}
          <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
            <a href="{{ blog.url }}" class="ai-breadcrumbs-link-{{ ai_gen_id }}">{{ blog.title }}</a>
          </li>
        {% else %}
          <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumbs-current-{{ ai_gen_id }}">{{ blog.title }}</span>
          </li>
        {% endif %}
      {% endif %}

      {% if article %}
        <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumbs-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        </li>
        <li class="ai-breadcrumbs-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumbs-current-{{ ai_gen_id }}">{{ article.title }}</span>
        </li>
      {% endif %}
    </ol>
  </div>
</nav>

{% schema %}
{
  "name": "Breadcrumbs",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "home_text",
      "label": "Home text",
      "default": "Home"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "/"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover",
      "default": "#82a31a"
    },
    {
      "type": "color",
      "id": "current_color",
      "label": "Current page",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator",
      "default": "#999999"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Desktop font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Mobile font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "hover_underline",
      "label": "Hover underline",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "underline",
          "label": "Underline"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Desktop item spacing",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "spacing_mobile",
      "label": "Mobile item spacing",
      "min": 4,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Desktop top padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Desktop bottom padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile top padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile bottom padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Breadcrumbs"
    }
  ]
}
{% endschema %}
