{%- comment -%}Accepts: product: {Object} Product Liquid object (optional){%- endcomment -%}
<div class="pc">
  <div class="pc__img">
    <a href="{{ product.url | default: '#' }}">
      {%- if product.featured_image != blank -%}
        <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" width="400" height="400" loading="lazy">
      {%- else -%}
        <img src="https://placehold.co/400x400/F2EBDF/FD9963?text=Product" alt="Product placeholder" width="400" height="400" loading="lazy">
      {%- endif -%}
    </a>
    <div class="pc__badges">
      {%- for tag in product.tags -%}
        {%- if tag contains 'Ages' or tag contains 'min' or tag == 'New' -%}<span class="pc__badge {% if tag == 'New' %}pc__badge--a{% endif %}">{{ tag }}</span>{%- endif -%}
      {%- endfor -%}
    </div>
    <button class="pc__wish" aria-label="Wishlist"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></button>
  </div>
  <div class="pc__info">
    <div class="pc__stars">{%- for i in (1..5) -%}<svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>{%- endfor -%}<span>5.0</span></div>
    <h3 class="pc__title"><a href="{{ product.url | default: '#' }}">{{ product.title | default: 'Paper Craft Kit' }}</a></h3>
    <p class="pc__hook">{%- if product.metafields.custom.hook != blank -%}{{ product.metafields.custom.hook }}{%- else -%}A beautiful paper kit to make and cherish.{%- endif -%}</p>
    <div class="pc__tags">{%- for tag in product.tags -%}{%- unless tag contains 'Ages' or tag contains 'min' or tag == 'New' -%}<span class="pc__tag">{{ tag }}</span>{%- endunless -%}{%- endfor -%}</div>
    <div class="pc__bot">
      <span class="pc__price">{%- if product != blank -%}{{ product.price | money_without_trailing_zeros }}{%- if product.compare_at_price > product.price -%}<s>{{ product.compare_at_price | money_without_trailing_zeros }}</s>{%- endif -%}{%- else -%}₹599{%- endif -%}</span>
      {%- if product != blank -%}
        {%- form 'product', product, style: "margin:0;padding:0;display:flex;" -%}<input type="hidden" name="id" value="{{ product.variants.first.id }}"><button type="submit" class="pc__atc" {% if product.available == false %}disabled{% endif %}>{%- if product.available == false -%}Sold out{%- else -%}Add to Cart{%- endif -%}</button>{%- endform -%}
      {%- else -%}<button class="pc__atc" type="button">Add to Cart</button>{%- endif -%}
    </div>
  </div>
</div>
