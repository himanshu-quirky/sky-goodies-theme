{%- comment -%}
  Sky Goodies v5 product card.
  Usage: {% render 'sg-product-card', product: product %}
{%- endcomment -%}

{%- liquid
  assign sg_build_time = product.metafields.custom.build_time
  assign sg_age = product.metafields.custom.age
  assign sg_difficulty = product.metafields.custom.difficulty

  if sg_build_time == blank
    assign sg_build_time = '2 hrs'
  endif
  if sg_age == blank
    assign sg_age = 'All ages'
  endif
  if sg_difficulty == blank
    assign sg_difficulty = 'Easy'
  endif

  assign sg_on_sale = false
  if product.compare_at_price > product.price
    assign sg_on_sale = true
  endif
-%}

<article class="sg-product-card">
  <a href="{{ product.url }}" class="sg-product-card__img-link" aria-label="{{ product.title | escape }}">
    <div class="sg-product-card__img">
      {%- if sg_on_sale -%}
        {%- assign sg_save_pct = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
        <span class="sg-product-card__badge sg-product-card__badge--sale">{{ sg_save_pct }}% OFF</span>
      {%- elsif product.tags contains 'New' or product.tags contains 'new' -%}
        <span class="sg-product-card__badge sg-product-card__badge--new">NEW</span>
      {%- endif -%}
      {%- if product.featured_image != blank -%}
        {{ product.featured_image | image_url: width: 600 | image_tag:
          widths: '300,400,600,800',
          sizes: '(max-width: 768px) 50vw, 25vw',
          alt: product.title,
          loading: 'lazy',
          class: 'sg-product-card__image'
        }}
      {%- else -%}
        <div class="sg-product-card__placeholder">{{ product.title }}</div>
      {%- endif -%}
    </div>
  </a>

  <div class="sg-product-card__body">
    <div class="sg-product-card__pills">
      <span class="sg-pill">{{ sg_build_time }}</span>
      <span class="sg-pill">{{ sg_age }}</span>
      <span class="sg-pill">{{ sg_difficulty }}</span>
    </div>

    {%- if product.type != blank -%}
      <span class="sg-product-card__type">{{ product.type }}</span>
    {%- endif -%}

    <h3 class="sg-product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>

    <div class="sg-product-card__price-row">
      <span class="sg-product-card__price">
        {{ product.price | money }}
        {%- if sg_on_sale -%}
          <span class="sg-product-card__strike">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
      </span>
    </div>

    {%- form 'product', product, class: 'sg-product-card__form' -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <button type="submit" class="sg-atc-btn" {% unless product.available %}disabled{% endunless %}>
        {%- if product.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
      </button>
    {%- endform -%}
  </div>
</article>
